<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>Teknik Elektronika - Politeknik Dewantara</title>
    <!-- Bootstrap 5.1.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js (hanya library, tanpa inisialisasi) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        body {
            background-color: #f8fafc;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding-top: 76px;
        }
        .navbar-custom {
            background: linear-gradient(135deg, #2193b0, #6dd5ed);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: white !important;
            font-weight: 500;
        }
        .navbar-custom .nav-link {
            position: relative;
            margin: 0 0.2rem;
            padding: 0.5rem 1rem;
            border-radius: 50px;
        }
        .navbar-custom .nav-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%) scaleX(0);
            width: 70%;
            height: 2px;
            background: white;
            border-radius: 2px;
            transition: transform 0.3s;
        }
        .navbar-custom .nav-link:hover::before {
            transform: translateX(-50%) scaleX(1);
        }
        .navbar-custom .nav-link:hover {
            color: rgba(255,255,255,0.9) !important;
            transform: translateY(-1px);
        }
        .navbar-toggler {
            border-color: rgba(255,255,255,0.5);
        }
        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255,255,255,0.8)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }
        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .navbar-brand img {
            height: 70px;
            width: auto;
            transition: height 0.3s;
        }
        .separator {
            color: white;
            font-size: 2.5rem;
            font-weight: 200;
            opacity: 0.7;
            line-height: 1;
            margin: 0 5px;
        }
        .brand-text {
            font-size: 1.4rem;
            font-weight: 700;
            line-height: 1.3;
            color: white;
            text-decoration: none;
        }
        .brand-sub {
            font-size: 0.9rem;
            font-weight: 400;
            opacity: 0.9;
            display: block;
        }
        @media (max-width: 768px) {
            body { padding-top: 66px; }
            .navbar-brand img { height: 50px; }
            .separator { font-size: 2rem; }
            .brand-text { font-size: 1rem; }
            .brand-sub { font-size: 0.7rem; }
        }
        @media (max-width: 576px) {
            body { padding-top: 60px; }
            .navbar-brand { gap: 5px; }
            .navbar-brand img { height: 40px; }
            .separator { font-size: 1.5rem; }
            .brand-text { font-size: 0.85rem; }
            .brand-sub { font-size: 0.7rem; }
        }
    </style>
</head>
<body>
    <!-- Navbar Fixed -->
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" alt="Logo Politeknik Dewantara">
                <span class="separator">|</span>
                <span class="brand-text">
                    TEKNIK ELEKTRONIKA (D3)
                    <span class="brand-sub">by Politeknik Dewantara</span>
                </span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#berita"><i class="bi bi-newspaper me-1"></i>Berita</a></li>
                    <li class="nav-item"><a class="nav-link" href="#statistik"><i class="bi bi-bar-chart-steps me-1"></i>Statistik</a></li>
                    <li class="nav-item"><a class="nav-link" href="#seminar"><i class="bi bi-calendar-event me-1"></i>Seminar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/login"><i class="bi bi-box-arrow-in-right me-1"></i>Portal Mahasiswa</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/login?role=admin"><i class="bi bi-shield-lock me-1"></i>Portal Dosen</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Konten Utama (kosong) -->
    <div class="container">
        <!-- Halaman siap diisi dengan konten landing page -->
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Smooth scroll untuk anchor links -->
    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });
    </script>
</body>
</html>