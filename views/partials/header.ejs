<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>Teknik Elektronika - Politeknik Dewantara</title>
    <!-- Bootstrap 5.1.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js (opsional) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        body {
            background-color: #f8fafc;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding-top: 76px; /* Tinggi navbar */
            overflow-x: hidden;
        }

        /* Navbar dengan gradien modern dan efek scroll */
        .navbar-custom {
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
        }

        .navbar-custom.scrolled {
            background: rgba(30, 58, 138, 0.9);
            backdrop-filter: blur(8px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: white !important;
            font-weight: 500;
            transition: color 0.3s, transform 0.2s;
        }

        .navbar-custom .nav-link {
            position: relative;
            margin: 0 0.2rem;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            transition: all 0.3s;
        }

        .navbar-custom .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
            color: #fff !important;
        }

        .navbar-custom .nav-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%) scaleX(0);
            width: 70%;
            height: 2px;
            background: white;
            border-radius: 2px;
            transition: transform 0.3s;
        }

        .navbar-custom .nav-link:hover::before {
            transform: translateX(-50%) scaleX(1);
        }

        .navbar-toggler {
            border-color: rgba(255,255,255,0.5);
            transition: all 0.3s;
        }

        .navbar-toggler:hover {
            border-color: white;
            background-color: rgba(255,255,255,0.1);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255,255,255,0.8)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-brand img {
            height: 70px;
            width: auto;
            transition: height 0.3s, transform 0.3s;
        }

        .navbar-brand:hover img {
            transform: scale(1.05);
        }

        .separator {
            color: white;
            font-size: 2.5rem;
            font-weight: 200;
            opacity: 0.7;
            line-height: 1;
            margin: 0 5px;
            transition: opacity 0.3s;
        }

        .brand-text {
            font-size: 1.4rem;
            font-weight: 700;
            line-height: 1.3;
            color: white;
            text-decoration: none;
        }

        .brand-sub {
            font-size: 0.9rem;
            font-weight: 400;
            opacity: 0.9;
            display: block;
        }

        /* Dropdown menu */
        .dropdown-menu {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 0.5rem;
            margin-top: 0.5rem;
        }

        .dropdown-item {
            border-radius: 0.7rem;
            padding: 0.5rem 1rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .dropdown-item:hover {
            background: linear-gradient(135deg, #2193b0, #6dd5ed);
            color: white;
        }

        /* HP kecil (375px, iPhone 6/7/8/X) */
@media (max-width: 390px) {
    .navbar-brand img {
        height: 35px;
    }
    .brand-text {
        font-size: 0.8rem;
    }
    .brand-sub {
        font-size: 0.6rem;
    }
    .navbar-nav .nav-link {
        font-size: 0.85rem;
        padding: 0.4rem 0.6rem;
    }
}

/* HP sangat kecil (320px, iPhone SE) */
@media (max-width: 340px) {
    .navbar-brand img {
        height: 30px;
    }
    .separator {
        font-size: 1.2rem;
        margin: 0 2px;
    }
    .brand-text {
        font-size: 0.7rem;
    }
    .brand-sub {
        font-size: 0.5rem;
    }
    .navbar-nav .nav-link {
        font-size: 0.8rem;
        padding: 0.3rem 0.5rem;
    }
    .navbar-brand {
        gap: 3px;
    }
}

/* HP besar (428px, iPhone Pro Max) */
@media (min-width: 430px) and (max-width: 480px) {
    .navbar-brand img {
        height: 45px;
    }
    .brand-text {
        font-size: 0.95rem;
    }
}
        /* ===== RESPONSIVE UNTUK TABLET DAN HP ===== */
        @media (max-width: 991px) {
            /* Navbar collapse background di mobile */
            .navbar-collapse {
                background: rgba(30, 58, 138, 0.95);
                backdrop-filter: blur(8px);
                border-radius: 1rem;
                padding: 1rem;
                margin-top: 0.5rem;
                border: 1px solid rgba(255,255,255,0.1);
            }
            /* Item menu di mobile lebih rapat */
            .navbar-nav .nav-link {
                margin: 0.2rem 0;
                padding: 0.6rem 1rem;
                text-align: left;
            }
            /* Dropdown menu di mobile tampil tanpa shadow berlebih */
            .dropdown-menu {
                background: transparent;
                box-shadow: none;
                padding-left: 1rem;
                margin-top: 0;
                border-left: 2px solid rgba(255,255,255,0.2);
            }
            .dropdown-item {
                color: white !important;
                padding: 0.5rem 1rem;
            }
            .dropdown-item:hover {
                background: rgba(255,255,255,0.1);
                color: white;
            }
        }

        @media (max-width: 768px) {
            body { padding-top: 66px; }
            .navbar-brand img { height: 50px; }
            .separator { font-size: 2rem; }
            .brand-text { font-size: 1rem; }
            .brand-sub { font-size: 0.7rem; }
            /* Ukuran font menu */
            .navbar-nav .nav-link {
                font-size: 0.95rem;
            }
        }

        @media (max-width: 576px) {
            body { padding-top: 60px; }
            .navbar-brand { gap: 5px; }
            .navbar-brand img { height: 40px; }
            .separator { font-size: 1.5rem; }
            .brand-text { font-size: 0.85rem; }
            .brand-sub { font-size: 0.65rem; }
            .navbar-nav .nav-link {
                font-size: 0.9rem;
                padding: 0.5rem 0.8rem;
            }
            /* Kurangi padding container */
            .container {
                padding-left: 10px;
                padding-right: 10px;
            }
        }

        /* Landscape HP */
        @media (max-height: 500px) and (orientation: landscape) {
            body { padding-top: 60px; }
            .navbar-brand img { height: 35px; }
            .brand-text { font-size: 0.8rem; }
        }

        /* Pembungkus konten (opsional) */
        .content-wrapper {
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            padding-left: 1rem;
            padding-right: 1rem;
            width: 100%;
        }
    </style>
</head>
<body>
    <!-- Navbar Fixed -->
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top" id="mainNavbar">
        <div class="container">
            <%
                let dashboardLink = '/';
                if (typeof user !== 'undefined' && user) {
                    if (user.role === 'mahasiswa') {
                        dashboardLink = '/mahasiswa/dashboard';
                    } else if (user.role === 'dosen') {
                        dashboardLink = '/dosen/dashboard';
                    } else if (user.role === 'admin') {
                        dashboardLink = '/admin/dashboard';
                    }
                }
            %>
            <a class="navbar-brand" href="<%= dashboardLink %>">
                <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" alt="Logo Politeknik Dewantara">
                <span class="separator">|</span>
                <span class="brand-text">
                    TEKNIK ELEKTRONIKA
                    <span class="brand-sub">by Politeknik Dewantara</span>
                </span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <% if (user.role === 'mahasiswa') { %>
                            <li class="nav-item"><a class="nav-link" href="/mahasiswa/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/mahasiswa/akademik"><i class="bi bi-journal-bookmark-fill me-1"></i>Akademik</a></li>
                            <li class="nav-item"><a class="nav-link" href="/mahasiswa/elearning"><i class="bi bi-laptop me-1"></i>ELK-Learning</a></li>
                            <li class="nav-item"><a class="nav-link" href="/mahasiswa/magang"><i class="bi bi-briefcase me-1"></i>ELK-Magang</a></li>
                        <% } else if (user.role === 'dosen') { %>
                            <li class="nav-item"><a class="nav-link" href="/dosen/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/dosen/mk"><i class="bi bi-book me-1"></i>Mata Kuliah</a></li>
                            <li class="nav-item"><a class="nav-link" href="/dosen/mahasiswa"><i class="bi bi-people me-1"></i>Mahasiswa Bimbingan</a></li>
                            <li class="nav-item"><a class="nav-link" href="/dosen/nilai"><i class="bi bi-bar-chart me-1"></i>Nilai</a></li>
                        <% } else if (user.role === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i>Pengguna</a></li>
                            <li class="nav-item"><a class="nav-link" href="/admin/mahasiswa"><i class="bi bi-mortarboard me-1"></i>Mahasiswa</a></li>
                            <li class="nav-item"><a class="nav-link" href="/admin/dosen"><i class="bi bi-person-badge me-1"></i>Dosen</a></li>
                            <li class="nav-item"><a class="nav-link" href="/admin/matakuliah"><i class="bi bi-book me-1"></i>Mata Kuliah</a></li>
                        <% } %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= user.nama || user.email %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                <li><a class="dropdown-item" href="<%= user.role === 'mahasiswa' ? '/mahasiswa/biodata' : (user.role === 'dosen' ? '/dosen/biodata' : '/admin/biodata') %>"><i class="bi bi-person me-2"></i>Profil</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/auth/login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Smooth scroll untuk anchor links (opsional) -->
    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Efek scroll untuk navbar
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('mainNavbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });
    </script>