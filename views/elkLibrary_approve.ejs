<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-check2-circle me-2"></i>Setujui Karya</h3>
    </div>
    <div class="form-body">
      <p><strong>Judul:</strong> <%= item.judul %></p>
      <p><strong>Penulis:</strong> <%= item.penulis %></p>
      <p><strong>Abstrak:</strong></p>
      <p><%= item.abstrak || item.abstract %></p>
      <p><strong>File:</strong> <a href="<%= item.fileUrl %>" target="_blank">Lihat</a></p>

      <form method="POST" action="/admin/elk-library/<%= item.id %>/approve">
        <div class="mb-3">
          <label for="catatan" class="form-label fw-bold">Catatan (opsional)</label>
          <textarea class="form-control" id="catatan" name="catatan" rows="2"></textarea>
        </div>
        <div class="d-flex gap-3">
          <button type="submit" name="action" value="approve" class="btn btn-success">Setujui</button>
          <button type="submit" name="action" value="reject" class="btn btn-danger">Tolak</button>
          <a href="/admin/elk-library" class="btn btn-secondary">Kembali</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>