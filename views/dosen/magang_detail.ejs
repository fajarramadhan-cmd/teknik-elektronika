<%- include('../partials/header') %>

<%
  // ========== DEFAULT VALUES ==========
  if (typeof mahasiswa === 'undefined') mahasiswa = { nama: '-', nim: '-', email: '-', noHp: '-', foto: null };
  if (typeof logbookList === 'undefined') logbookList = [];
  if (typeof semesterList === 'undefined') semesterList = [];
  if (typeof allPeriods === 'undefined') allPeriods = [];
  if (typeof selectedPeriod === 'undefined') selectedPeriod = null;
  if (typeof pdkStats === 'undefined') pdkStats = [];
  if (typeof selectedSemester === 'undefined') selectedSemester = '';
  if (typeof role === 'undefined') role = null;
  if (typeof isPembimbing1 === 'undefined') isPembimbing1 = false;
  if (typeof isPembimbing2 === 'undefined') isPembimbing2 = false;
  
  // Fungsi untuk mendapatkan URL gambar dari Google Drive
  const getImageUrl = (url, size = 200) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    return url;
  };

  // Fungsi untuk mendapatkan fileId dari URL
  const getFileId = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    match = url.match(/\/file\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
  
  // Format tanggal
  const formatTanggal = (dateString) => {
    if (!dateString) return '-';
    const date = new Date(dateString);
    return date.toLocaleDateString('id-ID', {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    });
  };
%>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --gray-border: #e2e8f0;
  }

  html { font-size: 16px; }
  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Alert Messages */
  .alert-fixed {
    position: fixed;
    top: 80px;
    right: 20px;
    z-index: 9999;
    min-width: 300px;
    animation: slideIn 0.3s ease;
  }
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  /* Profile Card */
  .profile-card {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .profile-card .avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .avatar-circle-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: white;
    color: var(--primary-start);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 600;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .profile-card h2 {
    font-weight: 700;
    margin-bottom: 0.3rem;
    font-size: 1.8rem;
  }
  .profile-card p {
    margin-bottom: 0.2rem;
    opacity: 0.9;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.95rem;
  }

  /* Role Badge */
  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .role-pembimbing2 {
    background: linear-gradient(135deg, #10b981, #34d399);
    color: white;
    box-shadow: 0 5px 15px rgba(16,185,129,0.3);
  }
  .role-pembimbing1 {
    background: linear-gradient(135deg, #6c757d, #adb5bd);
    color: white;
  }

  /* Filter Cards */
  .filter-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid var(--gray-border);
  }
  .filter-card .form-select, .filter-card .form-control {
    border-radius: 50px;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }

  /* PDK Stats Cards */
  .pdk-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    background: white;
    border-radius: 1rem;
    padding: 1rem;
    text-align: center;
    border: 1px solid var(--gray-border);
    transition: all 0.3s;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  .stat-card.active {
    border: 2px solid var(--primary-start);
    background: var(--primary-light);
  }
  .stat-card .pdk-kode {
    font-weight: 700;
    color: var(--primary-start);
    font-size: 0.8rem;
  }
  .stat-card .pdk-nama {
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .stat-card .stat-numbers {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .stat-card .stat-item {
    text-align: center;
  }
  .stat-card .stat-value {
    font-weight: 700;
    font-size: 1.2rem;
  }
  .stat-card .stat-label {
    font-size: 0.7rem;
    color: #64748b;
  }
  .stat-card.pending .stat-value { color: #f59e0b; }
  .stat-card.approved .stat-value { color: #10b981; }
  .stat-card.rejected .stat-value { color: #ef4444; }

  /* Page Header */
  .page-header {
    background: white;
    border-radius: 1.2rem;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid var(--gray-border);
  }
  .page-header h4 {
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.3rem;
  }
  .page-header .btn-group {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .btn-print {
    background: #17a2b8;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    color: white;
    font-weight: 500;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-print:hover {
    background: #138496;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(23,162,184,0.3);
    color: white;
  }
  .btn-back {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    color: var(--primary-start);
    font-weight: 500;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-back:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }

  /* Tabel */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid var(--gray-border);
    padding: 0;
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .logbook-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .logbook-table thead th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
    text-align: center;
  }
  .logbook-table tbody td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .logbook-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* Thumbnail */
  .thumbnail {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 10px;
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    transition: transform 0.2s;
  }
  .thumbnail:hover {
    transform: scale(1.1);
    box-shadow: 0 5px 10px rgba(0,0,0,0.2);
  }

  /* Badge Status */
  .badge-status {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
    border: 1px solid #a7f3d0;
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
    border: 1px solid #fecaca;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
    border: 1px solid #fde68a;
  }

  /* Tombol Aksi */
  .btn-approve {
    background: #10b981;
    border: none;
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-approve:hover {
    background: #059669;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(16,185,129,0.3);
  }
  .btn-reject {
    background: #ef4444;
    border: none;
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-reject:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(239,68,68,0.3);
  }

  /* Modal */
  .modal-content {
    border: none;
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .modal-header-custom {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-bottom: none;
    padding: 1.2rem 1.5rem;
  }
  .modal-header-custom .btn-close {
    background: rgba(255,255,255,0.8);
    opacity: 0.8;
  }
  .modal-header-custom .btn-close:hover {
    opacity: 1;
    transform: rotate(90deg);
  }

  /* Lightbox Modal */
  .lightbox-modal .modal-content {
    border: none;
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .lightbox-modal .modal-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-bottom: none;
  }
  .lightbox-modal .modal-body {
    padding: 0;
    background: #000;
  }
  .lightbox-modal .carousel-item img {
    max-height: 80vh;
    object-fit: contain;
  }

  /* Empty State */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1.1rem;
  }

  /* Info Period */
  .info-period {
    background: var(--info-bg);
    border-left: 4px solid var(--primary-start);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .profile-card h2 { font-size: 1.5rem; }
    .profile-card .avatar-large { width: 60px; height: 60px; }
    .avatar-circle-large { width: 60px; height: 60px; font-size: 2rem; }
    .page-header { flex-direction: column; align-items: stretch; }
    .page-header .btn-group { justify-content: center; }
    .pdk-stats { grid-template-columns: repeat(2, 1fr); }
    .logbook-table thead th { font-size: 0.8rem; padding: 0.8rem; }
    .logbook-table tbody td { font-size: 0.9rem; padding: 0.8rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .profile-card h2 { font-size: 1.3rem; }
    .pdk-stats { grid-template-columns: 1fr; }
    .logbook-table thead th { font-size: 0.75rem; padding: 0.6rem; }
    .logbook-table tbody td { font-size: 0.85rem; padding: 0.6rem; }
    .badge-status { font-size: 0.7rem; padding: 0.3rem 0.8rem; }
    .btn-approve, .btn-reject { padding: 0.2rem 0.8rem; font-size: 0.7rem; }
    .btn-print, .btn-back { padding: 0.4rem 1rem; font-size: 0.8rem; }
  }
</style>

<div class="container mt-4">
  <!-- Alert Messages -->
  <% if (session && session.success) { %>
    <div class="alert alert-success alert-dismissible fade show alert-fixed" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> <%= session.success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  
  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show alert-fixed" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Profile Card Mahasiswa -->
  <div class="profile-card">
    <div class="d-flex align-items-center flex-wrap">
      <div class="flex-shrink-0 me-4 mb-2 mb-sm-0">
        <% 
          const fotoUrl = mahasiswa.foto ? getImageUrl(mahasiswa.foto, 200) : null;
          if (fotoUrl) { 
        %>
          <img src="<%= fotoUrl %>" alt="foto <%= mahasiswa.nama %>" class="avatar-large" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(mahasiswa.nama) %>&background=1e3a8a&color=fff&size=80';">
        <% } else { %>
          <div class="avatar-circle-large">
            <%= (mahasiswa.nama || '?').charAt(0).toUpperCase() %>
          </div>
        <% } %>
      </div>
      <div>
        <h2 class="fw-bold"><%= mahasiswa.nama %></h2>
        <p><i class="bi bi-qr-code"></i> NIM: <%= mahasiswa.nim %></p>
        <p><i class="bi bi-envelope"></i> <%= mahasiswa.email %></p>
        <p class="mb-0"><i class="bi bi-telephone"></i> <%= mahasiswa.noHp || '-' %></p>
      </div>
    </div>
  </div>

  <!-- Role Badge -->
  <% if (isPembimbing2) { %>
    <div class="role-badge role-pembimbing2">
      <i class="bi bi-check-circle-fill"></i> Anda sebagai Pembimbing 2 - Anda dapat menyetujui/menolak logbook
    </div>
  <% } else if (isPembimbing1) { %>
    <div class="role-badge role-pembimbing1">
      <i class="bi bi-eye-fill"></i> Anda sebagai Pembimbing 1 - Hanya dapat melihat logbook (Read Only)
    </div>
  <% } %>

  <!-- Header dengan judul dan tombol -->
  <div class="page-header">
    <h4>
      <i class="bi bi-journal-bookmark-fill" style="color: var(--primary-start);"></i> Logbook Magang
    </h4>
    <div class="btn-group">
      <a href="/dosen/magang/print/<%= mahasiswa.id %><%= selectedPeriod ? `?periodId=${selectedPeriod.id}` : '' %>" class="btn-print" target="_blank">
        <i class="bi bi-printer"></i> Print
      </a>
      <a href="/dosen/magang" class="btn-back">
        <i class="bi bi-arrow-left"></i> Kembali
      </a>
    </div>
  </div>

  <!-- PDK Stats Cards (Filter Periode) -->
  <% if (allPeriods && allPeriods.length > 0) { %>
    <div class="pdk-stats">
      <a href="/dosen/magang/<%= mahasiswa.id %>" class="stat-card <%= !selectedPeriod ? 'active' : '' %>">
        <div class="pdk-kode">SEMUA</div>
        <div class="pdk-nama">Semua Periode</div>
        <div class="stat-numbers">
          <div class="stat-item pending">
            <div class="stat-value"><%= pdkStats.reduce((sum, s) => sum + s.pendingCount, 0) %></div>
            <div class="stat-label">Pending</div>
          </div>
          <div class="stat-item approved">
            <div class="stat-value"><%= pdkStats.reduce((sum, s) => sum + s.approvedCount, 0) %></div>
            <div class="stat-label">Approved</div>
          </div>
          <div class="stat-item rejected">
            <div class="stat-value"><%= pdkStats.reduce((sum, s) => sum + s.rejectedCount, 0) %></div>
            <div class="stat-label">Rejected</div>
          </div>
        </div>
      </a>
      <% allPeriods.forEach(period => { 
        const stats = pdkStats.find(s => s.id === period.id) || { pendingCount: 0, approvedCount: 0, rejectedCount: 0 };
      %>
        <a href="/dosen/magang/<%= mahasiswa.id %>?periodId=<%= period.id %>" class="stat-card <%= selectedPeriod && selectedPeriod.id === period.id ? 'active' : '' %>">
          <div class="pdk-kode"><%= period.pdkKode %></div>
          <div class="pdk-nama"><%= period.pdkNama %></div>
          <div class="stat-numbers">
            <div class="stat-item pending">
              <div class="stat-value"><%= stats.pendingCount %></div>
              <div class="stat-label">Pending</div>
            </div>
            <div class="stat-item approved">
              <div class="stat-value"><%= stats.approvedCount %></div>
              <div class="stat-label">Approved</div>
            </div>
            <div class="stat-item rejected">
              <div class="stat-value"><%= stats.rejectedCount %></div>
              <div class="stat-label">Rejected</div>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

  <!-- Info Periode Aktif -->
  <% if (selectedPeriod) { %>
    <div class="info-period">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
          <strong><i class="bi bi-info-circle"></i> Periode Magang:</strong> 
          <%= selectedPeriod.pdkKode %> - <%= selectedPeriod.pdkNama %>
          (<%= formatTanggal(selectedPeriod.tanggalMulai) %> 
          <%= selectedPeriod.tanggalSelesai ? `s/d ${formatTanggal(selectedPeriod.tanggalSelesai)}` : 'Berlangsung' %>)
        </div>
        <% if (selectedPeriod.perusahaan && selectedPeriod.perusahaan.nama) { %>
          <div class="mt-1 mt-sm-0">
            <i class="bi bi-building"></i> <%= selectedPeriod.perusahaan.nama %>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Filter Semester -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label fw-semibold"><i class="bi bi-funnel"></i> Filter Semester</label>
        <select name="semester" class="form-select" onchange="this.form.submit()">
          <option value="">Semua Semester</option>
          <% if (semesterList && semesterList.length > 0) { %>
            <% semesterList.forEach(s => { %>
              <option value="<%= s %>" <%= selectedSemester === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <% if (selectedPeriod) { %>
        <input type="hidden" name="periodId" value="<%= selectedPeriod.id %>">
      <% } %>
    </form>
  </div>

  <!-- Tabel Logbook -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table logbook-table">
        <thead>
          <tr>
            <th style="text-align: center;">No</th>
            <th>Tanggal</th>
            <th>Kegiatan</th>
            <th style="text-align: center;">Durasi</th>
            <th>Lokasi</th>
            <th>Semester</th>
            <th style="text-align: center;">Gambar</th>
            <th style="text-align: center;">Status</th>
            <% if (isPembimbing2) { %>
              <th style="text-align: center;">Aksi</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (logbookList.length === 0) { %>
            <tr>
              <td colspan="<%= isPembimbing2 ? 9 : 8 %>" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p>Belum ada logbook untuk periode ini.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% logbookList.forEach((item, index) => { %>
              <tr>
                <td style="text-align: center; font-weight: 600;"><%= index + 1 %></td>
                <td><%= item.tanggalFormatted %></td>
                <td style="max-width: 300px;"><%= item.kegiatan %></td>
                <td style="text-align: center;"><%= item.durasi ? item.durasi + ' jam' : '-' %></td>
                <td><%= item.lokasi || '-' %></td>
                <td><%= item.semester || '-' %></td>
                <td style="text-align: center;">
                  <% if (item.imageUrls && item.imageUrls.length > 0) { 
                    const firstUrl = item.imageUrls[0];
                    const fileId = getFileId(firstUrl);
                    const thumbUrl = fileId ? `https://drive.google.com/thumbnail?id=${fileId}&sz=w100` : firstUrl;
                    const directUrl = fileId ? `https://drive.google.com/uc?export=view&id=${fileId}` : firstUrl;
                  %>
                    <img src="<%= thumbUrl %>" 
                         class="thumbnail" 
                         alt="dokumentasi"
                         onclick='lihatGambar(<%= JSON.stringify(item.imageUrls) %>)'
                         onerror="this.onerror=null; this.src='<%= directUrl %>';">
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td style="text-align: center;">
                  <% if (item.status === 'approved') { %>
                    <span class="badge-status badge-approved">
                      <i class="bi bi-check-circle"></i> Disetujui
                    </span>
                    <% if (item.approvedByNama) { %>
                      <br><small class="text-muted">oleh: <%= item.approvedByNama %></small>
                    <% } %>
                  <% } else if (item.status === 'rejected') { %>
                    <span class="badge-status badge-rejected">
                      <i class="bi bi-x-circle"></i> Ditolak
                    </span>
                    <% if (item.rejectionReason) { %>
                      <br><small class="text-muted">Alasan: <%= item.rejectionReason %></small>
                    <% } %>
                    <% if (item.rejectedByNama) { %>
                      <br><small class="text-muted">oleh: <%= item.rejectedByNama %></small>
                    <% } %>
                  <% } else { %>
                    <span class="badge-status badge-pending">
                      <i class="bi bi-hourglass-split"></i> Pending
                    </span>
                  <% } %>
                </td>
                <% if (isPembimbing2) { %>
                  <td style="text-align: center;">
                    <% if (item.status === 'pending') { %>
                      <div class="d-flex gap-2 justify-content-center">
                        <form method="POST" action="/dosen/magang/logbook/<%= item.id %>/approve" style="display: inline;">
                          <button type="submit" class="btn-approve" onclick="return confirm('Setujui logbook ini?')">
                            <i class="bi bi-check-circle"></i> Setujui
                          </button>
                        </form>
                        <button type="button" class="btn-reject" data-bs-toggle="modal" data-bs-target="#rejectModal" 
                                data-logbook-id="<%= item.id %>" 
                                data-logbook-title="<%= item.kegiatan.substring(0, 50) %>">
                          <i class="bi bi-x-circle"></i> Tolak
                        </button>
                      </div>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Reject -->
<div class="modal fade" id="rejectModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header-custom">
        <h5 class="modal-title">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>Tolak Logbook
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="rejectForm">
        <div class="modal-body">
          <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Perhatian!</strong> Penolakan akan memberitahu mahasiswa beserta alasan yang diberikan.
          </div>
          <div class="mb-3">
            <label for="alasan" class="form-label fw-bold">Alasan Penolakan <span class="text-danger">*</span></label>
            <textarea class="form-control" id="alasan" name="alasan" rows="3" required 
                      placeholder="Masukkan alasan penolakan logbook..."></textarea>
            <small class="text-muted">Alasan akan ditampilkan kepada mahasiswa.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-x-circle me-1"></i> Tolak Logbook
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Lightbox Modal -->
<div class="modal fade lightbox-modal" id="galleryModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-images me-2"></i>Dokumentasi</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div id="galleryCarousel" class="carousel slide" data-bs-ride="false">
          <div class="carousel-inner" id="galleryCarouselInner"></div>
          <button class="carousel-control-prev" type="button" data-bs-target="#galleryCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#galleryCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
      <div class="modal-footer">
        <small class="text-muted">Jika gambar tidak tampil, <a href="#" id="openInNewTab" target="_blank">klik di sini untuk membuka di tab baru</a>.</small>
      </div>
    </div>
  </div>
</div>

<script>
  // Fungsi untuk mengekstrak fileId dari URL Google Drive
  function getFileId(url) {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    match = url.match(/\/file\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  }

  // Fungsi untuk mendapatkan URL thumbnail
  function getThumbUrl(url, size = 800) {
    const fileId = getFileId(url);
    if (fileId) {
      return `https://drive.google.com/thumbnail?id=${fileId}&sz=w${size}`;
    }
    return url;
  }

  // Fungsi untuk mendapatkan URL langsung ke file (fallback)
  function getDirectUrl(url) {
    const fileId = getFileId(url);
    if (fileId) {
      return `https://drive.google.com/uc?export=view&id=${fileId}`;
    }
    return url;
  }

  let currentImageUrls = [];

  function lihatGambar(imageUrls) {
    const inner = document.getElementById('galleryCarouselInner');
    inner.innerHTML = '';
    if (!imageUrls || imageUrls.length === 0) {
      alert('Tidak ada gambar untuk ditampilkan.');
      return;
    }
    currentImageUrls = imageUrls;
    imageUrls.forEach((url, index) => {
      const activeClass = index === 0 ? 'active' : '';
      const thumbUrl = getThumbUrl(url, 800);
      const directUrl = getDirectUrl(url);
      const item = `
        <div class="carousel-item ${activeClass}">
          <img src="${thumbUrl}" 
               class="d-block w-100" 
               alt="Dokumentasi"
               data-direct-url="${directUrl}"
               onerror="this.onerror=null; this.src=this.getAttribute('data-direct-url'); this.onerror=function(){ this.outerHTML='<div class=\'text-center p-5\'><i class=\'bi bi-exclamation-triangle\'></i> Gambar tidak dapat ditampilkan. <a href=\'${url}\' target=\'_blank\'>Buka di tab baru</a></div>'; };">
        </div>
      `;
      inner.innerHTML += item;
    });
    
    const modal = new bootstrap.Modal(document.getElementById('galleryModal'));
    modal.show();

    // Atur link "buka di tab baru" sesuai gambar aktif
    const carousel = document.getElementById('galleryCarousel');
    const updateNewTabLink = () => {
      const activeImg = carousel.querySelector('.carousel-item.active img');
      if (activeImg) {
        const directUrl = activeImg.getAttribute('data-direct-url');
        document.getElementById('openInNewTab').href = directUrl;
      }
    };
    carousel.addEventListener('slid.bs.carousel', updateNewTabLink);
    setTimeout(updateNewTabLink, 100);
  }

  // Set action form untuk reject modal
  const rejectModal = document.getElementById('rejectModal');
  if (rejectModal) {
    rejectModal.addEventListener('show.bs.modal', function(event) {
      const button = event.relatedTarget;
      const logbookId = button.getAttribute('data-logbook-id');
      const logbookTitle = button.getAttribute('data-logbook-title');
      
      const form = document.getElementById('rejectForm');
      form.action = `/dosen/magang/logbook/${logbookId}/reject`;
      
      const modalTitle = rejectModal.querySelector('.modal-title');
      modalTitle.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-2"></i>Tolak Logbook: ${logbookTitle}`;
    });
  }

  // Auto hide alert setelah 5 detik
  setTimeout(() => {
    const alerts = document.querySelectorAll('.alert-fixed');
    alerts.forEach(alert => {
      alert.style.opacity = '0';
      alert.style.transition = 'opacity 0.5s';
      setTimeout(() => alert.remove(), 500);
    });
  }, 5000);
</script>

<%- include('../partials/footer') %>