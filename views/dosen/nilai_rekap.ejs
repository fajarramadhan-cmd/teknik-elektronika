<%- include('../partials/header') %>

<%
  // Default values to prevent errors
  if (typeof mk === 'undefined') mk = { kode: '', nama: '', sks: '', semester: '' };
  if (typeof tugasList === 'undefined') tugasList = [];
  if (typeof data === 'undefined') data = [];
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin: 0;
    position: relative;
    z-index: 1;
    font-size: 2rem;
  }
  .page-header .btn-back {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 600;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-header .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Filter Card */
  .filter-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
  }
  .filter-card .row {
    align-items: center;
  }
  .filter-card strong {
    color: #1e293b;
  }

  /* Tabel */
  .table-responsive {
    border-radius: 1.5rem;
    overflow-x: auto;
    overflow-y: visible;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
    background: white;
  }
  .nilai-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
    min-width: 600px;
  }
  .nilai-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1rem;
    white-space: nowrap;
    text-align: center;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nilai-table tbody td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e9ecef;
    font-size: 0.95rem;
    text-align: center;
  }
  .nilai-table tbody tr:hover td {
    background-color: #f8fafc;
  }

  /* Badge nilai */
  .badge-primary {
    background: var(--primary-light);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    border: 1px solid rgba(30,58,138,0.2);
    display: inline-block;
    min-width: 45px;
  }
  .badge-nilai-bar {
    background: linear-gradient(135deg, #10b981, #34d399);
    color: white;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    display: inline-block;
    min-width: 45px;
  }

  /* Tombol Input Nilai */
  .btn-input {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .btn-input:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .btn-edit-nilai {
    background: transparent;
    border: 1px solid #f59e0b;
    color: #f59e0b;
    border-radius: 50px;
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    transition: all 0.3s;
    margin-left: 0.3rem;
  }
  .btn-edit-nilai:hover {
    background: #f59e0b;
    border-color: transparent;
    color: white;
  }

  /* Modal */
  .modal-content {
    border: none;
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .modal-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-bottom: none;
    padding: 1.2rem 1.5rem;
  }
  .modal-header .btn-close {
    background: rgba(255,255,255,0.8);
    opacity: 0.8;
    transition: all 0.2s;
  }
  .modal-header .btn-close:hover {
    opacity: 1;
    transform: rotate(90deg);
  }
  .modal-body {
    padding: 1.5rem;
  }
  .modal-footer {
    border-top: 1px solid #e9ecef;
    padding: 1rem 1.5rem;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .form-control, .form-select {
    border-radius: 0.9rem;
    padding: 0.6rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.2rem rgba(30,58,138,0.25);
  }
  .btn-secondary {
    background: #e9ecef;
    border: none;
    color: #1e293b;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background: #dee2e6;
    transform: translateY(-2px);
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(30,58,138,0.3);
    color: white;
  }

  /* Empty state */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1.1rem;
  }

  /* Info tambahan */
  .info-tugas {
    font-size: 0.7rem;
    font-weight: normal;
    display: block;
    color: rgba(255,255,255,0.8);
    margin-top: 0.2rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-header h2 { font-size: 1.6rem; }
    .page-header .btn-back { width: 100%; justify-content: center; }
    .filter-card .row > div { margin-bottom: 0.5rem; }
    .nilai-table thead th { font-size: 0.8rem; padding: 0.75rem; }
    .nilai-table tbody td { font-size: 0.9rem; padding: 0.5rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
    .nilai-table thead th { font-size: 0.75rem; padding: 0.5rem; }
    .nilai-table tbody td { font-size: 0.85rem; padding: 0.5rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <h2><i class="bi bi-bar-chart me-2"></i>Rekap Nilai - <%= mk.kode %> <%= mk.nama %></h2>
    <a href="/dosen/nilai" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <!-- Info MK -->
  <div class="filter-card">
    <div class="row g-3">
      <div class="col-md-3">
        <strong>Kode MK:</strong> <%= mk.kode %>
      </div>
      <div class="col-md-3">
        <strong>Nama MK:</strong> <%= mk.nama %>
      </div>
      <div class="col-md-3">
        <strong>SKS:</strong> <%= mk.sks %>
      </div>
      <div class="col-md-3">
        <strong>Semester:</strong> <%= mk.semester %>
      </div>
    </div>
  </div>

  <!-- Tabel -->
  <div class="table-responsive">
    <table class="table nilai-table">
      <thead>
        <tr>
          <th>No</th>
          <th>NIM</th>
          <th>Nama Mahasiswa</th>
          <% if (tugasList && tugasList.length > 0) { %>
            <% tugasList.forEach(tugas => { %>
              <th>
                <%= tugas.judul %>
                <small class="info-tugas">
                  Deadline: <%= tugas.deadline ? new Date(tugas.deadline).toLocaleDateString('id-ID') : '-' %>
                </small>
              </th>
            <% }) %>
          <% } else { %>
            <th>Belum ada tugas</th>
          <% } %>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (data.length === 0) { %>
          <tr>
            <td colspan="<%= 3 + (tugasList ? tugasList.length : 1) + 1 %>" class="text-center py-5">
              <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p class="text-muted">Belum ada mahasiswa terdaftar di MK ini.</p>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% data.forEach((item, index) => { %>
            <tr>
              <td class="text-center fw-bold"><%= index + 1 %></td>
              <td><%= item.mahasiswa.nim %></td>
              <td class="text-start"><%= item.mahasiswa.nama %></td>
              <% if (tugasList && tugasList.length > 0) { %>
                <% tugasList.forEach(tugas => { 
                  const nilaiData = item.nilai && item.nilai[tugas.id];
                  const nilai = nilaiData ? nilaiData.nilai : null;
                  const isRata = tugas.judul && tugas.judul.toLowerCase().includes('rata');
                %>
                  <td class="text-center">
                    <% if (nilai !== null && nilai !== '-') { %>
                      <span class="<%= isRata ? 'badge-nilai-bar' : 'badge-primary' %>">
                        <%= typeof nilai === 'number' ? nilai.toFixed(2) : nilai %>
                      </span>
                      <button class="btn-edit-nilai" onclick="bukaModalEdit('<%= item.mahasiswa.id %>', '<%= mk.id %>', '<%= tugas.id %>', '<%= tugas.judul %>', <%= nilai %>)">
                        <i class="bi bi-pencil"></i>
                      </button>
                    <% } else { %>
                      <span class="badge-primary" style="background:#f1f5f9; color:#64748b;">-</span>
                      <button class="btn-edit-nilai" onclick="bukaModalEdit('<%= item.mahasiswa.id %>', '<%= mk.id %>', '<%= tugas.id %>', '<%= tugas.judul %>', null)">
                        <i class="bi bi-plus"></i>
                      </button>
                    <% } %>
                  </td>
                <% }) %>
              <% } else { %>
                <td class="text-center text-muted">-</td>
              <% } %>
              <td class="text-center">
                <button class="btn-input" onclick="bukaModalTambah('<%= item.mahasiswa.id %>', '<%= mk.id %>')">
                  <i class="bi bi-plus-circle"></i> Tambah Nilai
                </button>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Input Nilai (untuk menambah nilai baru) -->
<div class="modal fade" id="nilaiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Tambah Nilai Baru</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/dosen/nilai/input" id="nilaiForm">
        <input type="hidden" name="mkId" id="mkId">
        <input type="hidden" name="mahasiswaId" id="mahasiswaId">
        <div class="modal-body">
          <div class="mb-3">
            <label for="tugasId" class="form-label">Pilih Tugas</label>
            <select class="form-select" id="tugasId" name="tugasId" required>
              <option value="">Pilih Tugas</option>
              <% if (tugasList && tugasList.length > 0) { %>
                <% tugasList.forEach(tugas => { %>
                  <option value="<%= tugas.id %>"><%= tugas.judul %> (Deadline: <%= tugas.deadline ? new Date(tugas.deadline).toLocaleDateString('id-ID') : '-' %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label for="nilai" class="form-label">Nilai (0-100)</label>
            <input type="number" class="form-control" id="nilai" name="nilai" min="0" max="100" step="0.01" required>
            <small class="text-muted">Masukkan angka antara 0-100</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Nilai (untuk mengedit nilai yang sudah ada) -->
<div class="modal fade" id="editNilaiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Edit Nilai</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/dosen/nilai/input" id="editNilaiForm">
        <input type="hidden" name="mkId" id="editMkId">
        <input type="hidden" name="mahasiswaId" id="editMahasiswaId">
        <input type="hidden" name="tugasId" id="editTugasId">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Tugas</label>
            <p class="fw-bold" id="editTugasJudul"></p>
          </div>
          <div class="mb-3">
            <label for="editNilai" class="form-label">Nilai (0-100)</label>
            <input type="number" class="form-control" id="editNilai" name="nilai" min="0" max="100" step="0.01" required>
            <small class="text-muted">Masukkan angka antara 0-100</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn-primary">Update Nilai</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Fungsi untuk membuka modal tambah nilai
  function bukaModalTambah(mahasiswaId, mkId) {
    document.getElementById('mahasiswaId').value = mahasiswaId;
    document.getElementById('mkId').value = mkId;
    document.getElementById('nilai').value = '';
    document.getElementById('tugasId').value = '';
    new bootstrap.Modal(document.getElementById('nilaiModal')).show();
  }
  
  // Fungsi untuk membuka modal edit nilai
  function bukaModalEdit(mahasiswaId, mkId, tugasId, tugasJudul, currentNilai) {
    document.getElementById('editMahasiswaId').value = mahasiswaId;
    document.getElementById('editMkId').value = mkId;
    document.getElementById('editTugasId').value = tugasId;
    document.getElementById('editTugasJudul').textContent = tugasJudul;
    document.getElementById('editNilai').value = currentNilai !== null ? currentNilai : '';
    new bootstrap.Modal(document.getElementById('editNilaiModal')).show();
  }
</script>

<%- include('../partials/footer') %>