<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.08);
    --gradient: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    --shadow-sm: 0 4px 12px rgba(0,0,0,0.05);
    --shadow-hover: 0 20px 30px -12px rgba(30,58,138,0.2);
  }

  /* Header Modern */
  .sk-header {
    background: var(--gradient);
    border-radius: 1.5rem;
    padding: 2rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .sk-header::after {
    content: '';
    position: absolute;
    top: -30%;
    right: -10%;
    width: 250px;
    height: 250px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    filter: blur(40px);
  }
  .sk-header h2 {
    font-weight: 800;
    font-size: 1.8rem;
    position: relative;
    z-index: 1;
  }
  .sk-header p {
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }

  /* Stat Cards (Ringkasan) */
  .stat-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: white;
    border-radius: 1.25rem;
    padding: 1rem 1.2rem;
    flex: 1;
    min-width: 120px;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(30,58,138,0.1);
    transition: all 0.2s;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--primary-start);
    line-height: 1.2;
  }
  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #64748b;
    letter-spacing: 0.5px;
  }

  /* Filter & Search (Opsional) */
  .filter-bar {
    background: white;
    border-radius: 1rem;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .search-box {
    flex: 2;
    position: relative;
  }
  .search-box i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
  }
  .search-box input {
    width: 100%;
    padding: 0.6rem 1rem 0.6rem 2.5rem;
    border-radius: 60px;
    border: 1px solid #e2e8f0;
    font-size: 0.85rem;
  }
  .filter-select {
    flex: 1;
    min-width: 180px;
  }
  .filter-select select {
    width: 100%;
    padding: 0.6rem 1rem;
    border-radius: 60px;
    border: 1px solid #e2e8f0;
    background: white;
    font-size: 0.85rem;
  }

  /* SK Card */
  .sk-card {
    border-radius: 1.25rem;
    border: none;
    background: white;
    transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
    box-shadow: var(--shadow-sm);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .sk-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
  }
  .sk-card .card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .badge-sk {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.9rem;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .badge-pa { background: #e0e7ff; color: #1e3a8a; }
  .badge-pembimbing { background: #dcfce7; color: #166534; }
  .badge-mengajar { background: #fef3c7; color: #92400e; }
  .sk-judul {
    font-weight: 700;
    font-size: 1rem;
    margin: 0.75rem 0 0.5rem;
    color: #1e293b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sk-tanggal {
    font-size: 0.7rem;
    color: #94a3b8;
    margin-bottom: 0.75rem;
  }
  .btn-pdf {
    border-radius: 60px;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border: none;
    color: white;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
  }
  .btn-pdf:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(220,38,38,0.3);
    background: linear-gradient(135deg, #dc2626, #b91c1c);
    color: white;
  }
  .empty-state {
    text-align: center;
    padding: 3rem;
    background: white;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .empty-state i {
    font-size: 3rem;
    color: #cbd5e1;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sk-header h2 { font-size: 1.4rem; }
    .stat-card { min-width: 100px; padding: 0.75rem; }
    .stat-number { font-size: 1.4rem; }
  }
  @media (max-width: 576px) {
    .filter-bar { flex-direction: column; align-items: stretch; }
    .filter-select { width: 100%; }
    .btn-pdf { font-size: 0.7rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="sk-header">
    <h2><i class="bi bi-file-earmark-text-fill me-2"></i> Surat Keputusan (SK)</h2>
    <p class="mb-0">Dokumen resmi SK yang diterbitkan untuk Anda sebagai dosen</p>
  </div>

  <!-- Statistik Ringkasan -->
  <%
    const totalSk = skList.length;
    const totalPa = skList.filter(s => s.kategori === 'pa').length;
    const totalPembimbing = skList.filter(s => s.kategori === 'pembimbing_magang').length;
    const totalMengajar = skList.filter(s => s.kategori === 'mengajar').length;
  %>
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-number"><%= totalSk %></div>
      <div class="stat-label">Total SK</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= totalPa %></div>
      <div class="stat-label">SK PA</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= totalPembimbing %></div>
      <div class="stat-label">SK Pembimbing Magang</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= totalMengajar %></div>
      <div class="stat-label">SK Mengajar</div>
    </div>
  </div>

  <!-- Filter dan Pencarian (client side) -->
  <div class="filter-bar">
    <div class="search-box">
      <i class="bi bi-search"></i>
      <input type="text" id="searchSk" placeholder="Cari judul atau kategori...">
    </div>
    <div class="filter-select">
      <select id="kategoriFilter">
        <option value="all">Semua Kategori</option>
        <option value="pa">SK PA</option>
        <option value="pembimbing_magang">SK Pembimbing Magang</option>
        <option value="mengajar">SK Mengajar</option>
      </select>
    </div>
  </div>

  <!-- Daftar SK -->
  <div class="row" id="skContainer">
    <% if (skList.length === 0) { %>
      <div class="col-12">
        <div class="empty-state">
          <i class="bi bi-envelope-paper"></i>
          <p class="mt-2 text-muted">Belum ada SK yang diberikan kepada Anda.</p>
        </div>
      </div>
    <% } else { %>
      <% skList.forEach(sk => { %>
        <div class="col-md-6 col-lg-4 mb-4 sk-item" 
             data-kategori="<%= sk.kategori %>" 
             data-judul="<%= sk.judul.toLowerCase() %>">
          <div class="card sk-card">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <span class="badge-sk 
                  <%= sk.kategori === 'pa' ? 'badge-pa' : (sk.kategori === 'pembimbing_magang' ? 'badge-pembimbing' : 'badge-mengajar') %>">
                  <i class="bi <%= sk.kategori === 'pa' ? 'bi-person-check' : (sk.kategori === 'pembimbing_magang' ? 'bi-briefcase' : 'bi-chalkboard') %>"></i>
                  <%= sk.kategori === 'pa' ? 'SK PA' : (sk.kategori === 'pembimbing_magang' ? 'SK Pembimbing Magang' : 'SK Mengajar') %>
                </span>
                <small class="sk-tanggal"><i class="bi bi-calendar3 me-1"></i><%= sk.tanggalUpload ? sk.tanggalUpload.toLocaleDateString('id-ID') : '-' %></small>
              </div>
              <h5 class="sk-judul"><%= sk.judul %></h5>
              <div class="mt-auto">
                <a href="<%= sk.fileUrl %>" target="_blank" class="btn btn-pdf">
                  <i class="bi bi-eye"></i> Lihat SK
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Filter & Search Script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchSk');
    const kategoriSelect = document.getElementById('kategoriFilter');
    const skItems = document.querySelectorAll('.sk-item');

    function filterCards() {
      const searchTerm = (searchInput.value || '').toLowerCase();
      const kategori = kategoriSelect.value;

      skItems.forEach(item => {
        const itemKategori = item.getAttribute('data-kategori');
        const itemJudul = item.getAttribute('data-judul') || '';
        const matchKategori = (kategori === 'all' || itemKategori === kategori);
        const matchSearch = (searchTerm === '' || itemJudul.includes(searchTerm));
        if (matchKategori && matchSearch) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    }

    searchInput.addEventListener('keyup', filterCards);
    kategoriSelect.addEventListener('change', filterCards);
  });
</script>

<%- include('../../partials/footer') %>