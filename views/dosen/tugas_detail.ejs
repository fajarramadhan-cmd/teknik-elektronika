<%- include('../partials/header') %>

<%
  // Hitung jumlah mahasiswa yang sudah dan belum mengumpulkan
  const sudahCount = mahasiswaList.filter(m => m.pengumpulan).length;
  const belumCount = mahasiswaList.length - sudahCount;
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER DETAIL ===== */
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 1.5rem;
    border-radius: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .detail-header h1 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2rem;
  }
  .detail-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }
  .detail-header .btn-light {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
  }
  .detail-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== INFO CARD ===== */
  .info-card {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .info-card h5 {
    font-weight: 700;
    color: #1e293b;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .info-card h5 i {
    color: var(--primary-start);
  }

  /* ===== RINGKASAN CARD (KECIL) ===== */
  .summary-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1rem;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    border: 1px solid rgba(30,58,138,0.1);
    height: 100%;
  }
  .summary-card h6 {
    color: #64748b;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.3rem;
  }
  .summary-number {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  /* ===== TABEL MAHASISWA (minimalis) ===== */
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 1rem;
  }
  .mahasiswa-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .mahasiswa-table th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .mahasiswa-table td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .mahasiswa-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid transparent;
  }
  .badge-success {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-secondary {
    background: #e2e3e5;
    color: #383d41;
    border-color: #d6d8db;
  }

  /* ===== TOMBOL AKSI ===== */
  .btn-outline-info {
    border: 1.5px solid #17a2b8;
    color: #17a2b8;
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.85rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: transparent;
  }
  .btn-outline-info:hover {
    background: #17a2b8;
    border-color: #17a2b8;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(23,162,184,0.3);
  }

  .btn-warning {
    background: #ffc107;
    border: none;
    color: #212529;
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.85rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-weight: 500;
  }
  .btn-warning:hover {
    background: #e0a800;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(255,193,7,0.3);
  }

  /* ===== MODAL ===== */
  .modal-content {
    border: none;
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .modal-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-bottom: none;
    padding: 1.2rem 1.5rem;
  }
  .modal-header .btn-close {
    background: rgba(255,255,255,0.8);
    opacity: 0.8;
    transition: all 0.2s;
  }
  .modal-header .btn-close:hover {
    opacity: 1;
    transform: rotate(90deg);
  }
  .modal-body {
    padding: 1.5rem;
  }
  .modal-footer {
    border-top: 1px solid #e9ecef;
    padding: 1rem 1.5rem;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .form-control {
    border-radius: 0.9rem;
    border: 1px solid #cbd5e1;
    padding: 0.6rem 1rem;
    transition: all 0.2s;
  }
  .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.2rem rgba(30,58,138,0.25);
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(30,58,138,0.3);
    color: white;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .detail-header h1 { font-size: 1.6rem; }
    .detail-header .btn-light { padding: 0.4rem 1.2rem; font-size: 0.9rem; }
    .mahasiswa-table th { font-size: 0.8rem; padding: 0.5rem; }
    .mahasiswa-table td { font-size: 0.9rem; padding: 0.5rem; }
    .summary-number { font-size: 1.8rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .detail-header h1 { font-size: 1.4rem; }
    .detail-header .btn-light { width: 100%; justify-content: center; }
    .detail-header .d-flex { flex-direction: column; align-items: flex-start !important; gap: 1rem; }
    .btn-outline-info, .btn-warning { padding: 0.2rem 0.8rem; font-size: 0.8rem; }
    .summary-number { font-size: 1.6rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .detail-header h1 { font-size: 1.2rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
  }
</style>

<div class="container mt-4">
  <div class="detail-header">
    <div class="d-flex flex-wrap justify-content-between align-items-center">
      <div>
        <h1><%= tugas.judul %></h1>
        <p class="mb-0">
          <i class="bi bi-book me-2"></i><%= tugas.mkKode %> - <%= tugas.mkNama %> |
          <i class="bi bi-calendar me-2"></i>Deadline: <%= new Date(tugas.deadline).toLocaleString('id-ID') %> |
          <span class="badge bg-light text-dark px-3 py-2"><%= tugas.tipe %></span>
        </p>
      </div>
      <div class="mt-2 mt-sm-0">
        <a href="/dosen/tugas" class="btn-light">
          <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
      </div>
    </div>
  </div>

  <!-- Deskripsi Tugas -->
  <div class="info-card">
    <h5><i class="bi bi-info-circle me-2"></i>Deskripsi</h5>
    <p><%= tugas.deskripsi || 'Tidak ada deskripsi.' %></p>
    <% if (tugas.fileUrl) { %>
      <a href="<%= tugas.fileUrl %>" target="_blank" class="btn-outline-info">
        <i class="bi bi-download"></i> Unduh Soal
      </a>
    <% } %>
  </div>

  <!-- Ringkasan Pengumpulan -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="summary-card">
        <h6>Total Mahasiswa</h6>
        <span class="summary-number" style="color: var(--primary-start);"><%= mahasiswaList.length %></span>
      </div>
    </div>
    <div class="col-md-4">
      <div class="summary-card">
        <h6>Sudah Mengumpulkan</h6>
        <span class="summary-number text-success"><%= sudahCount %></span>
      </div>
    </div>
    <div class="col-md-4">
      <div class="summary-card">
        <h6>Belum Mengumpulkan</h6>
        <span class="summary-number text-danger"><%= belumCount %></span>
      </div>
    </div>
  </div>

  <!-- Daftar Mahasiswa dan Pengumpulan -->
  <div class="info-card">
    <h5><i class="bi bi-people me-2"></i>Daftar Mahasiswa dan Pengumpulan</h5>
    <div class="table-responsive">
      <table class="table mahasiswa-table">
        <thead>
          <tr>
            <th>NIM</th>
            <th>Nama</th>
            <th>Status</th>
            <th>File</th>
            <th>Nilai</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr><td colspan="6" class="text-center py-4">Tidak ada mahasiswa terdaftar.</td></tr>
          <% } else { %>
            <% mahasiswaList.forEach(m => { %>
              <tr>
                <td><%= m.nim %></td>
                <td><%= m.nama %></td>
                <td>
                  <% if (m.pengumpulan) { %>
                    <span class="badge-status badge-success"><i class="bi bi-check-circle"></i> Sudah</span>
                  <% } else { %>
                    <span class="badge-status badge-secondary"><i class="bi bi-x-circle"></i> Belum</span>
                  <% } %>
                </td>
                <td>
                  <% if (m.pengumpulan && m.pengumpulan.fileUrl) { %>
                    <a href="<%= m.pengumpulan.fileUrl %>" target="_blank" class="btn-outline-info btn-sm">
                      <i class="bi bi-file-earmark-pdf"></i> Lihat
                    </a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <% if (m.pengumpulan && m.pengumpulan.nilai) { %>
                    <span class="fw-bold"><%= m.pengumpulan.nilai %></span>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <% if (m.pengumpulan) { %>
                    <button class="btn-warning btn-sm" onclick="beriNilai('<%= m.pengumpulan.id %>', '<%= m.nama %>')">
                      <i class="bi bi-pencil"></i> Nilai
                    </button>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Nilai -->
<div class="modal fade" id="nilaiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Input Nilai untuk <span id="namaMahasiswa"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/dosen/pengumpulan/nilai" id="nilaiForm">
        <input type="hidden" name="pengumpulanId" id="pengumpulanId">
        <div class="modal-body">
          <div class="mb-3">
            <label for="nilai" class="form-label">Nilai (0-100)</label>
            <input type="number" class="form-control" id="nilai" name="nilai" min="0" max="100" step="0.01" required>
          </div>
          <div class="mb-3">
            <label for="komentar" class="form-label">Komentar</label>
            <textarea class="form-control" id="komentar" name="komentar" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function beriNilai(pengumpulanId, nama) {
    if (!pengumpulanId) {
      alert('Mahasiswa belum mengumpulkan tugas.');
      return;
    }
    document.getElementById('pengumpulanId').value = pengumpulanId;
    document.getElementById('namaMahasiswa').textContent = nama;
    new bootstrap.Modal(document.getElementById('nilaiModal')).show();
  }
</script>

<%- include('../partials/footer') %>