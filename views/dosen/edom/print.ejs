<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cetak Hasil EDOM - <%= mkNama %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
  <style>
    @page {
      size: A4;
      margin: 1.5cm;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: #000;
      background-color: #fff;
      font-size: 10pt;
      line-height: 1.4;
    }

    .print-btn-container {
      margin-bottom: 20px;
      border-bottom: 1px solid #dee2e6;
      padding-bottom: 15px;
    }

    /* Kop surat */
    .kop-surat {
      display: flex;
      align-items: center;
      margin-bottom: 20px;
      border-bottom: 3px double #000;
      padding-bottom: 10px;
    }

    .logo-kop {
      width: 90px;
      height: auto;
      margin-right: 20px;
    }

    .teks-kop {
      flex: 1;
    }

    .teks-kop .nama-kampus {
      font-size: 27pt;
      font-weight: bold;
      margin: 0;
      color: #3b60a3;
      text-transform: uppercase;
    }

    .teks-kop .alamat, 
    .teks-kop .kontak {
      font-size: 13pt;
      margin: 0;
      color: #333;
    }

    .judul-dokumen {
      text-align: center;
      font-size: 13pt;
      font-weight: bold;
      margin-top: 20px;
    }

    .sub-judul {
      text-align: center;
      font-size: 1pt;
      margin-bottom: 25px;
    }

    /* Info Grid */
    .info-container {
      width: 100%;
      margin-bottom: 15px;
    }

    .info-table {
      width: 100%;
      border: none;
    }

    .info-table td {
      padding: 3px 0;
      vertical-align: top;
    }

    .info-label {
      font-weight: bold;
      width: 150px;
    }

    .titik-dua {
      width: 15px;
    }

    /* Table Pertanyaan */
    .table-pertanyaan {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }

    .table-pertanyaan th, 
    .table-pertanyaan td {
      border: 1px solid #000;
      padding: 8px;
    }

    .table-pertanyaan th {
      background-color: #f2f2f2 !important;
      text-align: center;
      font-weight: bold;
    }

    .rating-stars {
      color: #f39c12;
      text-align: center;
    }

    /* Komentar */
    .komentar-section {
      margin-top: 20px;
    }

    .komentar-box {
      border: 1px solid #ccc;
      padding: 10px;
      background: #fafafa;
      min-height: 60px;
    }

    .komentar-item {
      font-style: italic;
      font-size: 9pt;
      border-bottom: 1px dashed #eee;
      padding: 5px 0;
    }

    /* Tanda Tangan */
    .tanda-tangan-container {
      display: flex;
      justify-content: space-between;
      margin-top: 50px;
      page-break-inside: avoid;
    }

    .kolom-tanda {
      width: 30%;
      text-align: left;
    }

    .area-ttd {
      height: 80px;
    }

    .nama-ttd {
      font-weight: bold;
      text-decoration: underline;
      margin-bottom: 0;
    }

    @media print {
      .print-btn-container {
        display: none !important;
      }
      body {
        margin: 0;
      }
      .table-pertanyaan th {
        background-color: #f2f2f2 !important;
        -webkit-print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>

<div class="container-fluid px-4 py-3">
  
  <div class="d-flex justify-content-between align-items-center print-btn-container">
    <a href="/dosen/edom/detail?mkId=<%= mkId %>&periode=<%= periodeId %>" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
    <button onclick="window.print()" class="btn btn-primary btn-sm shadow-sm">
      <i class="bi bi-printer-fill"></i> Cetak Laporan
    </button>
  </div>

  <div class="kop-surat">
    <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" 
         alt="Logo Politeknik Dewantara" class="logo-kop">
    <div class="teks-kop">
      <h2 class="nama-kampus">POLITEKNIK DEWANTARA</h2>
      <p class="alamat">Jl. KH. Ahmad Razak 2 No. 7, Kota Palopo. Sulawesi Selatan</p>
      <p class="kontak">E-mail: sdm@polidewa.ac.id | Website: polidewa.ac.id</p>
    </div>
  </div>

  <div class="judul-dokumen">LAPORAN HASIL EVALUASI DOSEN OLEH MAHASISWA (EDOM)</div>
  <div class="sub-judul">Periode Akademik: <%= periodeNama %></div>

  <div class="info-container">
    <table class="info-table">
      <tr>
        <td class="info-label">Mata Kuliah</td>
        <td class="titik-dua">:</td>
        <td><%= mkKode %> - <%= mkNama %></td>
        <td class="info-label">Dosen Pengampu</td>
        <td class="titik-dua">:</td>
        <td><%= dosenNama %></td>
      </tr>
      <tr>
        <td class="info-label">Rata-rata Nilai</td>
        <td class="titik-dua">:</td>
        <td><strong><%= rataNilai.toFixed(2) %> / 5.00</strong></td>
        <td class="info-label">Total Responden</td>
        <td class="titik-dua">:</td>
        <td><%= totalResponden %> Mahasiswa</td>
      </tr>
    </table>
  </div>

  <table class="table-pertanyaan">
    <thead>
      <tr>
        <th width="5%">No</th>
        <th>Komponen Penilaian (Pertanyaan)</th>
        <th width="15%">Skor</th>
        <th width="20%">Rating</th>
      </tr>
    </thead>
    <tbody>
      <% if (pertanyaanList && pertanyaanList.length > 0) { %>
        <% pertanyaanList.forEach((q, idx) => { %>
          <tr>
            <td class="text-center"><%= idx + 1 %></td>
            <td><%= q.pertanyaan %></td>
            <td class="text-center"><%= q.rataNilai.toFixed(2) %></td>
            <td class="rating-stars">
              <% 
                let starFull = Math.floor(q.rataNilai);
                let starHalf = (q.rataNilai % 1) >= 0.5;
                for (let i = 1; i <= 5; i++) { 
                  if (i <= starFull) { %>
                    <i class="bi bi-star-fill"></i>
                  <% } else if (i === starFull + 1 && starHalf) { %>
                    <i class="bi bi-star-half"></i>
                  <% } else { %>
                    <i class="bi bi-star"></i>
                  <% } 
                } 
              %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="4" class="text-center">Data penilaian belum tersedia.</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <div class="komentar-section">
    <strong>Komentar / Saran Mahasiswa:</strong>
    <div class="komentar-box mt-2">
      <% if (semuaKomentar && semuaKomentar.length > 0) { %>
        <% semuaKomentar.forEach(k => { %>
          <div class="komentar-item">"<%= k %>"</div>
        <% }) %>
      <% } else { %>
        <p class="text-muted mb-0"><em>Tidak ada komentar yang diberikan.</em></p>
      <% } %>
    </div>
  </div>

  <div class="tanda-tangan-container">
    <div class="kolom-tanda">
      <p>Mengetahui,<br>Ketua Program Studi</p>
      <div class="area-ttd"></div>
      <p class="nama-ttd">Fajar Ramadhan, S.Pd., M.T</p>
      <p>NIDN. 8559777678130153</p>
    </div>

    <div class="kolom-tanda">
      <p>Dosen yang Dinilai<br>&nbsp;</p>
      <div class="area-ttd"></div>
      <p class="nama-ttd text-uppercase"><%= dosenNama %></p>
      <p>NIDN/NIP. <%= dosenNip || '-' %></p>
    </div>

    <div class="kolom-tanda">
      <p>Palopo, <%= new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %><br>Penilai,</p>
      <div class="area-ttd"></div>
      <p class="nama-ttd">( ............................ )</p>
      <p>Bagian Akademik</p>
    </div>
  </div>

</div>

</body>
</html>