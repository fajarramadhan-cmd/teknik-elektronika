<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.08);
    --card-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.02);
  }

  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.8rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 20px 35px -10px rgba(30,58,138,0.3);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 800;
    font-size: 1.7rem;
    margin-bottom: 0.25rem;
    position: relative;
    z-index: 2;
  }
  .page-header p {
    font-size: 0.95rem;
    opacity: 0.9;
    margin-bottom: 0;
    position: relative;
    z-index: 2;
  }

  .filter-card {
    background: white;
    border-radius: 1rem;
    padding: 1rem 1.2rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    box-shadow: var(--card-shadow);
    border: 1px solid rgba(30,58,138,0.08);
  }
  .filter-card label {
    font-weight: 600;
    color: #1e293b;
  }
  .filter-card select {
    border-radius: 60px;
    border: 1px solid #cbd5e1;
    padding: 0.5rem 1rem;
    background: white;
    min-width: 220px;
  }

  .card-edom {
    border: none;
    border-radius: 1.2rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: var(--card-shadow);
    height: 100%;
    background: white;
  }
  .card-edom:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 30px -12px rgba(0,0,0,0.15);
  }
  .card-header-edom {
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
    padding: 1rem;
    border-radius: 1.2rem 1.2rem 0 0;
  }
  .card-header-edom h5 {
    font-weight: 700;
    margin: 0;
    color: #0f172a;
  }
  .average-score {
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    line-height: 1.2;
  }
  .star-rating {
    font-size: 0.9rem;
    color: #ffc107;
    letter-spacing: 2px;
  }
  .responden-count {
    background: #eef2ff;
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 60px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .komentar-list {
    max-height: 200px;
    overflow-y: auto;
    margin-top: 0.5rem;
  }
  .komentar-item {
    background: #f8fafc;
    border-radius: 1rem;
    padding: 0.5rem 0.8rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    border-left: 3px solid var(--primary-start);
  }
  .btn-outline-custom {
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    border-radius: 60px;
    padding: 0.25rem 0.9rem;
    font-size: 0.75rem;
    transition: all 0.2s;
  }
  .btn-outline-custom:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
  }
  @media (max-width: 768px) {
    .page-header { padding: 1.2rem; }
    .page-header h2 { font-size: 1.4rem; }
    .filter-card { flex-direction: column; align-items: stretch; }
    .filter-card select { width: 100%; }
    .average-score { font-size: 2rem; }
  }
</style>

<div class="container mt-4">
  <div class="page-header">
    <h2><i class="bi bi-bar-chart-steps me-2"></i> Hasil Evaluasi Dosen (EDOM)</h2>
    <p>Rekap penilaian mahasiswa per mata kuliah secara anonim</p>
  </div>

  <div class="filter-card">
    <label><i class="bi bi-calendar-week me-1"></i> Periode Evaluasi:</label>
    <form method="GET" class="d-inline">
      <select name="periode" class="form-select" onchange="this.form.submit()">
        <option value="">-- Pilih Periode --</option>
        <% periods.forEach(p => { %>
          <option value="<%= p.id %>" <%= selectedPeriodId === p.id ? 'selected' : '' %>><%= p.nama %></option>
        <% }) %>
      </select>
    </form>
    <% if (selectedPeriod) { %>
      <span class="badge bg-light text-dark ms-auto"><%= selectedPeriod.tanggalMulai %> s/d <%= selectedPeriod.tanggalSelesai %></span>
    <% } %>
  </div>

  <% if (results.length === 0) { %>
    <div class="alert alert-info border-0 shadow-sm rounded-4">
      <i class="bi bi-info-circle-fill me-2"></i> Belum ada data evaluasi untuk periode yang dipilih.
    </div>
  <% } else { %>
    <div class="row g-4">
      <% results.forEach(r => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-edom">
            <div class="card-header-edom">
              <h5><%= r.mkKode %> - <%= r.mkNama %></h5>
              <div class="responden-count mt-1">
                <i class="bi bi-people-fill me-1"></i> <%= r.count %> responden
              </div>
            </div>
            <div class="card-body">
              <div class="text-center mb-2">
                <span class="average-score"><%= r.average %></span>
                <span class="text-muted"> / 5.00</span>
                <div class="star-rating mt-1">
                  <% 
                    let fullStars = Math.floor(r.average);
                    let halfStar = (r.average % 1) >= 0.5;
                    for (let i = 1; i <= 5; i++) {
                      if (i <= fullStars) { %>
                        <i class="bi bi-star-fill"></i>
                      <% } else if (i === fullStars+1 && halfStar) { %>
                        <i class="bi bi-star-half"></i>
                      <% } else { %>
                        <i class="bi bi-star"></i>
                      <% }
                    }
                  %>
                </div>
              </div>
              <% if (r.komentarList.length) { %>
                <hr>
                <strong><i class="bi bi-chat-dots me-1"></i> Komentar Anonim</strong>
                <div class="komentar-list">
                  <% r.komentarList.forEach(k => { %>
                    <div class="komentar-item">
                      <i class="bi bi-person-circle me-1 text-secondary"></i> <%= k %>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
              <a href="/dosen/edom/detail?mkId=<%= r.mkId %>&periode=<%= selectedPeriodId %>" class="btn-outline-custom btn-sm">
                <i class="bi bi-graph-up"></i> Detail
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>