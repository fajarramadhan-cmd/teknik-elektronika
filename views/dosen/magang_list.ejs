<%- include('../partials/header') %>

<%
  // ========== DEFAULT VALUES ==========
  if (typeof mahasiswaList === 'undefined') mahasiswaList = [];
  if (typeof message === 'undefined') message = null;
  
  // Fungsi untuk mendapatkan URL gambar dari Google Drive
  const getImageUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    return url;
  };
  
  // Ekstrak angkatan dari NIM
  const getAngkatan = (nim) => {
    if (!nim || nim.length < 2) return '';
    const duaDigit = nim.substring(0, 2);
    return `20${duaDigit}`;
  };
%>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --gray-border: #e2e8f0;
    --font-base: 16px;
  }

  html { font-size: 16px; }
  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin: 0;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 2rem;
  }
  .page-header .btn-back {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.6rem 1.8rem;
    font-weight: 600;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
  }
  .page-header .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Role Badge */
  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .role-pembimbing2 {
    background: linear-gradient(135deg, #10b981, #34d399);
    color: white;
    box-shadow: 0 5px 15px rgba(16,185,129,0.3);
  }
  .role-pembimbing1 {
    background: linear-gradient(135deg, #6c757d, #adb5bd);
    color: white;
  }

  /* Statistik Ringkasan */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    background: white;
    border-radius: 1rem;
    padding: 1rem;
    text-align: center;
    border: 1px solid var(--gray-border);
  }
  .stat-card .stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--primary-start);
  }
  .stat-card .stat-label {
    font-size: 0.8rem;
    color: #64748b;
  }

  /* Filter Section */
  .filter-section {
    background: white;
    border-radius: 1.2rem;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid var(--gray-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .filter-section .form-control,
  .filter-section .form-select {
    border-radius: 50px;
    padding: 0.5rem 1rem;
    border: 1px solid #cbd5e1;
    min-width: 200px;
    flex: 1 1 auto;
  }
  .filter-section .btn-filter {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .filter-section .btn-filter:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .filter-section .btn-reset {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .filter-section .btn-reset:hover {
    background: var(--primary-start);
    color: white;
    transform: translateY(-2px);
  }

  /* Tabel Container */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid var(--gray-border);
    padding: 0;
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Tabel minimalis */
  .magang-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .magang-table thead th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
    text-align: center;
  }
  .magang-table tbody td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.9rem;
  }
  .magang-table tbody tr {
    transition: background-color 0.2s;
  }
  .magang-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* PDK Badges */
  .pdk-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 600;
    margin-right: 0.3rem;
    margin-bottom: 0.2rem;
  }
  .pdk-badge-1 { background: #dbeafe; color: #1e40af; }
  .pdk-badge-2 { background: #d1fae5; color: #065f46; }
  .pdk-badge-3 { background: #fef3c7; color: #92400e; }

  /* Status Badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .status-success {
    background: #d1fae5;
    color: #065f46;
  }
  .status-warning {
    background: #fef3c7;
    color: #92400e;
  }
  .status-danger {
    background: #fee2e2;
    color: #991b1b;
  }

  /* Role Badge di Tabel */
  .role-badge-table {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .role-pembimbing1-table {
    background: var(--info-bg);
    color: var(--info-text);
  }
  .role-pembimbing2-table {
    background: var(--success-bg);
    color: var(--success-text);
  }
  .role-both-table {
    background: linear-gradient(135deg, var(--info-bg), var(--success-bg));
    color: var(--primary-start);
  }

  /* Avatar dan Foto */
  .avatar-circle {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(30,58,138,0.3);
    flex-shrink: 0;
  }
  .foto-mahasiswa {
    width: 45px;
    height: 45px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    flex-shrink: 0;
  }

  /* Info Mahasiswa */
  .mahasiswa-info {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .mahasiswa-info .nama {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.2rem;
  }
  .mahasiswa-info .nim {
    font-size: 0.8rem;
    color: #64748b;
  }

  /* Badge statistik */
  .badge-stat {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.8rem;
    min-width: 70px;
    text-align: center;
  }
  .badge-total {
    background: var(--primary-light);
    color: var(--primary-start);
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
  }
  .badge-zero {
    background: #e9ecef;
    color: #6c757d;
  }

  /* Tombol aksi */
  .btn-action {
    border-radius: 50px;
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    border: 1.5px solid transparent;
    background: transparent;
  }
  .btn-view {
    border-color: var(--primary-start);
    color: var(--primary-start);
  }
  .btn-view:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(30,58,138,0.3);
  }
  .btn-manage {
    border-color: #10b981;
    color: #10b981;
  }
  .btn-manage:hover {
    background: #10b981;
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(16,185,129,0.3);
  }
  .btn-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Alert styling */
  .custom-alert {
    border-radius: 1rem;
    border-left: 4px solid var(--primary-start);
    background: white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid var(--gray-border);
    color: var(--primary-dark);
  }

  /* Empty state */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1.1rem;
  }

  /* No results message */
  .no-results {
    text-align: center;
    padding: 2rem;
    color: #64748b;
    font-style: italic;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-header h2 { font-size: 1.6rem; }
    .page-header .btn-back { width: 100%; justify-content: center; }
    .filter-section { flex-direction: column; align-items: stretch; }
    .filter-section .form-control,
    .filter-section .form-select,
    .filter-section .btn-filter,
    .filter-section .btn-reset { width: 100%; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .btn-actions { flex-direction: column; align-items: stretch; }
    .btn-action { justify-content: center; }

    /* Card view untuk mobile */
    .magang-table thead {
      display: none;
    }
    .magang-table, .magang-table tbody, .magang-table tr, .magang-table td {
      display: block;
      width: 100%;
    }
    .magang-table tr {
      margin-bottom: 1rem;
      border: 1px solid #dee2e6;
      border-radius: 1rem;
      padding: 1rem;
      background: white;
    }
    .magang-table td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0;
      border-bottom: 1px dashed #e9ecef;
      border: none;
      text-align: left;
    }
    .magang-table td:last-child {
      border-bottom: none;
    }
    .magang-table td::before {
      content: attr(data-label);
      font-weight: 600;
      color: var(--primary-start);
      width: 40%;
    }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
    .stats-row { grid-template-columns: 1fr; }
  }
</style>

<div class="container mt-4">
  <!-- Page Header -->
  <div class="page-header">
    <h2>
      <i class="bi bi-journal-bookmark-fill"></i> Monitoring Magang
    </h2>
    <a href="/dosen/dashboard" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali ke Dashboard
    </a>
  </div>



  <!-- Statistik Ringkasan -->
  <% if (mahasiswaList.length > 0) { 
    const totalMahasiswa = mahasiswaList.length;
    const totalLogbook = mahasiswaList.reduce((sum, m) => sum + (m.totalLogbook || 0), 0);
    const totalPending = mahasiswaList.reduce((sum, m) => sum + (m.pendingCount || 0), 0);
  %>
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value"><%= totalMahasiswa %></div>
        <div class="stat-label">Mahasiswa Bimbingan</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= totalLogbook %></div>
        <div class="stat-label">Total Logbook</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= totalPending %></div>
        <div class="stat-label">Pending Approval</div>
      </div>
    </div>
  <% } %>

  <!-- Custom Alert Message -->
  <% if (message) { %>
    <div class="custom-alert">
      <i class="bi bi-info-circle-fill me-2" style="color: var(--primary-start);"></i>
      <%= message %>
    </div>
  <% } %>

  <!-- Filter Section -->
  <div class="filter-section">
    <input type="text" id="searchInput" class="form-control" placeholder="🔍 Cari nama atau NIM...">
    <select id="angkatanFilter" class="form-select">
      <option value="">📅 Semua Angkatan</option>
    </select>
    <button class="btn-filter" id="applyFilter">
      <i class="bi bi-funnel"></i> Terapkan
    </button>
    <button class="btn-reset" id="resetFilter">
      <i class="bi bi-arrow-repeat"></i> Reset
    </button>
  </div>

  <!-- Tabel Mahasiswa -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table magang-table" id="magangTable">
        <thead>
          <tr>
            <th style="text-align: center;">No</th>
            <th>Mahasiswa</th>
            <th>Role Anda</th>
            <th>PDK Diprogram</th>
            <th style="text-align: center;">Status</th>
            <th style="text-align: center;">Total</th>
            <th style="text-align: center;">Pending</th>
            <th style="text-align: center;">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p>Anda belum memiliki mahasiswa bimbingan.</p>
                  <p class="small text-muted mt-2">Silakan hubungi admin untuk menetapkan bimbingan.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% mahasiswaList.forEach((m, index) => { 
              const fotoUrl = m.foto ? getImageUrl(m.foto) : null;
              const angkatan = getAngkatan(m.nim);
              
              // Tentukan role badge
              let roleBadgeClass = '';
              let roleText = '';
              if (m.role === 'pembimbing1') {
                roleBadgeClass = 'role-pembimbing1-table';
                roleText = 'Pembimbing 1';
              } else if (m.role === 'pembimbing2') {
                roleBadgeClass = 'role-pembimbing2-table';
                roleText = 'Pembimbing 2';
              } else if (m.role === 'pembimbing1_dan_2') {
                roleBadgeClass = 'role-both-table';
                roleText = 'Pembimbing 1 & 2';
              } else {
                roleBadgeClass = 'role-pembimbing1-table';
                roleText = '-';
              }
            %>
            <tr data-nama="<%= (m.nama || '').toLowerCase() %>" 
                data-nim="<%= m.nim || '' %>" 
                data-angkatan="<%= angkatan %>"
                data-total="<%= m.totalLogbook || 0 %>"
                data-pending="<%= m.pendingCount || 0 %>">
              <td data-label="No" style="text-align: center; font-weight: 600;"><%= index + 1 %></td>
              <td data-label="Mahasiswa">
                <div class="mahasiswa-info">
                  <% if (fotoUrl) { %>
                    <img src="<%= fotoUrl %>" alt="foto <%= m.nama %>" class="foto-mahasiswa" 
                         onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(m.nama) %>&background=1e3a8a&color=fff&size=45';">
                  <% } else { %>
                    <div class="avatar-circle"><%= (m.nama || '?').charAt(0).toUpperCase() %></div>
                  <% } %>
                  <div>
                    <div class="nama"><%= m.nama %></div>
                    <div class="nim"><%= m.nim || '-' %></div>
                    <% if (angkatan) { %>
                      <div class="small text-muted">Angkatan <%= angkatan %></div>
                    <% } %>
                  </div>
                </div>
              </td>
              <td data-label="Role Anda" style="text-align: center;">
                <span class="role-badge-table <%= roleBadgeClass %>">
                  <i class="bi <%= m.role === 'pembimbing2' ? 'bi-check-circle' : (m.role === 'pembimbing1' ? 'bi-eye' : 'bi-star') %>"></i>
                  <%= roleText %>
                </span>
              </td>
              <td data-label="PDK Diprogram">
                <% if (m.enrolledPdks && m.enrolledPdks.length > 0) { %>
                  <% m.enrolledPdks.forEach(function(pdk) { %>
                    <span class="pdk-badge pdk-badge-<%= pdk.urutan %>">
                      <%= pdk.kode %> (PDK <%= pdk.urutan %>)
                    </span>
                  <% }); %>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td data-label="Status" style="text-align: center;">
                <% 
                  let statusClass = '';
                  let statusIcon = '';
                  let statusText = '';
                  if (m.hasActivePeriod) {
                    statusClass = 'success';
                    statusIcon = 'bi-play-circle-fill';
                    statusText = 'Magang Aktif';
                  } else if (m.enrolledPdks && m.enrolledPdks.length > 0) {
                    statusClass = 'warning';
                    statusIcon = 'bi-clock-history';
                    statusText = 'Sudah KRS';
                  } else {
                    statusClass = 'danger';
                    statusIcon = 'bi-exclamation-triangle-fill';
                    statusText = 'Belum KRS';
                  }
                %>
                <span class="status-badge status-<%= statusClass %>">
                  <i class="bi <%= statusIcon %>"></i> <%= statusText %>
                </span>
              </td>
              <td data-label="Total" style="text-align: center;">
                <span class="badge-stat badge-total"><%= m.totalLogbook || 0 %></span>
              </td>
              <td data-label="Pending" style="text-align: center;">
                <% if ((m.pendingCount || 0) > 0) { %>
                  <span class="badge-stat badge-pending"><%= m.pendingCount %></span>
                <% } else { %>
                  <span class="badge-stat badge-zero">0</span>
                <% } %>
              </td>
              <td data-label="Aksi" style="text-align: center;">
                <div class="btn-actions">
                  <a href="/dosen/magang/<%= m.id %>" class="btn-action btn-view" title="Lihat Logbook">
                    <i class="bi bi-eye"></i> Logbook
                  </a>
                  <a href="/dosen/magang-period/<%= m.id %>" class="btn-action btn-manage" title="Kelola Magang">
                    <i class="bi bi-gear-fill"></i> Kelola
                  </a>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
      <div id="noFilterResult" class="no-results" style="display: none;">
        <i class="bi bi-search"></i> Tidak ada mahasiswa yang cocok dengan filter.
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    // Fungsi untuk mendapatkan daftar angkatan unik dari baris tabel
    function getUniqueAngkatan() {
      const rows = document.querySelectorAll('#magangTable tbody tr');
      const angkatanSet = new Set();
      rows.forEach(row => {
        const angkatan = row.getAttribute('data-angkatan');
        if (angkatan && angkatan !== '') angkatanSet.add(angkatan);
      });
      return Array.from(angkatanSet).sort().reverse();
    }

    // Isi dropdown angkatan
    const angkatanFilter = document.getElementById('angkatanFilter');
    const angkatanList = getUniqueAngkatan();
    angkatanList.forEach(angkatan => {
      const option = document.createElement('option');
      option.value = angkatan;
      option.textContent = angkatan;
      angkatanFilter.appendChild(option);
    });

    // Fungsi filter
    function filterTable() {
      const searchInput = document.getElementById('searchInput').value.toLowerCase().trim();
      const angkatanValue = document.getElementById('angkatanFilter').value;
      const rows = document.querySelectorAll('#magangTable tbody tr');
      let visibleCount = 0;

      rows.forEach(row => {
        const nama = row.getAttribute('data-nama') || '';
        const nim = row.getAttribute('data-nim') || '';
        const angkatan = row.getAttribute('data-angkatan') || '';

        let matchSearch = true;
        if (searchInput !== '') {
          matchSearch = nama.includes(searchInput) || nim.includes(searchInput);
        }

        let matchAngkatan = true;
        if (angkatanValue !== '') {
          matchAngkatan = angkatan === angkatanValue;
        }

        if (matchSearch && matchAngkatan) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      const noResultDiv = document.getElementById('noFilterResult');
      if (visibleCount === 0) {
        noResultDiv.style.display = 'block';
      } else {
        noResultDiv.style.display = 'none';
      }
    }

    // Reset filter
    function resetFilter() {
      document.getElementById('searchInput').value = '';
      document.getElementById('angkatanFilter').value = '';
      const rows = document.querySelectorAll('#magangTable tbody tr');
      rows.forEach(row => row.style.display = '');
      document.getElementById('noFilterResult').style.display = 'none';
    }

    // Event listeners
    document.getElementById('applyFilter').addEventListener('click', filterTable);
    document.getElementById('resetFilter').addEventListener('click', resetFilter);
    document.getElementById('searchInput').addEventListener('keyup', filterTable);
    document.getElementById('angkatanFilter').addEventListener('change', filterTable);
  })();
</script>

