<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }
  .btn-gradient {
    background: white;
    border: none;
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    border: 1px solid rgba(33,147,176,0.1);
    overflow: hidden;
  }
  .artikel-table {
    margin-bottom: 0;
  }
  .artikel-table thead th {
    background: linear-gradient(135deg, var(--primary-light), rgba(109,213,237,0.1));
    color: var(--primary-dark);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--primary-start);
    padding: 1rem 0.75rem;
    white-space: nowrap;
  }
  .artikel-table tbody tr {
    transition: all 0.2s;
  }
  .artikel-table tbody tr:hover {
    background-color: var(--primary-light);
    transform: scale(1.01);
    box-shadow: 0 5px 15px rgba(33,147,176,0.1);
  }
  .artikel-table td {
    padding: 1rem 0.75rem;
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }
  .artikel-table td:last-child {
    white-space: nowrap;
    width: 1%;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }
  .badge-approved {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-rejected {
    background: #f8d7da;
    color: #721c24;
    border-color: #f5c6cb;
  }

  /* ===== TOMBOL AKSI ===== */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
    margin: 0 2px;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-detail {
    background: var(--primary-start);
  }
  .btn-detail:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }
  .btn-edit {
    background: #ffc107;
  }
  .btn-edit:hover {
    background: #e0a800;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(255,193,7,0.3);
  }
  .btn-delete {
    background: #dc3545;
  }
  .btn-delete:hover {
    background: #c82333;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(220,53,69,0.3);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8fafc;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 0;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header dengan tombol buat baru -->
  <div class="page-header">
    <h2><i class="bi bi-journal-richtext me-2"></i>Artikel Saya</h2>
    <a href="/dosen/artikel/create" class="btn-gradient">
      <i class="bi bi-plus-circle"></i> Buat Artikel Baru
    </a>
  </div>

  <!-- Notifikasi sukses hapus -->
  <% if (typeof success !== 'undefined' && success === 'deleted') { %>
    <div class="alert alert-info alert-dismissible fade show mb-4" role="alert" style="border-left: 4px solid #17a2b8; border-radius: 1rem;">
      <i class="bi bi-trash-fill me-2"></i>Artikel berhasil dihapus.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Artikel -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table artikel-table">
        <thead>
          <tr>
            <th>Judul</th>
            <th>Abstrak</th>
            <th>Tanggal Upload</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (artikelList.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-journal-text"></i>
                  <h4>Belum Ada Artikel</h4>
                  <p class="text-muted">Buat artikel pertama Anda dengan klik tombol "Buat Artikel Baru".</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% artikelList.forEach(a => { %>
              <tr>
                <td><strong><%= a.judul %></strong></td>
                <td><%= (a.abstrak || '').substring(0, 80) %><%= (a.abstrak || '').length > 80 ? '...' : '' %></td>
                <td><%= new Date(a.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %></td>
                <td>
                  <% if (a.status === 'pending') { %>
                    <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                  <% } else if (a.status === 'approved') { %>
                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                  <% } else if (a.status === 'rejected') { %>
                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/dosen/artikel/<%= a.id %>" class="btn-icon-sm btn-detail" title="Detail">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/dosen/artikel/<%= a.id %>/edit" class="btn-icon-sm btn-edit" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form method="POST" action="/dosen/artikel/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus artikel ini?')">
                      <button class="btn-icon-sm btn-delete" title="Hapus">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>