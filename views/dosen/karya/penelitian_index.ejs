<%- include('../../partials/header') %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-mortarboard-fill"></i> Penelitian Saya</h2>
    <a href="/dosen/penelitian/tambah" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Tambah Penelitian</a>
  </div>
  <div class="table-responsive">
    <table class="table table-bordered table-hover">
      <thead class="table-light">
        <tr>
          <th>Judul</th>
          <th>Jurnal</th>
          <th>Tahun</th>
          <th>Status Submit</th>
          <th>Status Verifikasi</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% list.forEach(item => { %>
          <tr>
            <td><%= item.judul %></td>
            <td><%= item.namaJurnal || '-' %></td>
            <td><%= item.tahun %></td>
            <td><%= item.statusSubmit === 'sudah_submit' ? 'Sudah Submit' : 'Belum Submit' %></td>
            <td><span class="badge bg-<%= item.status === 'pending' ? 'warning' : (item.status === 'approved' ? 'success' : 'danger') %>"><%= item.status %></span></td>
            <td>
              <a href="/dosen/penelitian/<%= item.id %>" class="btn btn-sm btn-info">Detail</a>
              <% if (item.status === 'pending') { %>
                <form method="POST" action="/dosen/penelitian/<%= item.id %>/hapus" style="display:inline" onsubmit="return confirm('Yakin hapus?')">
                  <button class="btn btn-sm btn-danger">Hapus</button>
                </form>
              <% } %>
             </td>
           </tr>
        <% }) %>
        <% if (list.length === 0) { %>
          <tr><td colspan="6" class="text-center">Belum ada data penelitian.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../../partials/footer') %>