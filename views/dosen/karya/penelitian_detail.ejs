<%- include('../../partials/header') %>
<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-header bg-info text-white">
      <h4 class="mb-0">Detail Penelitian</h4>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-12 mb-2"><strong>Judul:</strong> <%= data.judul %></div>
        <div class="col-md-6 mb-2"><strong>Nama Jurnal:</strong> <%= data.namaJurnal || '-' %></div>
        <div class="col-md-6 mb-2"><strong>Link Jurnal:</strong> <%= data.linkJurnal ? '<a href="'+data.linkJurnal+'" target="_blank">Buka</a>' : '-' %></div>
        <div class="col-md-6 mb-2"><strong>Status Submit:</strong> <%= data.statusSubmit === 'sudah_submit' ? 'Sudah Submit' : 'Belum Submit' %></div>
        <div class="col-md-6 mb-2"><strong>Tahun:</strong> <%= data.tahun %></div>
        <div class="col-12 mb-2"><strong>Status Verifikasi:</strong> <span class="badge bg-<%= data.status === 'pending' ? 'warning' : (data.status === 'approved' ? 'success' : 'danger') %>"><%= data.status %></span></div>
        <% if (data.suratTugasUrl) { %>
          <div class="col-12 mb-2"><strong>Surat Tugas:</strong> <a href="<%= data.suratTugasUrl %>" target="_blank">Lihat</a></div>
        <% } %>
        <% if (data.fileUrl) { %>
          <div class="col-12 mb-2"><strong>File Penelitian:</strong> <a href="<%= data.fileUrl %>" target="_blank">Buka PDF</a></div>
        <% } %>
      </div>
      <hr>
      <div class="mt-3">
        <a href="/dosen/penelitian" class="btn btn-secondary">Kembali</a>
        <% if (data.status === 'pending') { %>
          <form method="POST" action="/dosen/penelitian/<%= data.id %>/hapus" style="display:inline" onsubmit="return confirm('Hapus?')">
            <button class="btn btn-danger">Hapus</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>