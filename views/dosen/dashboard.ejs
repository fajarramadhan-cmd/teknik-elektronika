<%- include('../partials/header') %>

<%
  // Set default values for optional variables to prevent undefined errors
  if (typeof events === 'undefined') events = [];
  if (typeof berita === 'undefined') berita = [];
  if (typeof logbookPendingList === 'undefined') logbookPendingList = [];
  if (typeof logbookPendingCount === 'undefined') logbookPendingCount = 0;

  // Fungsi untuk mendapatkan URL gambar dari Google Drive
  const getImageUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w200-h200`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w200-h200`;
    return url;
  };
  
  // Format tanggal
  const formatTanggal = (dateString) => {
    if (!dateString) return '-';
    const date = new Date(dateString);
    return date.toLocaleDateString('id-ID', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== PROFILE CARD (seperti dashboard mahasiswa) ===== */
  .profile-card {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem;
    color: white;
    margin-bottom: 1.5rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.3);
    position: relative;
    overflow: hidden;
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .profile-card h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    position: relative;
    z-index: 1;
  }
  .profile-card p {
    font-size: 0.95rem;
    opacity: 0.9;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .profile-avatar {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    border: 4px solid rgba(255,255,255,0.5);
    object-fit: cover;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .profile-avatar i {
    font-size: 3rem;
    color: white;
  }
  .profile-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    background: rgba(255,255,255,0.15);
    padding: 0.6rem 1rem;
    border-radius: 50px;
    backdrop-filter: blur(4px);
    position: relative;
    z-index: 1;
  }
  .profile-stats span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .profile-stats i {
    font-size: 1rem;
  }

  /* ===== INFO CARD (untuk informasi dosen) ===== */
  .info-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .info-card .card-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 1rem 1.5rem;
  }
  .info-card .card-header h5 {
    font-size: 1.1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }
  .info-card .card-body {
    padding: 1.5rem;
  }
  .stat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1 1 auto;
  }
  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: var(--primary-light);
    color: var(--primary-start);
  }
  .stat-content {
    flex: 1;
  }
  .stat-label {
    font-size: 0.8rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .stat-number {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
  }
  .btn-outline-primary {
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.4rem 1.2rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
    white-space: nowrap;
  }
  .btn-outline-primary:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }

  /* ===== LOGBOOK PENDING TABLE ===== */
  .logbook-pending-table {
    width: 100%;
    font-size: 0.85rem;
  }
  .logbook-pending-table th {
    background: #f8f9fa;
    padding: 0.75rem;
    font-weight: 600;
    border-bottom: 2px solid #e9ecef;
  }
  .logbook-pending-table td {
    padding: 0.75rem;
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }
  .logbook-pending-table tr:hover td {
    background-color: #f8fafc;
  }
  .btn-approve-small {
    background: #10b981;
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.25rem 0.8rem;
    font-size: 0.7rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-approve-small:hover {
    background: #059669;
    transform: translateY(-2px);
    color: white;
  }
  .btn-view-small {
    background: transparent;
    border: 1px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.25rem 0.8rem;
    font-size: 0.7rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-view-small:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
  }
  .badge-pending-small {
    background: var(--warning-bg);
    color: var(--warning-text);
    padding: 0.2rem 0.5rem;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 500;
  }

  /* ===== QUICK ACTION CARDS ===== */
  .quick-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.2rem 1rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid rgba(30,58,138,0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    display: block;
    height: 100%;
  }
  .quick-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px rgba(30,58,138,0.15);
    border-color: transparent;
  }
  .quick-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin: 0 auto 0.8rem;
    background: var(--primary-light);
    color: var(--primary-start);
    transition: all 0.3s;
  }
  .quick-card:hover .quick-icon {
    transform: scale(1.1);
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
  }
  .quick-card h6 {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.3rem;
    font-size: 0.95rem;
  }
  .quick-card p {
    color: #64748b;
    font-size: 0.75rem;
    margin-bottom: 0;
  }

  /* ===== SECTION TITLE ===== */
  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1.5rem 0 1rem;
    position: relative;
    padding-left: 1rem;
  }
  .section-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2rem;
    bottom: 0.2rem;
    width: 5px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 5px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .profile-card h2 { font-size: 1.4rem; }
    .profile-avatar { width: 60px; height: 60px; }
    .stat-number { font-size: 1.5rem; }
    .logbook-pending-table th,
    .logbook-pending-table td {
      padding: 0.5rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .profile-stats { flex-direction: column; gap: 0.4rem; border-radius: 20px; padding: 0.5rem 0.8rem; }
    .profile-stats span { font-size: 0.8rem; }
    .stat-row { flex-direction: column; align-items: stretch; }
    .stat-item { flex-wrap: wrap; }
    .btn-outline-primary { width: 100%; text-align: center; }
    .quick-icon { width: 55px; height: 55px; font-size: 1.8rem; }
    .quick-card h6 { font-size: 0.85rem; }
    
    /* Card view untuk logbook pending */
    .logbook-pending-table thead {
      display: none;
    }
    .logbook-pending-table tr {
      display: block;
      margin-bottom: 1rem;
      border: 1px solid #e9ecef;
      border-radius: 0.75rem;
      padding: 0.75rem;
    }
    .logbook-pending-table td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.4rem 0;
      border-bottom: 1px dashed #e9ecef;
    }
    .logbook-pending-table td:last-child {
      border-bottom: none;
    }
    .logbook-pending-table td::before {
      content: attr(data-label);
      font-weight: 600;
      color: var(--primary-start);
      width: 40%;
    }
  }
</style>

<div class="container mt-4">
  <!-- Profile Card (seperti dashboard mahasiswa) -->
  <div class="profile-card">
    <div class="d-flex align-items-center flex-wrap">
      <div class="flex-shrink-0">
        <% 
          const fotoUrl = dosen && dosen.foto ? getImageUrl(dosen.foto) : null;
          if (fotoUrl) { 
        %>
          <img src="<%= fotoUrl %>" alt="foto <%= dosen.nama %>" class="profile-avatar" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(dosen.nama) %>&background=1e3a8a&color=fff&size=80';">
        <% } else { %>
          <div class="profile-avatar bg-white d-flex align-items-center justify-content-center">
            <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
          </div>
        <% } %>
      </div>
      <div class="flex-grow-1 ms-3 mt-2 mt-sm-0">
        <h2 class="fw-bold"><%= dosen.nama %></h2>
        <p class="mb-1"><%= dosen.nip || '-' %> | <%= dosen.email %></p>
        <!-- Statistik di dalam profile card -->
        <div class="profile-stats">
          <span><i class="bi bi-book"></i> Mata Kuliah: <%= mkCount || 0 %></span>
          <span><i class="bi bi-people"></i> Mahasiswa Bimbingan: <%= totalMahasiswa || 0 %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Card Informasi Dosen (Tugas Aktif & Belum Dinilai + Event + Logbook Pending) -->
  <div class="info-card">
    <div class="card-header">
      <h5><i class="bi bi-info-circle me-2"></i>Informasi Dosen</h5>
    </div>
    <div class="card-body">
      <div class="stat-row">
        <!-- Tugas Aktif -->
        <div class="stat-item">
          <div class="stat-icon">
            <i class="bi bi-file-earmark-text"></i>
          </div>
          <div class="stat-content">
            <div class="stat-label">Tugas Aktif</div>
            <div class="stat-number"><%= tugasAktif || 0 %></div>
          </div>
          <a href="/dosen/tugas" class="btn <%= tugasAktif > 0 ? 'btn-warning' : 'btn-outline-secondary' %> rounded-pill px-4">
            <%= tugasAktif > 0 ? 'Lihat Tugas' : 'Tidak Ada' %>
          </a>
        </div>
        <!-- Belum Dinilai -->
        <div class="stat-item">
          <div class="stat-icon">
            <i class="bi bi-clock-history"></i>
          </div>
          <div class="stat-content">
            <div class="stat-label">Belum Dinilai</div>
            <div class="stat-number"><%= pengumpulanBelumDinilai || 0 %></div>
          </div>
          <a href="/dosen/tugas" class="btn <%= pengumpulanBelumDinilai > 0 ? 'btn-warning' : 'btn-outline-secondary' %> rounded-pill px-4">
            <%= pengumpulanBelumDinilai > 0 ? 'Lihat Nilai' : 'Tidak Ada' %>
          </a>
        </div>
        <!-- Logbook Pending (TAMBAHAN) -->
        <div class="stat-item">
          <div class="stat-icon">
            <i class="bi bi-journal-bookmark-fill"></i>
          </div>
          <div class="stat-content">
            <div class="stat-label">Logbook Pending</div>
            <div class="stat-number"><%= logbookPendingCount %></div>
          </div>
          <a href="/dosen/magang" class="btn <%= logbookPendingCount > 0 ? 'btn-warning' : 'btn-outline-secondary' %> rounded-pill px-4">
            <%= logbookPendingCount > 0 ? 'Lihat Logbook' : 'Tidak Ada' %>
          </a>
        </div>
      </div>

      

      <!-- Bagian Event (jika ada) -->
      <% if (events && events.length > 0) { %>
        <hr class="my-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-calendar-event me-2"></i>Acara Mendatang</h6>
        <div class="d-flex flex-wrap gap-3">
          <% events.slice(0, 4).forEach(event => { %>
            <div class="flex-grow-1" style="min-width: 200px;">
              <div class="p-3 rounded-3" style="background: rgba(30,58,138,0.05); border-left: 3px solid var(--primary-start);">
                <div class="fw-semibold"><%= event.judul %></div>
                <div class="small text-muted">
                  <i class="bi bi-calendar3 me-1"></i><%= new Date(event.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'long' }) %>
                </div>
                <% if (event.deskripsi) { %>
                  <p class="small text-muted mt-1 mb-0"><%= event.deskripsi.substring(0, 100) %><%= event.deskripsi.length > 100 ? '...' : '' %></p>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Aksi Cepat (Fitur Dosen) -->
  <h4 class="section-title">Fitur Dosen</h4>
  <div class="row g-4 mb-4">
    <!-- Buat Tugas -->
    <div class="col-6 col-md-3">
      <a href="/dosen/tugas/create" class="quick-card">
        <div class="quick-icon"><i class="bi bi-plus-circle"></i></div>
        <h6>Buat Tugas</h6>
        <p>Buat tugas baru</p>
      </a>
    </div>
    <!-- Daftar Tugas -->
    <div class="col-6 col-md-3">
      <a href="/dosen/tugas" class="quick-card">
        <div class="quick-icon"><i class="bi bi-list-task"></i></div>
        <h6>Daftar Tugas</h6>
        <p>Lihat semua tugas</p>
      </a>
    </div>
    <!-- Mata Kuliah -->
    <div class="col-6 col-md-3">
      <a href="/dosen/mk" class="quick-card">
        <div class="quick-icon"><i class="bi bi-book"></i></div>
        <h6>Mata Kuliah</h6>
        <p>Lihat progress</p>
      </a>
    </div>
    <!-- Monitoring Magang -->
    <div class="col-6 col-md-3">
      <a href="/dosen/magang" class="quick-card">
        <div class="quick-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
        <h6>Monitoring Magang</h6>
        <p>Lihat logbook</p>
      </a>
    </div>
    <!-- Input Nilai -->
    <div class="col-6 col-md-3">
      <a href="/dosen/nilai" class="quick-card">
        <div class="quick-icon"><i class="bi bi-bar-chart"></i></div>
        <h6>Input Nilai</h6>
        <p>Rekap nilai</p>
      </a>
    </div>
    <!-- ELK Library -->
    <div class="col-6 col-md-3">
      <a href="/dosen/artikel" class="quick-card">
        <div class="quick-icon"><i class="bi bi-journal-richtext"></i></div>
        <h6>ELK Library</h6>
        <p>Kelola artikel</p>
      </a>
    </div>
    <!-- Kalender Akademik -->
    <div class="col-6 col-md-3">
      <a href="/dosen/kalender" class="quick-card">
        <div class="quick-icon"><i class="bi bi-calendar-event"></i></div>
        <h6>Kalender Akademik</h6>
        <p>Jadwal penting</p>
      </a>
    </div>
    <!-- MyRPS -->
    <div class="col-6 col-md-3">
      <a href="/dosen/kurikulum" class="quick-card">
      <div class="quick-icon"><i class="bi bi-file-text"></i></div>
      <h6>MyRPS</h6>
      <p>Kurikulum & RPS</p>
    </a>
    </div>
    <!-- Laporan Magang -->
    <div class="col-6 col-md-3">
      <a href="/dosen/laporan-magang" class="quick-card">
        <div class="quick-icon"><i class="bi bi-file-earmark-pdf"></i></div>
        <h6>Laporan Magang</h6>
        <p>Lihat laporan mahasiswa</p>
      </a>
    </div>
    <!-- Biodata -->
    <div class="col-6 col-md-3">
      <a href="/dosen/biodata" class="quick-card">
        <div class="quick-icon"><i class="bi bi-person"></i></div>
        <h6>Biodata</h6>
        <p>Edit profil</p>
      </a>
    </div>
  </div>

  <!-- Pengumuman atau Berita (opsional) -->
  <% if (berita.length > 0) { %>
    <div class="info-card">
      <div class="card-header">
        <h5><i class="bi bi-megaphone me-2"></i>Pengumuman</h5>
      </div>
      <div class="card-body">
        <div class="row g-4">
          <% berita.slice(0, 3).forEach(b => { %>
            <div class="col-md-4">
              <div class="quick-card p-3 text-start">
                <h6 class="fw-bold"><%= b.judul %></h6>
                <p class="small text-muted"><%= new Date(b.tanggal).toLocaleDateString('id-ID') %></p>
                <p class="small"><%= b.isi.substring(0, 60) %>...</p>
                <a href="/berita/<%= b.id %>" class="btn-outline-primary btn-sm">Baca</a>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>