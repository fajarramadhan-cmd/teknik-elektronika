<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
  }
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .info-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .info-card .card-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 0.8rem 1.2rem;
    font-weight: 600;
  }
  .badge-status {
    padding: 0.3rem 0.9rem;
    border-radius: 60px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-pending { background: #fef3c7; color: #b45309; }
  .badge-completed { background: #d1fae5; color: #065f46; }
  .badge-rejected { background: #fee2e2; color: #991b1b; }
  .badge-cancelled { background: #e2e8f0; color: #475569; }
</style>

<div class="container mt-4">
  <div class="page-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-envelope-paper me-2"></i>Detail Surat</h2>
      <p>Informasi lengkap pengajuan surat Anda</p>
    </div>
    <a href="/dosen/surat" class="btn btn-light"><i class="bi bi-arrow-left me-2"></i>Kembali</a>
  </div>

  <div class="info-card">
    <div class="card-header">
      <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Informasi Surat</h5>
    </div>
    <div class="card-body p-4">
      <div class="row">
        <div class="col-md-6">
          <p><strong>Jenis Surat:</strong> <%= surat.jenisSurat %></p>
          <p><strong>Tujuan:</strong> <%= surat.tujuan || '-' %></p>
          <p><strong>Keperluan:</strong> <%= surat.keperluan %></p>
        </div>
        <div class="col-md-6">
          <p><strong>Kode Validasi:</strong> <code class="bg-light p-1 rounded"><%= surat.kodeValidasi %></code></p>
          <p><strong>Tanggal Pengajuan:</strong> <%= new Date(surat.createdAt).toLocaleString('id-ID') %></p>
          <p><strong>Status:</strong> 
            <span class="badge-status 
              <%= surat.status === 'pending' ? 'badge-pending' : (surat.status === 'completed' ? 'badge-completed' : (surat.status === 'rejected' ? 'badge-rejected' : 'badge-cancelled')) %>">
              <%= surat.status === 'pending' ? 'Menunggu' : (surat.status === 'completed' ? 'Selesai' : (surat.status === 'rejected' ? 'Ditolak' : 'Dibatalkan')) %>
            </span>
          </p>
        </div>
      </div>
      <% if (surat.isiLain) { %>
        <div class="mt-3">
          <strong>Informasi Tambahan:</strong>
          <p class="bg-light p-2 rounded mt-1"><%= surat.isiLain %></p>
        </div>
      <% } %>
    </div>
  </div>

  <% if (surat.status === 'completed' && surat.fileUrl) { %>
    <div class="info-card">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-file-pdf me-2"></i>File Surat</h5>
      </div>
      <div class="card-body p-4">
        <a href="/dosen/surat/<%= surat.id %>/download" target="_blank" class="btn btn-success">
          <i class="bi bi-download me-2"></i>Unduh Surat (PDF)
        </a>
      </div>
    </div>
  <% } %>

  <% if (surat.history && surat.history.length > 0) { %>
    <div class="info-card">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Riwayat Status</h5>
      </div>
      <div class="card-body p-4">
        <ul class="list-group">
          <% surat.history.forEach(h => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span><%= h.catatan %></span>
              <small class="text-muted"><%= new Date(h.timestamp).toLocaleString('id-ID') %></small>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  <% } %>

  <% if (surat.status === 'pending') { %>
    <div class="text-end">
      <form method="POST" action="/dosen/surat/<%= surat.id %>/batal" onsubmit="return confirm('Yakin batalkan pengajuan surat ini?')">
        <button class="btn btn-danger"><i class="bi bi-x-circle me-2"></i>Batalkan Pengajuan</button>
      </form>
    </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>