<%- include('../partials/header') %>

<%
  // Fungsi untuk mendapatkan URL gambar yang dapat ditampilkan
  const getImageUrl = (url) => {
    if (!url) return null;
    // Jika dari Google Drive, konversi ke thumbnail
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    // Jika URL biasa, langsung gunakan
    return url;
  };
%>

<style>
  /* ===== TEMA KONSISTEN ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
  }

  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin: 0;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .page-header .btn-back {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.6rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-header .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Filter Card */
  .filter-card {
    background: white;
    border-radius: 1.5rem;
    border: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.8rem;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(33,147,176,0.1);
  }
  .filter-label {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .form-control, .form-select {
    border-radius: 1rem;
    border: 1px solid #dee2e6;
    padding: 0.6rem 1.2rem;
    transition: all 0.2s;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.25rem rgba(33,147,176,0.25);
  }
  .btn-filter {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(33,147,176,0.2);
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .btn-filter:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(33,147,176,0.4);
  }
  .btn-reset {
    background: white;
    border: 1px solid #ced4da;
    color: #6c757d;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    transition: all 0.2s;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .btn-reset:hover {
    background: #e9ecef;
    border-color: #adb5bd;
    color: #495057;
  }

  /* Tabel */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(33,147,176,0.1);
  }
  .mahasiswa-table {
    margin-bottom: 0;
  }
  .mahasiswa-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1.2rem 1rem;
    white-space: nowrap;
  }
  .mahasiswa-table tbody td {
    vertical-align: middle;
    padding: 1.2rem 1rem;
    background-color: white;
    border-bottom: 1px solid #e9ecef;
  }
  .mahasiswa-table tbody tr:hover td {
    background-color: #f8f9fa;
  }

  /* Avatar dan Foto */
  .avatar-circle {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(33,147,176,0.3);
  }
  .foto-mahasiswa {
    width: 45px;
    height: 45px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  /* Badge MK */
  .badge-mk {
    background: var(--primary-light);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid rgba(33,147,176,0.2);
  }
  .badge-mk-empty {
    background: #f1f3f5;
    color: #868e96;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  /* Angkatan badge */
  .angkatan-badge {
    background: #e9ecef;
    color: #495057;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    display: inline-block;
  }

  /* Tombol detail */
  .btn-detail {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .btn-detail:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(33,147,176,0.3);
  }

  /* Empty state */
  .empty-state {
    padding: 4rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1.1rem;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Page Header dengan gradien -->
  <div class="page-header">
    <h2>
      <i class="bi bi-people-fill"></i> Mahasiswa Bimbingan
    </h2>
    <a href="/dosen/dashboard" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="angkatan" class="filter-label">
          <i class="bi bi-calendar-range" style="color: var(--primary-start);"></i> Angkatan
        </label>
        <select class="form-select" id="angkatan" name="angkatan">
          <option value="">Semua Angkatan</option>
          <% if (angkatanList && angkatanList.length) { %>
            <% angkatanList.forEach(a => { %>
              <option value="<%= a %>" <%= a === filterAngkatan ? 'selected' : '' %>><%= a %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="search" class="filter-label">
          <i class="bi bi-search" style="color: var(--primary-start);"></i> Cari Nama/NIM
        </label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Ketik nama atau NIM" value="<%= search || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn-filter">
          <i class="bi bi-funnel"></i> Filter
        </button>
      </div>
      <div class="col-md-2">
        <a href="/dosen/mahasiswa" class="btn-reset">
          <i class="bi bi-arrow-counterclockwise"></i> Reset
        </a>
      </div>
    </form>
  </div>

  <!-- Tabel Mahasiswa -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table mahasiswa-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Foto</th>
            <th>NIM</th>
            <th>Nama</th>
            <th>Angkatan</th>
            <th>Mata Kuliah</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p>Tidak ada mahasiswa bimbingan.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% mahasiswaList.forEach((m, index) => { 
              const imageUrl = m.foto ? getImageUrl(m.foto) : null;
            %>
            <tr>
              <td class="fw-bold"><%= index + 1 %></td>
              <td>
                <% if (imageUrl) { %>
                  <img src="<%= imageUrl %>" alt="foto <%= m.nama %>" class="foto-mahasiswa" 
                       onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(m.nama) %>&background=2193b0&color=fff&size=45';">
                <% } else { %>
                  <div class="avatar-circle">
                    <%= (m.nama || '?').charAt(0).toUpperCase() %>
                  </div>
                <% } %>
              </td>
              <td><strong><%= m.nim || '-' %></strong></td>
              <td><%= m.nama %></td>
              <td><span class="angkatan-badge"><%= m.angkatan || '-' %></span></td>
              <td>
                <% if (m.mkDiambil && m.mkDiambil.length > 0) { %>
                  <span class="badge-mk">
                    <i class="bi bi-book"></i> <%= m.mkDiambil.length %> MK
                  </span>
                <% } else { %>
                  <span class="badge-mk-empty">
                    <i class="bi bi-book"></i> 0 MK
                  </span>
                <% } %>
              </td>
              <td>
                <a href="/dosen/mahasiswa/<%= m.id %>" class="btn-detail">
                  <i class="bi bi-eye"></i> Detail
                </a>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>