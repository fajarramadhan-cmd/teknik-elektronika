<%- include('../partials/header') %>

<%
  // Fungsi untuk memformat tanggal
  const formatDate = (date) => {
    if (!date) return '-';
    return new Date(date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
  };
%>

<style>
  /* ===== TEMA KONSISTEN ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* Header Detail */
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 2rem;
    border-radius: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .detail-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .detail-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .detail-header .btn-light {
    border-radius: 50px;
    padding: 0.6rem 1.8rem;
    font-weight: 600;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
    background: white;
    color: var(--primary-start);
  }
  .detail-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Info Card */
  .info-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    padding: 1.8rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(33,147,176,0.1);
  }
  .info-card h5 {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .info-card h5 i {
    color: var(--primary-start);
  }

  /* Dosen Badge */
  .dosen-badge {
    background: var(--primary-light);
    color: var(--primary-start);
    border: 1px solid rgba(33,147,176,0.2);
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.9rem;
    display: inline-block;
  }

  /* Progress Bar */
  .progress-lg {
    height: 1.5rem;
    border-radius: 1rem;
    background-color: #e9ecef;
    overflow: hidden;
  }
  .progress-bar {
    background: linear-gradient(90deg, var(--primary-start), var(--primary-end));
    border-radius: 1rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* List Group Mahasiswa */
  .list-group-item {
    border: none;
    border-bottom: 1px solid #e9ecef;
    padding: 1rem 0;
    background: transparent;
  }
  .list-group-item:last-child {
    border-bottom: none;
  }
  .mahasiswa-badge {
    background: var(--primary-light);
    color: var(--primary-start);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
  }
  .btn-link {
    color: var(--primary-start);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }
  .btn-link:hover {
    color: var(--primary-dark);
    text-decoration: underline;
  }

  /* Tabel Pertemuan */
  .table-container {
    background: white;
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    border: 1px solid rgba(33,147,176,0.1);
  }
  .pertemuan-table {
    margin-bottom: 0;
  }
  .pertemuan-table thead th {
    background: #f8f9fa;
    font-weight: 600;
    color: #2c3e50;
    border-bottom: 2px solid var(--primary-start);
    padding: 1rem;
    white-space: nowrap;
  }
  .pertemuan-table tbody td {
    vertical-align: middle;
    padding: 1rem;
    border-bottom: 1px solid #e9ecef;
  }
  .pertemuan-table tbody tr:hover {
    background-color: #f8f9fa;
  }
  .pertemuan-table .table-success {
    background-color: #f0f9ff;
  }

  /* Badge Status */
  .badge-status {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid transparent;
  }
  .badge-success {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-warning {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }

  /* Tombol Aksi */
  .btn-edit-pertemuan {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.25rem 1rem;
    font-size: 0.8rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-edit-pertemuan:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }

  /* Upload Form */
  .upload-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .upload-form .form-control-sm {
    width: 140px;
    height: 32px;
    border-radius: 50px;
    border: 1px solid #ced4da;
    padding: 0.2rem 0.8rem;
    font-size: 0.8rem;
  }
  .upload-form .form-control-sm:hover {
    border-color: var(--primary-start);
  }
  .btn-upload {
    background: var(--primary-start);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-upload:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }

  /* Link File */
  .btn-file {
    background: #e7f5ff;
    color: #0d6efd;
    border: none;
    border-radius: 50px;
    padding: 0.2rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 0.3rem;
  }
  .btn-file:hover {
    background: #d0e8ff;
    color: #0a58ca;
  }

  /* Tugas Card */
  .tugas-item {
    border-left: 4px solid var(--primary-start);
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 1rem;
    margin-bottom: 0.8rem;
  }
  .tugas-item strong {
    color: #1e293b;
  }
  .tugas-item .badge {
    background: var(--primary-light);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
  }

  /* Responsif */
  @media (max-width: 768px) {
    .detail-header .d-flex {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .upload-form {
      flex-direction: column;
      align-items: flex-start;
    }
    .upload-form .form-control-sm {
      width: 100%;
    }
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="detail-header">
    <div class="d-flex flex-wrap justify-content-between align-items-center">
      <div>
        <h1><%= mk.kode %> - <%= mk.nama %></h1>
        <p>
          <span><i class="bi bi-book"></i> <%= mk.sks %> SKS</span>
          <span><i class="bi bi-calendar"></i> <%= mk.semester || 'Semester ?' %></span>
          <span><i class="bi bi-clock"></i> <%= mk.jadwal || 'Jadwal belum diatur' %></span>
        </p>
      </div>
      <a href="/dosen/mk" class="btn-light btn">
        <i class="bi bi-arrow-left"></i> Kembali
      </a>
    </div>
  </div>

  <!-- Info Dosen & Progress -->
  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="info-card">
        <h5><i class="bi bi-people"></i> Dosen Pengampu</h5>
        <% if (dosenList && dosenList.length > 0) { %>
          <div class="d-flex flex-wrap gap-2">
            <% dosenList.forEach(d => { %>
              <span class="dosen-badge"><i class="bi bi-person"></i> <%= d %></span>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted">Belum ada dosen tetap</p>
        <% } %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="info-card">
        <h5><i class="bi bi-bar-chart-steps"></i> Progress Perkuliahan</h5>
        <div class="progress-lg progress mb-2">
          <div class="progress-bar" role="progressbar" style="width: <%= persentase %>%;" 
               aria-valuenow="<%= persentase %>" aria-valuemin="0" aria-valuemax="100">
            <%= persentase %>%
          </div>
        </div>
        <p class="text-muted"><%= terlaksana %> dari 16 pertemuan telah dilaksanakan</p>
      </div>
    </div>
  </div>

  <!-- Daftar Mahasiswa (Short) -->
  <div class="info-card mb-4">
    <h5><i class="bi bi-people-fill"></i> Mahasiswa Terdaftar</h5>
    <div class="list-group">
      <% mahasiswaList.slice(0, 5).forEach(m => { %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <strong><%= m.nama %></strong><br>
            <small class="text-muted"><%= m.nim %></small>
          </div>
          <span class="mahasiswa-badge"><i class="bi bi-check-circle"></i> Aktif</span>
        </div>
      <% }) %>
    </div>
    <a href="/dosen/mk/<%= mk.id %>/mahasiswa" class="btn-link mt-2 d-inline-block">
      <i class="bi bi-arrow-right"></i> Lihat semua mahasiswa
    </a>
  </div>

  <!-- Tabel Pertemuan dengan Upload Materi -->
  <div class="info-card">
    <h5><i class="bi bi-list-task"></i> Rencana Perkuliahan (16 Pertemuan)</h5>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table pertemuan-table">
          <thead>
            <tr>
              <th>Pertemuan</th>
              <th>Topik</th>
              <th>Tanggal</th>
              <th>Status</th>
              <th>Materi</th>
              <th>Catatan</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% pertemuanList.forEach(p => { %>
              <tr class="<%= p.status === 'selesai' ? 'table-success' : '' %>">
                <td class="text-center fw-bold">#<%= p.pertemuan %></td>
                <td>
                  <span class="topik-text-<%= p.pertemuan %>"><%= p.topik %></span>
                  <input type="text" class="form-control form-control-sm edit-input-<%= p.pertemuan %>" value="<%= p.topik %>" style="display: none;">
                </td>
                <td>
                  <span class="tanggal-text-<%= p.pertemuan %>"><%= formatDate(p.tanggal) %></span>
                  <input type="date" class="form-control form-control-sm edit-input-<%= p.pertemuan %>" value="<%= p.tanggal ? p.tanggal.split('T')[0] : '' %>" style="display: none;">
                </td>
                <td>
                  <span class="badge-status <%= p.status === 'selesai' ? 'badge-success' : 'badge-warning' %>">
                    <i class="bi <%= p.status === 'selesai' ? 'bi-check-circle' : 'bi-hourglass-split' %>"></i>
                    <%= p.status === 'selesai' ? 'Selesai' : 'Belum' %>
                  </span>
                </td>
                <td>
                  <% if (p.fileUrl) { %>
                    <a href="<%= p.fileUrl %>" target="_blank" class="btn-file mb-1">
                      <i class="bi bi-file-earmark-pdf"></i> Lihat
                    </a><br>
                  <% } %>
                  <form method="POST" action="/dosen/mk/<%= mk.id %>/pertemuan/<%= p.pertemuan %>" enctype="multipart/form-data" class="upload-form">
                    <input type="file" name="file" class="form-control-sm" accept=".pdf,.doc,.docx,.ppt,.pptx,.jpg,.png">
                    <button type="submit" class="btn-upload"><i class="bi bi-upload"></i> Upload</button>
                  </form>
                </td>
                <td>
                  <span class="catatan-text-<%= p.pertemuan %>"><%= p.catatan || '-' %></span>
                  <input type="text" class="form-control form-control-sm edit-input-<%= p.pertemuan %>" value="<%= p.catatan || '' %>" style="display: none;">
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <button class="btn-edit-pertemuan" onclick="editPertemuan(<%= p.pertemuan %>)">
                      <i class="bi bi-pencil"></i> Edit
                    </button>
                    <button class="btn-edit-pertemuan" onclick="submitEdit(<%= p.pertemuan %>)" style="display: none;" id="save-<%= p.pertemuan %>">
                      <i class="bi bi-check-lg"></i> Simpan
                    </button>
                    <button class="btn-edit-pertemuan" onclick="cancelEdit(<%= p.pertemuan %>)" style="display: none;" id="cancel-<%= p.pertemuan %>">
                      <i class="bi bi-x-lg"></i> Batal
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tugas Terkait -->
  <% if (tugasList && tugasList.length > 0) { %>
    <div class="info-card mt-4">
      <h5><i class="bi bi-file-earmark-text"></i> Tugas Aktif</h5>
      <div class="row g-3">
        <% tugasList.slice(0, 5).forEach(t => { %>
          <div class="col-md-6">
            <div class="tugas-item">
              <div class="d-flex justify-content-between align-items-start">
                <strong><%= t.judul %></strong>
                <span class="badge"><%= t.tipe %></span>
              </div>
              <small class="text-muted"><i class="bi bi-calendar3"></i> Deadline: <%= formatDate(t.deadline) %></small>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<script>
  function editPertemuan(pertemuan) {
    // Hide text
    document.querySelector(`.topik-text-${pertemuan}`).style.display = 'none';
    document.querySelector(`.tanggal-text-${pertemuan}`).style.display = 'none';
    document.querySelector(`.catatan-text-${pertemuan}`).style.display = 'none';
    
    // Show inputs
    document.querySelectorAll(`.edit-input-${pertemuan}`).forEach(el => el.style.display = 'block');
    
    // Show buttons
    document.getElementById(`save-${pertemuan}`).style.display = 'inline-block';
    document.getElementById(`cancel-${pertemuan}`).style.display = 'inline-block';
  }

  function cancelEdit(pertemuan) {
    // Show text
    document.querySelector(`.topik-text-${pertemuan}`).style.display = 'inline';
    document.querySelector(`.tanggal-text-${pertemuan}`).style.display = 'inline';
    document.querySelector(`.catatan-text-${pertemuan}`).style.display = 'inline';
    
    // Hide inputs
    document.querySelectorAll(`.edit-input-${pertemuan}`).forEach(el => el.style.display = 'none');
    
    // Hide buttons
    document.getElementById(`save-${pertemuan}`).style.display = 'none';
    document.getElementById(`cancel-${pertemuan}`).style.display = 'none';
  }

  function submitEdit(pertemuan) {
    const topik = document.querySelectorAll(`.edit-input-${pertemuan}`)[0].value;
    const tanggal = document.querySelectorAll(`.edit-input-${pertemuan}`)[1].value;
    const catatan = document.querySelectorAll(`.edit-input-${pertemuan}`)[2].value;
    
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/dosen/mk/<%= mk.id %>/pertemuan/${pertemuan}`;
    form.enctype = 'multipart/form-data'; // penting jika ada file, tapi di sini hanya teks
    
    const inputTopik = document.createElement('input');
    inputTopik.type = 'hidden';
    inputTopik.name = 'topik';
    inputTopik.value = topik;
    form.appendChild(inputTopik);
    
    const inputTanggal = document.createElement('input');
    inputTanggal.type = 'hidden';
    inputTanggal.name = 'tanggal';
    inputTanggal.value = tanggal;
    form.appendChild(inputTanggal);
    
    const inputCatatan = document.createElement('input');
    inputCatatan.type = 'hidden';
    inputCatatan.name = 'catatan';
    inputCatatan.value = catatan;
    form.appendChild(inputCatatan);
    
    document.body.appendChild(form);
    form.submit();
  }
</script>

<%- include('../partials/footer') %>