<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', 'Segoe UI', system-ui, sans-serif;
      background: radial-gradient(circle at 20% 30%, #0a2f3a, #03121f);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .tv-screen {
      width: 100%;
      max-width: 1400px;
      aspect-ratio: 16 / 9;
      background: rgba(0,0,0,0.3);
      border-radius: 32px;
      backdrop-filter: blur(2px);
      box-shadow: 0 25px 45px rgba(0,0,0,0.4);
      display: flex;
      flex-direction: column;
      padding: 20px;
    }
    /* Header */
    .tv-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(15,35,55,0.7);
      backdrop-filter: blur(16px);
      border-radius: 40px;
      padding: 10px 20px;
      margin-bottom: 20px;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .logo-area {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo-area img { height: 45px; width: auto; }
    .title h1 { font-size: 1.2rem; color: white; }
    .title p { font-size: 0.65rem; opacity: 0.9; color: white; } /* subtitle putih */
    .center-title h2 {
      font-size: 1.5rem;
      background: linear-gradient(120deg, #fff, #ffd966);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }
    /* Jam besar, putih, tanpa tanggal */
    .clock {
      background: rgba(0,0,0,0.6);
      padding: 6px 14px;
      border-radius: 60px;
      font-family: monospace;
      font-size: 1.8rem;  /* diperbesar */
      font-weight: bold;
      text-align: center;
      border: 1px solid rgba(255,215,0,0.4);
      color: white;
      min-width: 180px;
      letter-spacing: 2px;
    }
    /* 3 Kolom Layout */
    .three-col {
      flex: 1;
      display: flex;
      gap: 20px;
      min-height: 0;
    }
    /* Kolom Kiri - Info Mahasiswa */
    .col-left {
      flex: 1.2;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(12px);
      border-radius: 28px;
      padding: 18px;
      border: 1px solid rgba(255,255,255,0.15);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
    }
    .student-card {
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 15px;
      margin-bottom: 15px;
    }
    .student-card h3 {
      color: #ffd966;
      font-size: 1.2rem;
      margin-bottom: 10px;
      border-left: 3px solid #ffd966;
      padding-left: 10px;
    }
    .info-row {
      margin: 8px 0;
      color: white;
      font-size: 0.85rem;
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
    }
    .info-label {
      font-weight: 600;
      min-width: 90px;
      color: #aaa;
    }
    .info-value {
      color: white;
      word-break: break-word;
    }
    /* Kolom Tengah - Foto */
    .col-middle {
      flex: 2.5;
      background: #00000066;
      border-radius: 28px;
      overflow: hidden;
      position: relative;
    }
    .slides-wrapper {
      height: 100%;
      width: 100%;
      position: relative;
    }
    .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.7s;
      visibility: hidden;
      display: flex;
      flex-direction: column;
    }
    .slide.active {
      opacity: 1;
      visibility: visible;
    }
    .slide-image {
      flex: 1;
      overflow: hidden;
      margin: 10px;
      border-radius: 24px;
    }
    .slide-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 24px;
    }
    /* Kolom Kanan - Statistik Prodi */
    .col-right {
      flex: 1;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(12px);
      border-radius: 28px;
      padding: 18px;
      border: 1px solid rgba(255,255,255,0.15);
      display: flex;
      flex-direction: column;
      gap: 15px;
      overflow-y: auto;
    }
    .stat-card {
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 12px;
    }
    .stat-card h4 {
      color: #ffd966;
      font-size: 1rem;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: white;
      text-align: center;
    }
    .stat-desc {
      text-align: center;
      font-size: 0.7rem;
      color: #ccc;
    }
    .progress-bar-container {
      background: #333;
      border-radius: 10px;
      margin-top: 5px;
    }
    .progress-bar-fill {
      width: 0%;
      height: 8px;
      background: #ffd966;
      border-radius: 10px;
    }
    .running-text {
      background: rgba(10,25,40,0.8);
      border-radius: 40px;
      padding: 8px 16px;
      margin-top: 18px;
      overflow: hidden;
      white-space: nowrap;
      font-size: 0.8rem;
      border: 1px solid rgba(255,215,0,0.5);
      color: white;
    }
    marquee { color: white; }
    @media (max-width: 900px) {
      .three-col { flex-direction: column; }
      .tv-screen { aspect-ratio: auto; height: auto; }
      .clock { font-size: 1.2rem; min-width: 120px; }
    }
  </style>
</head>
<body>
<div class="tv-screen">
  <div class="tv-header">
    <div class="logo-area">
      <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" alt="Logo" onerror="this.src='https://placehold.co/50x50?text=PD'">
      <div class="title">
        <h1>TEKNIK ELEKTRONIKA (D3)</h1>
        <p>by POLITEKNIK DEWANTARA</p>   <!-- subtitle putih -->
      </div>
    </div>
    <div class="center-title">
      <h2>MONITORING MAGANG MAHASISWA</h2>
    </div>
    <div class="clock" id="liveClock">--:--:--</div> <!-- hanya waktu -->
  </div>

  <div class="three-col">
    <!-- KOLOM KIRI: Info Mahasiswa -->
    <div class="col-left" id="infoMahasiswa">
      <div class="student-card">
        <h3><i class="fas fa-user-graduate"></i> Mahasiswa</h3>
        <div class="info-row">
          <span class="info-value" id="slideNama" style="font-size: 1.4rem; font-weight: bold; color: #ffd966;">-</span>
        </div>
        <div class="info-row"><span class="info-label">NIM:</span><span class="info-value" id="slideNim">-</span></div>
        <div class="info-row"><span class="info-label">Perusahaan:</span><span class="info-value" id="slidePerusahaan">-</span></div>
        <div class="info-row"><span class="info-label">Dospim 1:</span><span class="info-value" id="slidePembimbing1">-</span></div>
        <div class="info-row"><span class="info-label">Dospim 2:</span><span class="info-value" id="slidePembimbing2">-</span></div>
        <div class="info-row"><span class="info-label">Progress Logbook:</span>
          <span class="info-value" id="slideProgress">-</span>
        </div>
        <div class="progress-bar-container">
          <div id="slideProgressBar" class="progress-bar-fill"></div>
        </div>
        <div class="info-row"><span class="info-label">Kegiatan:</span><span class="info-value" id="slideKegiatan">-</span></div>
        <div class="info-row"><span class="info-label">Tanggal:</span><span class="info-value" id="slideTanggal">-</span></div>
        <div class="info-row"><span class="info-label">Lokasi:</span><span class="info-value" id="slideLokasi">-</span></div>
      </div>
    </div>

    <!-- KOLOM TENGAH: Slideshow Foto -->
    <div class="col-middle">
      <div class="slides-wrapper" id="slidesWrapper"></div>
    </div>

    <!-- KOLOM KANAN: Statistik Prodi -->
    <div class="col-right">
      <div class="stat-card">
        <h4><i class="fas fa-book"></i> Total Logbook</h4>
        <div class="stat-number"><%= stats.totalLogbook %></div>
        <div class="stat-desc">semua entri</div>
      </div>
      <div class="stat-card">
        <h4><i class="fas fa-clock"></i> Logbook Pending</h4>
        <div class="stat-number"><%= stats.logbookPending %></div>
        <div class="stat-desc">menunggu persetujuan</div>
      </div>
      <div class="stat-card">
        <h4><i class="fas fa-users"></i> Mahasiswa Magang Aktif</h4>
        <div class="stat-number"><%= stats.totalMahasiswaMagangAktif %></div>
        <div class="stat-desc">sedang magang</div>
      </div>
      <div class="stat-card">
        <h4><i class="fas fa-tasks"></i> Tugas Aktif</h4>
        <div class="stat-number"><%= stats.tugasAktif %></div>
        <div class="stat-desc">perlu dinilai</div>
      </div>
    </div>
  </div>

  <div class="running-text">
    <marquee behavior="scroll" direction="left" scrollamount="5" onmouseover="this.stop()" onmouseout="this.start()">
      Realtime Monitoring Magang Mahasiswa Prodi Teknik Elektronika | Database dari Logbook Digital ELK-Magang elektronika.polidewa.ac.id | Design by Fajar Elektrik v.1.0.0
    </marquee>
  </div>
</div>

<script>
  const slides = <%- JSON.stringify(slides) %>;
  let currentIndex = 0;
  let autoInterval;

  function updateInfoPanel(index) {
    const slide = slides[index];
    if (!slide) return;
    document.getElementById('slideNama').innerText = slide.mahasiswa || '-';
    document.getElementById('slideNim').innerText = slide.nim || '-';
    document.getElementById('slidePerusahaan').innerText = slide.perusahaan || '-';
    document.getElementById('slidePembimbing1').innerText = slide.pembimbing1 || '-';
    document.getElementById('slidePembimbing2').innerText = slide.pembimbing2 || '-';
    document.getElementById('slideKegiatan').innerText = slide.caption || '-';
    document.getElementById('slideTanggal').innerText = slide.tanggal || '-';
    document.getElementById('slideLokasi').innerText = slide.lokasi || '-';
    
    const progressText = `${slide.progressUploaded || 0} / ${slide.progressTotal || 0} hari (${slide.progressPercent || 0}%)`;
    document.getElementById('slideProgress').innerText = progressText;
    document.getElementById('slideProgressBar').style.width = `${slide.progressPercent || 0}%`;
  }

  function buildSlides() {
    const wrapper = document.getElementById('slidesWrapper');
    wrapper.innerHTML = '';
    slides.forEach((slide, idx) => {
      const slideDiv = document.createElement('div');
      slideDiv.className = 'slide';
      if (idx === 0) slideDiv.classList.add('active');
      slideDiv.innerHTML = `
        <div class="slide-image">
          <img src="${slide.imageUrl}" alt="Foto Magang" onerror="this.onerror=null; this.src='https://via.placeholder.com/800x600?text=Gambar+Tidak+Tersedia'">
        </div>
      `;
      wrapper.appendChild(slideDiv);
    });
    if (slides.length) updateInfoPanel(0);
  }

  function goToSlide(index) {
    const slidesDivs = document.querySelectorAll('.slide');
    if (!slidesDivs.length) return;
    slidesDivs[currentIndex].classList.remove('active');
    currentIndex = (index + slides.length) % slides.length;
    slidesDivs[currentIndex].classList.add('active');
    updateInfoPanel(currentIndex);
  }

  function nextSlide() { goToSlide(currentIndex + 1); }
  function startAutoSlide() {
    if (autoInterval) clearInterval(autoInterval);
    autoInterval = setInterval(nextSlide, 8000);
  }

  // Jam hanya menampilkan waktu (HH:MM:SS), besar, putih
  function updateClock() {
    const now = new Date();
    const timeStr = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    document.getElementById('liveClock').innerText = timeStr;
  }

  window.onload = () => {
    buildSlides();
    startAutoSlide();
    updateClock();
    setInterval(updateClock, 1000);
  };
</script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</body>
</html>