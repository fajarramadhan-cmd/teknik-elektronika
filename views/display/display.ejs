<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Galeri Magang - TV Prodi</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', 'Segoe UI', system-ui, sans-serif;
      background: radial-gradient(circle at 20% 30%, #0a2f3a, #03121f);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .tv-screen {
      width: 100%;
      max-width: 1280px;
      aspect-ratio: 16 / 9;
      background: rgba(0,0,0,0.3);
      border-radius: 32px;
      backdrop-filter: blur(2px);
      box-shadow: 0 25px 45px rgba(0,0,0,0.4);
      display: flex;
      flex-direction: column;
      padding: 20px;
    }
    .tv-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(15,35,55,0.7);
      backdrop-filter: blur(16px);
      border-radius: 40px;
      padding: 12px 24px;
      margin-bottom: 20px;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .logo-area {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .logo-area img {
      height: 50px;
      width: auto;
    }
    .title h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
    }
    .title p {
      font-size: 0.7rem;
      opacity: 0.9;
    }
    .center-title {
      text-align: center;
      flex: 1;
    }
    .center-title h2 {
      font-size: 1.8rem;
      background: linear-gradient(120deg, #fff, #ffd966);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }
    .clock {
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(8px);
      padding: 8px 16px;
      border-radius: 60px;
      font-family: monospace;
      font-size: 0.9rem;
      text-align: center;
      border: 1px solid rgba(255,215,0,0.4);
      color: white;
      min-width: 160px;
    }
    .carousel-container {
      flex: 1;
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      background: #00000066;
    }
    .slides-wrapper {
      height: 100%;
      width: 100%;
      position: relative;
    }
    .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.7s ease-in-out;
      visibility: hidden;
      display: flex;
      flex-direction: column;
    }
    .slide.active {
      opacity: 1;
      visibility: visible;
    }
    .slide-image {
      flex: 1;
      overflow: hidden;
      margin: 8px;
      border-radius: 24px;
    }
    .slide-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 24px;
    }
    .slide-caption {
      background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
      padding: 15px 20px;
      color: white;
      border-radius: 0 0 24px 24px;
      margin-top: -70px;
      position: relative;
      z-index: 2;
    }
    .slide-caption h3 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 5px;
    }
    .slide-caption p {
      font-size: 0.85rem;
      margin: 3px 0;
    }
    .running-text {
      background: rgba(10,25,40,0.8);
      backdrop-filter: blur(12px);
      border-radius: 40px;
      padding: 10px 20px;
      margin-top: 18px;
      overflow: hidden;
      white-space: nowrap;
      font-size: 0.9rem;
      border: 1px solid rgba(255,215,0,0.5);
      color: white;
    }
    marquee { color: white; }
    @media (max-width: 768px) {
      .tv-screen { aspect-ratio: auto; height: auto; }
      .center-title h2 { font-size: 1.2rem; }
      .slide-caption h3 { font-size: 1rem; }
    }
  </style>
</head>
<body>
<div class="tv-screen">
  <div class="tv-header">
    <div class="logo-area">
      <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" alt="Logo" onerror="this.src='https://placehold.co/50x50?text=PD'">
      <div class="title">
        <h1>POLITEKNIK DEWANTARA</h1>
        <p>TV DISPLAY - PRODI ELEKTRONIKA</p>
      </div>
    </div>
    <div class="center-title">
      <h2>📸 GALERI MAGANG MAHASISWA</h2>
    </div>
    <div class="clock" id="liveClock">Memuat jam...</div>
  </div>

  <div class="carousel-container">
    <div class="slides-wrapper" id="slidesWrapper"></div>
  </div>

  <div class="running-text">
    <marquee behavior="scroll" direction="left" scrollamount="5" onmouseover="this.stop()" onmouseout="this.start()">
      📢 Total Mahasiswa Aktif Magang: <span id="totalMahasiswa"><%= totalMahasiswaMagang %></span> orang | 
      📸 Total Logbook Disetujui: <span id="totalLogbook"><%= totalLogbookApproved %></span> foto | 
      🏆 Semangat menyelesaikan magang dengan baik! | 
      📞 Hubungi helpdesk akademik untuk informasi lebih lanjut.
    </marquee>
  </div>
</div>

<script>
  const slides = <%- JSON.stringify(slides) %>;
  let currentIndex = 0;
  let autoInterval;

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  function buildSlides() {
    const wrapper = document.getElementById('slidesWrapper');
    wrapper.innerHTML = '';
    slides.forEach((slide, idx) => {
      const slideDiv = document.createElement('div');
      slideDiv.className = 'slide';
      if (idx === 0) slideDiv.classList.add('active');
      slideDiv.innerHTML = `
        <div class="slide-image">
          <img src="${slide.imageUrl}" alt="Foto Magang" onerror="this.onerror=null; this.src='https://via.placeholder.com/1280x720?text=Gambar+Tidak+Tersedia'">
        </div>
        <div class="slide-caption">
          <h3><i class="fas fa-user-graduate"></i> ${escapeHtml(slide.mahasiswa)}</h3>
          <p><i class="fas fa-calendar-alt"></i> ${slide.tanggal} | <i class="fas fa-map-marker-alt"></i> ${slide.lokasi || 'Tidak ada lokasi'}</p>
          <p><i class="fas fa-tasks"></i> ${escapeHtml(slide.caption)}</p>
        </div>
      `;
      wrapper.appendChild(slideDiv);
    });
  }

  function goToSlide(index) {
    const slidesDivs = document.querySelectorAll('.slide');
    if (!slidesDivs.length) return;
    slidesDivs[currentIndex].classList.remove('active');
    currentIndex = (index + slides.length) % slides.length;
    slidesDivs[currentIndex].classList.add('active');
  }

  function nextSlide() {
    goToSlide(currentIndex + 1);
  }

  function startAutoSlide() {
    if (autoInterval) clearInterval(autoInterval);
    autoInterval = setInterval(nextSlide, 8000);
  }

  function updateClock() {
    const now = new Date();
    const dateStr = now.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    const timeStr = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    document.getElementById('liveClock').innerHTML = `${dateStr}<br>🕒 ${timeStr}`;
  }

  window.onload = () => {
    buildSlides();
    startAutoSlide();
    updateClock();
    setInterval(updateClock, 1000);
  };
</script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</body>
</html>