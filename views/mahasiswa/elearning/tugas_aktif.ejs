<%- include('../../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
  }

  /* Header dengan gradien biru (konsisten) */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.2rem;
    padding: 1.2rem;
    color: white;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 20px rgba(30,58,138,0.2);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
  }
  .page-header h2 {
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .page-header p {
    font-size: 0.8rem;
    opacity: 0.9;
    margin: 0.2rem 0 0;
  }
  .btn-back {
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: 0.2s;
  }
  .btn-back:hover {
    background: rgba(255,255,255,0.3);
    transform: translateY(-2px);
    color: white;
  }

  /* Container tabel responsif */
  .table-card {
    background: white;
    border-radius: 1.2rem;
    padding: 0;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
    overflow-x: auto;
  }
  .tugas-table {
    width: 100%;
    min-width: 600px; /* Membuat tabel bisa di-scroll horizontal di HP */
    margin-bottom: 0;
  }
  .tugas-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    padding: 0.8rem;
    border: none;
  }
  .tugas-table tbody td {
    padding: 0.8rem;
    vertical-align: middle;
    border-bottom: 1px solid #f0f2f5;
    font-size: 0.85rem;
  }
  .tugas-table tbody tr:hover {
    background-color: #fefce8;
  }

  /* Badge status */
  .badge-status {
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }
  .badge-belum { background: #fef3c7; color: #b45309; }
  .badge-sudah { background: #d1fae5; color: #065f46; }

  /* Deadline */
  .deadline-lewat { color: #dc3545; font-weight: 600; }

  /* Tombol */
  .btn-detail {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.25rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-detail:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(30,58,138,0.3);
    color: white;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 2rem;
  }
  .empty-state i {
    font-size: 2.5rem;
    color: #cbd5e1;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .page-header h2 { font-size: 1.3rem; }
    .btn-back { padding: 0.3rem 0.8rem; font-size: 0.75rem; }
    .tugas-table thead th { font-size: 0.7rem; padding: 0.6rem; }
    .tugas-table tbody td { font-size: 0.8rem; padding: 0.6rem; }
    .badge-status { font-size: 0.65rem; padding: 0.2rem 0.5rem; }
    .btn-detail { font-size: 0.7rem; padding: 0.2rem 0.7rem; }
  }

  @media (max-width: 576px) {
    .page-header h2 { font-size: 1.2rem; }
    .page-header p { font-size: 0.7rem; }
    .btn-back { font-size: 0.7rem; }
    .tugas-table { min-width: 520px; }
    .tugas-table thead th { font-size: 0.65rem; }
  }
</style>

<div class="container mt-3">
  <!-- Header -->
  <div class="page-header">
    <div>
      <h2><i class="bi bi-list-task"></i> Tugas Aktif</h2>
      <p>Daftar tugas yang masih dapat dikerjakan</p>
    </div>
    <a href="/mahasiswa/elearning" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <!-- Tabel -->
  <div class="table-card">
    <div class="table-responsive">
      <table class="tugas-table">
        <thead>
          <tr>
            <th>Mata Kuliah</th>
            <th>Judul Tugas</th>
            <th>Deadline</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (tugasList && tugasList.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-4">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p class="mt-2 mb-0">Tidak ada tugas aktif</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% tugasList.forEach(t => { 
              const deadline = new Date(t.deadline);
              const now = new Date();
              const deadlineLewat = deadline < now;
            %>
              <tr>
                <td>
                  <strong><%= t.mkKode %></strong><br>
                  <small class="text-muted"><%= t.mkNama %></small>
                </td>
                <td>
                  <strong><%= t.judul %></strong>
                  <% if (t.deskripsi) { %>
                    <br><small class="text-muted"><%= t.deskripsi.substring(0, 40) %><%= t.deskripsi.length > 40 ? '...' : '' %></small>
                  <% } %>
                </td>
                <td class="<%= deadlineLewat ? 'deadline-lewat' : '' %>">
                  <i class="bi bi-calendar-event"></i> <%= deadline.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %><br>
                  <i class="bi bi-clock"></i> <%= deadline.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                </td>
                <td>
                  <% if (t.pengumpulan) { %>
                    <span class="badge-status badge-sudah">
                      <i class="bi bi-check-circle-fill"></i> Sudah
                    </span>
                  <% } else { %>
                    <span class="badge-status badge-belum">
                      <i class="bi bi-hourglass-split"></i> Belum
                    </span>
                  <% } %>
                </td>
                <td>
                  <a href="/mahasiswa/elearning/tugas/<%= t.id %>" class="btn-detail">
                    <i class="bi bi-eye"></i> Detail
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>