<%- include('../../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive (jika diperlukan nanti)
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.2rem;
    padding: 1.2rem;
    color: white;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 20px rgba(30,58,138,0.2);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
  }
  .page-header h2 {
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .page-header p {
    font-size: 0.8rem;
    opacity: 0.9;
    margin: 0.2rem 0 0;
  }
  .btn-back {
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-weight: 500;
    color: white;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    transition: 0.2s;
  }
  .btn-back:hover {
    background: rgba(255,255,255,0.3);
    transform: translateY(-2px);
    color: white;
  }

  /* ===== TABEL RESPONSIF ===== */
  .table-wrapper {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    overflow-x: auto;
    border: 1px solid rgba(30,58,138,0.1);
    -webkit-overflow-scrolling: touch;
  }
  .table-mk {
    width: 100%;
    min-width: 500px; /* Agar tabel tidak terlalu sempit di hp, bisa di-scroll */
    margin-bottom: 0;
  }
  .table-mk th {
    background: #f8fafc;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.7rem;
    padding: 0.7rem 0.5rem;
    border-bottom: 2px solid #e2e8f0;
    text-align: center;
  }
  .table-mk td {
    padding: 0.7rem 0.5rem;
    vertical-align: middle;
    border-bottom: 1px solid #f0f2f5;
    font-size: 0.8rem;
    text-align: center;
  }
  .table-mk td:first-child {
    text-align: left;
    font-weight: 500;
  }
  .table-mk tr:hover {
    background: #fefce8;
  }
  .progress-bar-bg {
    background: #e2e8f0;
    height: 6px;
    border-radius: 3px;
    width: 100%;
    overflow: hidden;
    margin-top: 4px;
  }
  .progress-bar-fill {
    background: linear-gradient(90deg, var(--primary-start), var(--primary-end));
    height: 100%;
    border-radius: 3px;
  }
  .progress-text {
    font-size: 0.7rem;
    display: flex;
    justify-content: space-between;
    margin-bottom: 2px;
  }
  .badge-tugas {
    background: #d1fae5;
    color: #065f46;
    padding: 0.2rem 0.5rem;
    border-radius: 50px;
    font-size: 0.65rem;
    font-weight: 600;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .badge-tidak {
    background: #fef3c7;
    color: #92400e;
  }
  .btn-detail {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
    font-size: 0.7rem;
    transition: 0.2s;
    text-decoration: none;
    display: inline-block;
    white-space: nowrap;
  }
  .btn-detail:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(30,58,138,0.3);
    color: white;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    text-align: center;
    padding: 2rem;
  }
  .empty-state i {
    font-size: 2.5rem;
    color: #cbd5e1;
  }
  .empty-state h5 {
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }

  /* ===== RESPONSIVE UNTUK HP ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { padding: 1rem; }
    .page-header h2 { font-size: 1.3rem; }
    .btn-back { padding: 0.3rem 0.8rem; font-size: 0.75rem; }
    .table-mk th { font-size: 0.65rem; padding: 0.5rem 0.3rem; }
    .table-mk td { padding: 0.5rem 0.3rem; font-size: 0.75rem; }
    .badge-tugas { font-size: 0.6rem; padding: 0.15rem 0.4rem; }
    .btn-detail { font-size: 0.65rem; padding: 0.2rem 0.6rem; }
    .progress-text { font-size: 0.65rem; }
  }

  @media (max-width: 480px) {
    .table-mk { min-width: 480px; }
    .table-mk th { font-size: 0.6rem; }
    .table-mk td { font-size: 0.7rem; }
    .btn-detail { font-size: 0.6rem; padding: 0.2rem 0.5rem; }
    .badge-tugas { font-size: 0.55rem; }
    .progress-text { font-size: 0.6rem; }
  }

  @media (max-width: 360px) {
    .table-mk { min-width: 420px; }
    .table-mk th, .table-mk td { padding: 0.4rem 0.2rem; }
  }
</style>

<div class="container mt-3">
  <!-- Header responsif -->
  <div class="page-header">
    <div>
      <h2><i class="bi bi-laptop"></i> ELK‑Learning</h2>
      <p>Mata kuliah Anda dengan progres & tugas</p>
    </div>
    <a href="/mahasiswa/dashboard" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <!-- Tabel Mata Kuliah -->
  <div class="table-wrapper">
    <div class="table-responsive">
      <table class="table table-mk">
        <thead>
          <tr>
            <th>Mata Kuliah</th>
            <th>Jml Mhs</th>
            <th>Progress</th>
            <th>Status Tugas</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mkList.length === 0) { %>
            <tr>
              <td colspan="5" class="empty-state">
                <i class="bi bi-inbox"></i>
                <h5>Belum Ada Mata Kuliah</h5>
                <p class="text-muted small">Anda belum terdaftar di mata kuliah manapun.</p>
                <a href="/mahasiswa/akademik/krs" class="btn-detail mt-2">Buat KRS</a>
              </td>
            </tr>
          <% } else { %>
            <% mkList.forEach(mk => { %>
              <tr>
                <td class="fw-semibold text-start"><%= mk.kode %> - <%= mk.nama %></td>
                <td><%= mk.jumlahMahasiswa || 0 %></td>
                <td>
                  <div class="progress-text">
                    <span><%= mk.progressPertemuan.terlaksana %>/16</span>
                    <span><%= mk.progressPertemuan.persen %>%</span>
                  </div>
                  <div class="progress-bar-bg">
                    <div class="progress-bar-fill" style="width: <%= mk.progressPertemuan.persen %>%;"></div>
                  </div>
                </td>
                <td>
                  <% if (mk.adaTugasAktif) { %>
                    <span class="badge-tugas"><i class="bi bi-check-circle-fill"></i> Ada</span>
                  <% } else { %>
                    <span class="badge-tugas badge-tidak"><i class="bi bi-clock-history"></i> Tidak</span>
                  <% } %>
                </td>
                <td>
                  <a href="/mahasiswa/elearning/mk/<%= mk.id %>" class="btn-detail">
                    <i class="bi bi-eye"></i> Detail
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>