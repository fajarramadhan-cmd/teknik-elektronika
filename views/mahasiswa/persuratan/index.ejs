<%- include('../../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .persuratan-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .persuratan-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .persuratan-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .persuratan-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }

  /* ===== TOMBOL GRADIEN ===== */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(33,147,176,0.2);
    text-decoration: none;
    display: inline-block;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(33,147,176,0.4);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }
  .btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  /* ===== ACTION BUTTONS ===== */
  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .surat-table {
    margin-bottom: 0;
  }
  .surat-table thead th {
    background: linear-gradient(135deg, var(--primary-light), rgba(109,213,237,0.1));
    color: var(--primary-dark);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--primary-start);
    padding: 1rem 0.75rem;
  }
  .surat-table tbody tr {
    transition: all 0.2s;
  }
  .surat-table tbody tr:hover {
    background-color: var(--primary-light);
    transform: scale(1.01);
    box-shadow: 0 5px 15px rgba(33,147,176,0.1);
  }
  .surat-table td {
    padding: 1rem 0.75rem;
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }
  .badge-approved {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-rejected {
    background: #f8d7da;
    color: #721c24;
    border-color: #f5c6cb;
  }
  .badge-cancelled {
    background: #e2e3e5;
    color: #383d41;
    border-color: #d6d8db;
  }
  .badge-completed {
    background: #d1ecf1;
    color: #0c5460;
    border-color: #bee5eb;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 1.5rem;
  }
</style>

<div class="container-fluid mt-4">
  <!-- HEADER DENGAN GRADIEN (tanpa tombol) -->
  <div class="persuratan-header">
    <h2><i class="bi bi-envelope-paper-fill me-2"></i>Persuratan</h2>
    <p class="mb-0">Kelola pengajuan surat aktif kuliah dan surat lainnya</p>
  </div>

  <!-- TOMBOL AKSI (dipisah dari header) -->
  <div class="action-buttons">
    <a href="/mahasiswa/persuratan/aktif-kuliah" class="btn-gradient btn-icon">
      <i class="bi bi-envelope-paper"></i> Surat Aktif Kuliah
    </a>
    <a href="/mahasiswa/persuratan/lainnya" class="btn-outline-gradient btn-icon">
      <i class="bi bi-envelope-plus"></i> Surat Lainnya
    </a>
  </div>

  <!-- TABEL DAFTAR SURAT -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table surat-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Jenis Surat</th>
            <th>Nomor Surat</th>
            <th>Tanggal Pengajuan</th>
            <th>Semester</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (suratList.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Belum Ada Surat</h4>
                  <p>Ajukan surat pertama Anda dengan klik tombol di atas.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% suratList.forEach((surat, index) => { %>
            <tr>
              <td class="fw-semibold"><%= index + 1 %></td>
              <td><%= surat.jenis %></td>
              <td><%= surat.nomorSurat || '-' %></td>
              <td><%= new Date(surat.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
              <td><%= surat.semester || '-' %></td>
              <td>
                <% if (surat.status === 'pending') { %>
                  <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                <% } else if (surat.status === 'approved') { %>
                  <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                <% } else if (surat.status === 'rejected') { %>
                  <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                <% } else if (surat.status === 'cancelled') { %>
                  <span class="badge-status badge-cancelled"><i class="bi bi-x-octagon"></i> Dibatalkan</span>
                <% } else if (surat.status === 'completed') { %>
                  <span class="badge-status badge-completed"><i class="bi bi-check2-all"></i> Selesai</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/mahasiswa/persuratan/<%= surat.id %>" class="btn btn-sm btn-outline-primary" title="Detail">
                    <i class="bi bi-eye"></i>
                  </a>
                  <% if (surat.status === 'completed' && surat.fileUrl) { %>
                    <a href="/mahasiswa/persuratan/<%= surat.id %>/download" class="btn btn-sm btn-outline-success" target="_blank" title="Unduh">
                      <i class="bi bi-download"></i>
                    </a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>