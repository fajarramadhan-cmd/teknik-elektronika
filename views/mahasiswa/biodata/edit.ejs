<%- include('../../partials/header') %>

<%
  // Fungsi untuk mendapatkan thumbnail dari Google Drive
  const getDriveThumbnail = (url, size = 200) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    return url;
  };
  const fotoPreview = user.foto ? getDriveThumbnail(user.foto, 200) : null;
%>

<style>
  /* ===== TEMA KONSISTEN ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* Form Card */
  .form-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 700px;
    margin: 0 auto;
    border: 1px solid rgba(33,147,176,0.1);
  }
  .form-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 1.8rem;
    color: white;
  }
  .form-header h3 {
    margin: 0;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .form-body {
    padding: 2.5rem;
    background: white;
  }

  /* Form Elements */
  .form-label {
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.3rem;
  }
  .form-control {
    border-radius: 1rem;
    padding: 0.75rem 1.2rem;
    border: 1px solid #cbd5e1;
    transition: all 0.2s;
  }
  .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.25rem rgba(33,147,176,0.25);
  }

  /* Preview Foto */
  .avatar-preview {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid white;
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    margin-bottom: 1rem;
  }
  .preview-container {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  /* Buttons */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.7rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 5px 15px rgba(33,147,176,0.2);
    border: none;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(33,147,176,0.4);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.7rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }

  /* Keterangan kecil */
  .text-muted {
    color: #64748b;
  }

  /* Responsif */
  @media (max-width: 768px) {
    .form-body {
      padding: 1.5rem;
    }
    .d-flex.justify-content-between {
      flex-direction: column;
      gap: 1rem;
    }
    .btn-gradient, .btn-outline-gradient {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-pencil-square"></i> Edit Biodata</h3>
    </div>
    <div class="form-body">
      <!-- Preview Foto -->
      <% if (fotoPreview) { %>
        <div class="preview-container">
          <img src="<%= fotoPreview %>" alt="foto" class="avatar-preview" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.nama) %>&background=2193b0&color=fff&size=120';">
        </div>
      <% } else if (user.foto) { %>
        <div class="preview-container">
          <img src="<%= user.foto %>" alt="foto" class="avatar-preview">
        </div>
      <% } %>

      <form method="POST" action="/mahasiswa/biodata/edit" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="nama" class="form-label">Nama Lengkap <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="nama" name="nama" value="<%= user.nama || '' %>" required>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
          <input type="email" class="form-control" id="email" name="email" value="<%= user.email || '' %>" required>
        </div>
        <div class="mb-3">
          <label for="noHp" class="form-label">Nomor HP</label>
          <input type="text" class="form-control" id="noHp" name="noHp" value="<%= user.noHp || '' %>">
        </div>
        <div class="mb-3">
          <label for="foto" class="form-label">Foto Profil</label>
          <input type="file" class="form-control" id="foto" name="foto" accept="image/*">
          <small class="text-muted">Kosongkan jika tidak ingin mengubah foto</small>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <a href="/mahasiswa/biodata" class="btn-outline-gradient">
            <i class="bi bi-arrow-left"></i> Kembali
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save"></i> Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>