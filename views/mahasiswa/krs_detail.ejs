<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== DETAIL CARD ===== */
  .detail-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
    background: white;
  }
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 2rem;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .detail-header h2 {
    font-weight: 700;
    font-size: 2rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .detail-header p {
    margin-bottom: 0;
    opacity: 0.9;
    font-size: 1rem;
    position: relative;
    z-index: 1;
  }
  .detail-body {
    padding: 2rem;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid transparent;
    position: relative;
    z-index: 1;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
    border-color: #fde68a;
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
    border-color: #a7f3d0;
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: #fecaca;
  }

  /* ===== INFO TABLE ===== */
  .info-table {
    margin-bottom: 0;
  }
  .info-table th {
    width: 200px;
    font-weight: 600;
    color: #1e293b;
    border: none;
    padding: 0.5rem 0;
  }
  .info-table td {
    border: none;
    padding: 0.5rem 0;
  }

  /* ===== MK TABLE (minimalis) ===== */
  .mk-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .mk-table th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .mk-table td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .mk-table tfoot th {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
  }

  /* ===== TOMBOL ===== */
  .btn-outline-secondary {
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    border-radius: 50px;
    padding: 0.5rem 2rem;
    font-weight: 600;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-outline-secondary:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.2);
  }

  .btn-outline-info {
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-outline-info:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.2);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .detail-header h2 { font-size: 1.8rem; }
    .detail-header { padding: 1.5rem; }
    .detail-body { padding: 1.5rem; }
    .info-table th { width: 150px; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .detail-header h2 { font-size: 1.5rem; }
    .badge-status { font-size: 0.8rem; padding: 0.4rem 1rem; }
    .mk-table th { font-size: 0.8rem; padding: 0.5rem; }
    .mk-table td { font-size: 0.85rem; padding: 0.5rem; }
    .info-table th { width: 120px; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .detail-header h2 { font-size: 1.3rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
    .info-table th { width: 100px; }
  }
</style>

<div class="container mt-4">
  <div class="detail-card">
    <div class="detail-header d-flex flex-wrap justify-content-between align-items-center">
      <div>
        <h2>Detail KRS</h2>
        <p class="mb-0">Semester: <%= krs.semester || '-' %></p>
      </div>
      <span class="badge-status 
        <%= krs.status === 'pending' ? 'badge-pending' : '' %>
        <%= krs.status === 'approved' ? 'badge-approved' : '' %>
        <%= krs.status === 'rejected' ? 'badge-rejected' : '' %>
        mt-2 mt-sm-0">
        <%= krs.status %>
      </span>
    </div>
    <div class="detail-body">
      <h5 class="fw-bold mb-3">Data Mahasiswa</h5>
      <table class="table table-borderless info-table">
        <tr>
          <th>NIM</th>
          <td><%= user.nim || '-' %></td>
        </tr>
        <tr>
          <th>Nama</th>
          <td><%= user.nama || '-' %></td>
        </tr>
        <tr>
          <th>Program Studi</th>
          <td>Teknik Elektronika</td>
        </tr>
      </table>

      <hr>

      <h5 class="fw-bold mb-3">Mata Kuliah yang Direncanakan</h5>
      <div class="table-responsive">
        <table class="table mk-table">
          <thead>
            <tr>
              <th>No</th>
              <th>Kode</th>
              <th>Nama Mata Kuliah</th>
              <th>SKS</th>
            </tr>
          </thead>
          <tbody>
            <% if (mkList && mkList.length > 0) { %>
              <% mkList.forEach((mk, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= mk.kode || '-' %></td>
                <td><%= mk.nama || '-' %></td>
                <td><%= mk.sks || '-' %></td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center">Tidak ada mata kuliah</td>
              </tr>
            <% } %>
          </tbody>
          <tfoot>
            <tr>
              <th colspan="3" class="text-end">Total SKS</th>
              <th>
                <% 
                  let total = 0;
                  if (mkList) mkList.forEach(m => total += (m.sks || 0));
                %>
                <%= total %>
              </th>
            </tr>
          </tfoot>
        </table>
      </div>

      <hr>

      <h5 class="fw-bold mb-3">File KRS</h5>
      <% if (krs.driveFileLink) { %>
        <a href="<%= krs.driveFileLink %>" target="_blank" class="btn-outline-info">
          <i class="bi bi-file-earmark-pdf"></i> Lihat File KRS
        </a>
      <% } else { %>
        <p class="text-muted">Belum ada file yang diupload.</p>
      <% } %>

      <div class="mt-4 d-flex gap-3">
        <a href="/mahasiswa/akademik/krs" class="btn-outline-secondary">
          <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
        
       <a href="/mahasiswa/akademik/krs/krs_print/<%= krs.id %>" target="_blank" class="btn-outline-info">
  <i class="bi bi-printer-fill me-2"></i> Cetak KRS
</a>

        </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>