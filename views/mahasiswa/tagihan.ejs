<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }

  /* ===== SUMMARY CARD ===== */
  .summary-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-bottom: 2rem;
    border: 1px solid rgba(33,147,176,0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .summary-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 35px rgba(33,147,176,0.15);
  }
  .summary-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    background: var(--primary-light);
    color: var(--primary-start);
    margin-bottom: 1rem;
  }
  .summary-label {
    color: #64748b;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .summary-value {
    font-weight: 700;
    font-size: 1.8rem;
    color: #1e293b;
    line-height: 1.2;
  }
  .summary-value.text-success {
    color: #10b981 !important;
  }
  .summary-value.text-danger {
    color: #ef4444 !important;
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(33,147,176,0.1);
    transition: box-shadow 0.3s;
  }
  .table-container:hover {
    box-shadow: 0 20px 35px rgba(33,147,176,0.15);
  }
  .table-tagihan {
    margin-bottom: 0;
  }
  .table-tagihan thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1.2rem 1rem;
  }
  .table-tagihan tbody td {
    vertical-align: middle;
    padding: 1rem;
    background-color: white;
    border-bottom: 1px solid #e9ecef;
  }
  .table-tagihan tbody tr {
    transition: background 0.2s;
  }
  .table-tagihan tbody tr:hover {
    background-color: var(--primary-light);
  }
  .table-tagihan tbody tr:last-child td {
    border-bottom: none;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-lunas {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-belum {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 0;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="page-header">
    <h2><i class="bi bi-cash-coin me-2"></i>Tagihan SPP</h2>
    <p class="mb-0 opacity-75">Riwayat tagihan SPP per semester</p>
  </div>

  <!-- Ringkasan Tagihan -->
  <div class="summary-card">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="summary-icon">
          <i class="bi bi-hourglass-split"></i>
        </div>
        <div class="summary-label">Total Tagihan (Belum Lunas)</div>
        <div class="summary-value">
          Rp <%= new Intl.NumberFormat('id-ID').format(totalTagihan) %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-icon">
          <i class="bi bi-check-circle-fill" style="color: #10b981;"></i>
        </div>
        <div class="summary-label">Sudah Dibayar</div>
        <div class="summary-value text-success">
          Rp <%= new Intl.NumberFormat('id-ID').format(totalLunas) %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-icon">
          <i class="bi bi-exclamation-triangle-fill" style="color: #ef4444;"></i>
        </div>
        <div class="summary-label">Sisa Tagihan</div>
        <div class="summary-value text-danger">
          Rp <%= new Intl.NumberFormat('id-ID').format(sisaTagihan) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabel Tagihan -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table table-tagihan">
        <thead>
          <tr>
            <th>Semester</th>
            <th>Jumlah</th>
            <th>Jatuh Tempo</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (tagihan.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Tidak Ada Tagihan</h4>
                  <p class="text-muted">Tidak ada tagihan SPP yang perlu dibayar saat ini.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% tagihan.forEach(t => { %>
              <tr>
                <td><strong><%= t.semester %></strong></td>
                <td>Rp <%= new Intl.NumberFormat('id-ID').format(t.jumlah) %></td>
                <td>
                  <%= t.jatuhTempo ? new Date(t.jatuhTempo).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) : '-' %>
                </td>
                <td>
                  <% if (t.status === 'lunas') { %>
                    <span class="badge-status badge-lunas"><i class="bi bi-check-circle"></i> Lunas</span>
                  <% } else { %>
                    <span class="badge-status badge-belum"><i class="bi bi-hourglass-split"></i> Belum Lunas</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>