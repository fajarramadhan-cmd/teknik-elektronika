<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
  }
  .rating-star {
    font-size: 2rem;
    cursor: pointer;
    color: #cbd5e1;
    transition: 0.2s;
    margin-right: 0.2rem;
  }
  .rating-star.active {
    color: #fbbf24;
  }
  .rating-star:hover {
    transform: scale(1.1);
  }
  .question-card {
    border-left: 4px solid var(--primary-start);
    transition: 0.2s;
  }
  .question-card:hover {
    background: #f8fafc;
  }
</style>

<div class="container mt-4">
  <div class="card shadow-lg border-0 rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4">
      <h4 class="mb-0"><i class="bi bi-star-fill me-2"></i> Evaluasi: <%= mk.kode %> - <%= mk.nama %></h4>
      <small><i class="bi bi-calendar-week me-1"></i> Periode: <%= activePeriod.nama %></small>
    </div>
    <div class="card-body p-4">
      <form method="POST">
        <% questions.forEach((q, idx) => { %>
          <div class="question-card border rounded-3 p-3 mb-3 bg-white">
            <div class="fw-bold"><%= idx+1 %>. <%= q.pertanyaan %></div>
            <div class="mt-2">
              <div class="rating-input" data-qid="<%= q.id %>">
                <input type="hidden" name="nilai_<%= q.id %>" id="nilai_<%= q.id %>" required>
                <% for (let i = 1; i <= 5; i++) { %>
                  <i class="bi bi-star rating-star" data-value="<%= i %>"></i>
                <% } %>
              </div>
            </div>
            <div class="mt-2">
              <textarea name="komentar_<%= q.id %>" class="form-control" rows="2" placeholder="Komentar (opsional)"></textarea>
            </div>
          </div>
        <% }) %>
        <div class="d-flex justify-content-end mt-4 gap-2">
          <a href="/mahasiswa/edom" class="btn btn-outline-secondary rounded-pill px-4">Batal</a>
          <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-send me-2"></i> Kirim Evaluasi</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.rating-input').forEach(container => {
    const stars = container.querySelectorAll('.rating-star');
    const inputHidden = container.querySelector('input[type="hidden"]');
    
    stars.forEach(star => {
      star.addEventListener('click', () => {
        const value = parseInt(star.getAttribute('data-value'));
        inputHidden.value = value;
        stars.forEach(s => s.classList.remove('active'));
        for (let i = 0; i < value; i++) {
          stars[i].classList.add('active');
        }
      });
    });
  });
</script>

<%- include('../../partials/footer') %>