<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== PROFILE CARD ===== */
  .profile-card {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem;
    color: white;
    margin-bottom: 1.5rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.3);
    position: relative;
    overflow: hidden;
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .profile-card h2 {
    font-size: 1.8rem;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }
  .profile-card p {
    font-size: 0.95rem;
    position: relative;
    z-index: 1;
  }
  .profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    transition: transform 0.3s;
  }
  .profile-avatar:hover {
    transform: scale(1.05);
  }

  /* ===== STATISTIK CARDS ===== */
  .stat-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.2rem 1rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.03);
    transition: all 0.3s;
    height: 100%;
    border: 1px solid rgba(33,147,176,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .stat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(33,147,176,0.15);
    border-color: transparent;
  }
  .stat-icon {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
    transition: all 0.3s;
  }
  .stat-card:hover .stat-icon {
    transform: scale(1.1);
  }
  .stat-value {
    font-size: 1.7rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
  }
  .stat-label {
    color: #64748b;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ===== TAGIHAN CARD ===== */
  .tagihan-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid rgba(33,147,176,0.1);
  }
  .tagihan-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 1rem 1.5rem;
  }
  .tagihan-header h5 {
    font-size: 1.1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tagihan-header .btn-light {
    border-radius: 50px;
    padding: 0.3rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 500;
    background: rgba(255,255,255,0.9);
    border: none;
    transition: all 0.3s;
  }
  .tagihan-header .btn-light:hover {
    background: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }
  .tagihan-item {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e9ecef;
    transition: background 0.2s;
  }
  .tagihan-item:hover {
    background: #f8f9fa;
  }
  .tagihan-item:last-child {
    border-bottom: none;
  }
  .badge-tagihan {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
  }
  .badge-lunas {
    background: #d4edda;
    color: #155724;
  }
  .badge-belum {
    background: #fff3cd;
    color: #856404;
  }

  /* ===== MENU CARDS ===== */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.2rem;
    margin-top: 1rem;
  }
  .menu-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem 1rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid rgba(33,147,176,0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    display: block;
    height: 100%;
  }
  .menu-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px rgba(33,147,176,0.15);
    border-color: transparent;
  }
  .menu-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    margin: 0 auto 1rem;
    transition: all 0.3s;
  }
  .menu-card:hover .menu-icon {
    transform: scale(1.1);
  }
  .menu-title {
    font-weight: 700;
    color: #1e293b;
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }
  .menu-desc {
    color: #64748b;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  /* ===== UTILITY ===== */
  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1.5rem 0 1rem;
    position: relative;
    padding-left: 1rem;
  }
  .section-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2rem;
    bottom: 0.2rem;
    width: 5px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 5px;
  }
</style>

<%
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<div class="container-fluid mt-4">
  <!-- Notifikasi Upload Sukses -->
  <% if (uploadSuccess) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>File KRS berhasil diupload ke Google Drive!
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Profile Card dengan Foto -->
  <div class="profile-card">
    <div class="d-flex align-items-center flex-wrap">
      <div class="flex-shrink-0">
        <% if (user.foto) { 
          const fileId = getFileIdFromUrl(user.foto);
        %>
          <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w200" 
               alt="foto profil" 
               class="profile-avatar"
               onerror="this.onerror=null; this.src='<%= user.foto %>'; this.onerror=null;">
        <% } else { %>
          <div class="profile-avatar bg-white d-flex align-items-center justify-content-center">
            <i class="bi bi-person-circle text-primary fs-1"></i>
          </div>
        <% } %>
      </div>
      <div class="flex-grow-1 ms-3 mt-2 mt-sm-0">
        <h2 class="fw-bold mb-1">Selamat Datang, <%= user.nama || user.email %>!</h2>
        <p class="mb-0 opacity-75">
          <i class="bi bi-qr-code me-2"></i>NIM: <%= user.nim || '-' %> 
          <span class="mx-3">|</span>
          <i class="bi bi-envelope me-2"></i><%= user.email %>
        </p>
      </div>
    </div>
  </div>

  <!-- Statistik Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(13,110,253,0.1); color: #0d6efd;">
          <i class="bi bi-book"></i>
        </div>
        <div class="stat-value"><%= totalSks || 0 %></div>
        <div class="stat-label">SKS Diambil</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(25,135,84,0.1); color: #198754;">
          <i class="bi bi-calendar-week"></i>
        </div>
        <div class="stat-value"><%= semesterSekarang || 'Genap 2025/2026' %></div>
        <div class="stat-label">Semester Aktif</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(13,202,240,0.1); color: #0dcaf0;">
          <i class="bi bi-bar-chart-steps"></i>
        </div>
        <div class="stat-value"><%= pertemuanRata || 0 %> / 16</div>
        <div class="stat-label">Pertemuan Terkini</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255,193,7,0.1); color: #ffc107;">
          <i class="bi bi-file-earmark-text"></i>
        </div>
        <div class="stat-value"><%= tugasAktif ? tugasAktif.length : 0 %></div>
        <div class="stat-label">Tugas Aktif</div>
      </div>
    </div>
  </div>

  <!-- Tagihan SPP -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="tagihan-card">
        <div class="tagihan-header d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0"><i class="bi bi-cash-coin"></i> Tagihan SPP</h5>
          <a href="/mahasiswa/tagihan" class="btn btn-light btn-sm">Lihat Semua</a>
        </div>
        <div class="card-body p-0">
          <% if (tagihan.length === 0) { %>
            <div class="p-4 text-center text-muted">
              <i class="bi bi-check-circle-fill fs-1 text-success d-block mb-2"></i>
              <p class="mb-0">Tidak ada tagihan aktif.</p>
            </div>
          <% } else { %>
            <% tagihan.slice(0, 3).forEach(t => { %>
              <div class="tagihan-item d-flex flex-wrap justify-content-between align-items-center">
                <div>
                  <strong class="fs-6"><%= t.semester %></strong>
                  <p class="mb-0 text-muted small">
                    <i class="bi bi-calendar3 me-1"></i>Jatuh tempo: <%= t.jatuhTempo ? new Date(t.jatuhTempo).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) : '-' %>
                  </p>
                </div>
                <div class="text-end mt-2 mt-sm-0">
                  <span class="fw-bold fs-5">Rp <%= new Intl.NumberFormat('id-ID').format(t.jumlah) %></span><br>
                  <span class="badge-tagihan <%= t.status === 'lunas' ? 'badge-lunas' : 'badge-belum' %>">
                    <%= t.status === 'lunas' ? 'Lunas' : 'Belum Lunas' %>
                  </span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Menu Akses Cepat -->
  <h4 class="section-title">Layanan Mahasiswa</h4>
  <div class="menu-grid">
    <!-- Akademik -->
    <a href="/mahasiswa/akademik" class="menu-card">
      <div class="menu-icon" style="background: rgba(13,110,253,0.1); color: #0d6efd;">
        <i class="bi bi-journal-bookmark-fill"></i>
      </div>
      <h6 class="menu-title">Akademik</h6>
      <p class="menu-desc">KRS, KHS, Transkrip, Kalender Akademik</p>
    </a>

    <!-- ELK-Learning -->
    <a href="/mahasiswa/elearning" class="menu-card">
      <div class="menu-icon" style="background: rgba(25,135,84,0.1); color: #198754;">
        <i class="bi bi-laptop"></i>
      </div>
      <h6 class="menu-title">ELK-Learning</h6>
      <p class="menu-desc">Jadwal kuliah, tugas, kumpul tugas online</p>
    </a>

    <!-- ELK-Magang -->
    <a href="/mahasiswa/magang" class="menu-card">
      <div class="menu-icon" style="background: rgba(255,193,7,0.1); color: #ffc107;">
        <i class="bi bi-briefcase"></i>
      </div>
      <h6 class="menu-title">ELK-Magang</h6>
      <p class="menu-desc">Logbook, upload nilai, permohonan seminar</p>
    </a>

    <!-- Persuratan -->
    <a href="/mahasiswa/persuratan" class="menu-card">
      <div class="menu-icon" style="background: rgba(13,202,240,0.1); color: #0dcaf0;">
        <i class="bi bi-envelope-paper"></i>
      </div>
      <h6 class="menu-title">Persuratan</h6>
      <p class="menu-desc">Surat aktif kuliah, rekomendasi, dll.</p>
    </a>

    <!-- Tracer Study -->
    <a href="/mahasiswa/tracer" class="menu-card">
      <div class="menu-icon" style="background: rgba(220,53,69,0.1); color: #dc3545;">
        <i class="bi bi-bar-chart-line"></i>
      </div>
      <h6 class="menu-title">Tracer Study</h6>
      <p class="menu-desc">Isi survei keberkerjaan alumni</p>
    </a>

    <!-- Biodata -->
    <a href="/mahasiswa/biodata" class="menu-card">
      <div class="menu-icon" style="background: rgba(108,117,125,0.1); color: #6c757d;">
        <i class="bi bi-person-circle"></i>
      </div>
      <h6 class="menu-title">Biodata</h6>
      <p class="menu-desc">Profil, foto, ubah password</p>
    </a>
  </div>

  <!-- Footer kecil -->
  <div class="text-center text-muted mt-5 mb-3">
    <small><i class="bi bi-shield-check me-1"></i> Sistem Informasi Mahasiswa Elektronika- Politeknik Dewantara 2025 by Fajar Elektrik</small>
  </div>
</div>

<%- include('../partials/footer') %>