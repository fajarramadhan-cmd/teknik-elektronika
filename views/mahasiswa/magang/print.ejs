<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cetak Logbook - <%= mahasiswa.nama %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
  <style>
    /* Pengaturan Kertas Default */
    @page {
      size: A4;
      margin: 1.5cm;
    }

    /* Gaya Umum Dokumen Formal */
    body {
      font-family: 'Times New Roman', Times, serif;
      color: #000;
      background-color: #fff;
      font-size: 10pt; /* Ukuran dasar diperkecil */
    }

    .print-btn {
      margin: 20px 0;
      font-family: Arial, sans-serif;
    }

    /* === KOP SURAT FORMAL (Rata Kiri) === */
    .kop-surat {
      display: flex;
      align-items: center;
      position: relative;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 3px solid #000;
    }
    .kop-surat::after {
      content: "";
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 100%;
      border-bottom: 1px solid #000;
    }
    .logo-kop {
      width: 90px; /* Logo sedikit diperkecil */
      height: auto;
      margin-right: 20px;
    }
    .teks-kop {
      flex: 1;
      text-align: left;
    }
    .teks-kop .nama-kampus {
      font-family: Arial, sans-serif;
      font-size: 24pt; /* Diperkecil dari 24pt */
      font-weight: bold;
      margin: 0;
      color: #035a94;
      letter-spacing: 1px;
    }
    .teks-kop .prodi {
      font-size: 13pt; /* Diperkecil dari 16pt */
      font-weight: bold;
      font-weight: bold;
      margin: 3px 0;
      color: #000;
      text-transform: uppercase;
    }
    .teks-kop .alamat {
      font-size: 10pt; /* Diperkecil */
      margin: 0;
      color: #000;
    }

    /* === INFORMASI MAHASISWA & MAGANG (Dalam Kotak) === */
    .judul-dokumen {
      text-align: center;
      margin-bottom: 15px;
    }
    .judul-dokumen h4 {
      font-size: 14pt; /* Ukuran judul diperkecil */
      font-weight: bold;
      text-decoration: underline;
      margin-bottom: 0;
    }

    .info-box {
      border: 1px solid #000;
      padding: 10px 15px;
      margin-bottom: 20px;
      background-color: #fff;
    }
    .info-table {
      width: 100%;
      font-size: 10pt; /* Diperkecil dari 11pt */
    }
    .info-table td {
      padding: 3px 5px;
      vertical-align: top;
      border: none;
    }
    .info-table td:first-child {
      font-weight: bold;
    }

    /* === TABEL LOGBOOK === */
    .table {
      font-size: 10pt; /* Diperkecil dari 11pt */
      border-color: #000;
      margin-bottom: 10px;
    }
    .table-bordered th, 
    .table-bordered td {
      border: 1px solid #000;
      vertical-align: middle;
      padding: 6px; /* Padding dikurangi agar baris lebih rapat */
    }
    .table thead th {
      background-color: #e9ecef;
      text-align: center;
      vertical-align: middle;
      font-weight: bold;
    }
    
    tr {
      page-break-inside: avoid;
    }
    thead {
      display: table-header-group;
    }

    /* === GALERI & THUMBNAIL === */
    .thumbnail {
      width: 80px; /* Diperkecil dari 100px */
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
      margin: 2px;
      border: 1px solid #999;
    }
    .gallery {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* === TANDA TANGAN (3 Kolom) === */
    .tanda-tangan-container {
      page-break-inside: avoid;
      margin-top: 30px;
      width: 100%;
      font-size: 9pt; /* Ukuran font TTD */
    }
    .tiga-kolom {
      display: flex;
      justify-content: space-between;
      text-align: left;
      margin-bottom: 20px;
    }
    .kolom-tanda {
      width: 32%;
    }
    .area-ttd {
      height: 70px; /* Diperkecil ruang ttd-nya */
    }
    .kaprodi {
      text-align: center;
      margin-top: 20px;
    }
    .nama-ttd {
      font-weight: bold;
      text-decoration: underline;
      margin-bottom: 0;
    }
    .nip-ttd {
      margin-top: 0;
    }

    /* === PENGATURAN CETAK (PRINT) === */
    @media print {
      body {
        margin: 0;
      }
      .btn, .print-btn { 
        display: none !important; 
      }
      .table thead th {
        background-color: #e9ecef !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .thumbnail {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>
  <div class="container-fluid px-4 py-3">
    <div class="text-end">
      <button onclick="window.print()" class="btn btn-primary btn-sm print-btn shadow-sm">
        <i class="bi bi-printer-fill"></i> Cetak Dokumen / PDF
      </button>
    </div>

    <div class="kop-surat">
      <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" 
           alt="Logo Politeknik Dewantara" class="logo-kop">
      <div class="teks-kop">
        <h2 class="nama-kampus">POLITEKNIK DEWANTARA</h2>
        <h3 class="prodi">PROGRAM STUDI TEKNIK ELEKTRONIKA</h3>
        <p class="alamat">Jl. KH Ahmad Razak 2, No. 7, Kota Palopo, Sulawesi Selatan</p>
      </div>
    </div>

    <div class="judul-dokumen">
      <h4>LOGBOOK  MAGANG</h4>
    </div>
    
    <div class="info-box">
      <table class="info-table">
        <tr>
          <td width="20%">Nama Mahasiswa</td>
          <td width="2%">:</td>
          <td width="78%"><%= mahasiswa.nama %></td>
        </tr>
        <tr>
          <td>NIM</td>
          <td>:</td>
          <td><%= mahasiswa.nim %></td>
        </tr>
        <% if (pdkInfo && pdkInfo.perusahaan && pdkInfo.perusahaan.nama) { %>
        <tr>
          <td>Perusahaan </td>
          <td>:</td>
          <td><%= pdkInfo.perusahaan.nama %></td>
        </tr>
        <% } else { %>
        <tr>
          <td>Perusahaan </td>
          <td>:</td>
          <td>-</td>
        </tr>
        <% } %>
        
        <% if (pdkInfo && pdkInfo.tanggalMulai) { %>
        <tr>
          <td>Periode Magang</td>
          <td>:</td>
          <td><%= pdkInfo.tanggalMulai %> s/d <%= pdkInfo.tanggalSelesai || 'Berlangsung' %></td>
        </tr>
        <% } else { %>
        <tr>
          <td>Periode Magang</td>
          <td>:</td>
          <td>-</td>
        </tr>
        <% } %>
      </table>
    </div>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th width="5%">No</th>
          <th width="12%">Tanggal</th>
          <th width="28%">Kegiatan</th>
          <th width="15%">Lokasi</th>
          <th width="10%">Durasi<br>(Jam)</th>
          <th width="30%">Dokumentasi</th>
        </tr>
      </thead>
      <tbody>
        <% if (logbook.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-4 fst-italic">Belum ada entri logbook.</td>
          </tr>
        <% } %>
        <% logbook.forEach((item, index) => { %>
          <tr>
            <td class="text-center"><%= index + 1 %></td>
            <td class="text-center"><%= new Date(item.tanggal).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %></td>
            <td class="text-justify"><%= item.kegiatan %></td>
            <td class="text-center"><%= item.lokasi || '-' %></td>
            <td class="text-center fw-bold"><%= item.durasi || '-' %></td>
            <td class="text-center">
              <% if (item.imageUrls && item.imageUrls.length > 0) { %>
                <div class="gallery">
                  <% item.imageUrls.forEach(url => { 
                    let fileId = '';
                    if (url.includes('id=')) {
                      fileId = url.split('id=')[1].split('&')[0];
                    } else if (url.includes('/d/')) {
                      fileId = url.split('/d/')[1].split('/')[0];
                    } else {
                      fileId = url.split('/').pop();
                    }
                  %>
                    <a href="<%= url %>" target="_blank">
                      <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w600" 
                           class="thumbnail" alt="dokumentasi"
                           onerror="this.onerror=null; this.src='https://drive.google.com/uc?export=view&id=<%= fileId %>';">
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <span class="text-muted fst-italic">Tidak ada foto</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="bg-light fw-bold">
          <td colspan="4" class="text-end pe-3">Total Jam Kegiatan:</td>
          <td class="text-center"><%= totalDurasi.toFixed(1) %></td>
          <td class="text-center"><%= totalEntries %> Entri</td>
        </tr>
      </tfoot>
    </table>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <small class="text-muted fst-italic">Logbook ini dicetak di Web Portal Elektronika Polidewa: <%= generatedAt %></small>
    </div>

    <div class="tanda-tangan-container">
      <div class="tiga-kolom">
        
        <div class="kolom-tanda">
          <p class="mb-0">Mengetahui,</p>
          <p>Dosen Pembimbing 1</p>
          <div class="area-ttd"></div>
          <% if (pembimbing && pembimbing.pembimbing1) { %>
            <p class="nama-ttd"><%= pembimbing.pembimbing1.nama %></p>
            <p class="nip-ttd">NUPTK/NIDN.</p>
          <% } else { %>
            <p class="nama-ttd">( ____________________ )</p>
            <p class="nip-ttd">NIP/NIDN.</p>
          <% } %>
        </div>

        <div class="kolom-tanda">
          <p class="mb-0"><br></p>
          <p>Dosen Pembimbing 2</p>
          <div class="area-ttd"></div>
          <% if (pembimbing && pembimbing.pembimbing2) { %>
            <p class="nama-ttd"><%= pembimbing.pembimbing2.nama %></p>
            <p class="nip-ttd">NUPTK/NIDN. </p>
          <% } else { %>
            <p class="nama-ttd">( ____________________ )</p>
            <p class="nip-ttd">NUPTK/NIDN.</p>
          <% } %>
        </div>

        <div class="kolom-tanda">
          <p class="mb-0">Palopo, <%= new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
          <p>Pendamping Lapangan</p>
          <div class="area-ttd"></div>
          <p class="nama-ttd">( ____________________ )</p>
        </div>

      </div>

      <div class="kaprodi">
        <p class="mb-0">Mengesahkan,</p>
        <p>Ketua Program Studi Teknik Elektronika</p>
        <div class="area-ttd"></div>
        <p class="nama-ttd">Fajar Ramadhan, S.Pd., M.T</p>
        <p class="nip-ttd">NUPTK. 8559777678130153</p>
      </div>
    </div>

  </div>
</body>
</html>