<%- include('../../partials/header') %>

<style>
  .laporan-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 10px 30px rgba(33,147,176,0.2);
  }
  .card-laporan {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    transition: all 0.3s;
    overflow: hidden;
  }
  .card-laporan:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(33,147,176,0.15);
  }
  .card-header-laporan {
    background: linear-gradient(135deg, rgba(33,147,176,0.05), rgba(109,213,237,0.05));
    border-bottom: 1px solid rgba(33,147,176,0.1);
    padding: 1rem 1.25rem;
    font-weight: 600;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }
  .file-info {
    background-color: #f8f9fa;
    border-left: 4px solid #2193b0;
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    transition: all 0.2s;
  }
  .file-info:hover {
    background-color: #eef2f7;
  }
  .file-link {
    display: inline-block;
    max-width: 200px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: middle;
    color: #2193b0;
    font-weight: 500;
    text-decoration: none;
  }
  .file-link:hover {
    text-decoration: underline;
    color: #125d74;
  }
  .file-size {
    font-size: 0.75rem;
    color: #6c757d;
    margin-left: 2rem;
  }
  .badge-status {
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-weight: 500;
  }
  .rejection-reason {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    border-radius: 0.75rem;
    padding: 0.75rem;
    color: #721c24;
    font-size: 0.9rem;
    margin-top: 1rem;
  }
  .empty-state {
    background-color: #f8f9fa;
    border-radius: 1rem;
    padding: 2rem 1rem;
    text-align: center;
    color: #6c757d;
  }
  .form-upload {
    margin-top: 1rem;
  }
  .form-control-file {
    border: 2px dashed #ced4da;
    border-radius: 0.75rem;
    padding: 0.75rem;
    transition: all 0.2s;
    background-color: #f8f9fa;
  }
  .form-control-file:hover {
    border-color: #2193b0;
    background-color: #eef2f7;
  }
  .form-control-file:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="laporan-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2 class="fw-bold mb-2"><i class="bi bi-file-earmark-pdf me-2"></i>Laporan Magang</h2>
      <p class="mb-0 opacity-75">Unggah laporan magang 1, 2, dan 3 sesuai ketentuan</p>
    </div>
    <a href="/mahasiswa/magang" class="btn btn-light rounded-pill px-4 py-2 mt-3 mt-sm-0">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Info petunjuk -->
  <div class="alert alert-info d-flex align-items-center mb-4" role="alert" style="border-left: 4px solid #2193b0; border-radius: 0.75rem;">
    <i class="bi bi-info-circle-fill fs-4 me-3"></i>
    <div>
      <strong>Petunjuk:</strong> Unggah file PDF maksimal 10MB. Setelah diunggah, laporan akan diperiksa oleh pembimbing. Status akan diperbarui secara otomatis.
    </div>
  </div>

  <!-- Kartu Laporan -->
  <div class="row g-4">
    <% for (let i = 1; i <= 3; i++) { 
      const item = laporanList[i-1];
      const status = item.exists ? item.data.status : null;
      const isApproved = status === 'approved';
      const isRejected = status === 'rejected';
      const isSubmitted = status === 'submitted';
    %>
      <div class="col-md-4">
        <div class="card card-laporan h-100">
          <div class="card-header-laporan d-flex justify-content-between align-items-center">
            <span><i class="bi bi-file-text me-2"></i>Laporan Magang <%= i %></span>
            <% if (item.exists) { %>
              <span class="badge bg-<%= isApproved ? 'success' : (isRejected ? 'danger' : 'warning') %> badge-status">
                <%= isApproved ? 'Disetujui' : (isRejected ? 'Ditolak' : 'Menunggu') %>
              </span>
            <% } else { %>
              <span class="badge bg-secondary badge-status">Belum Upload</span>
            <% } %>
          </div>
          <div class="card-body d-flex flex-column">
            <% if (item.exists) { %>
              <!-- Info file -->
              <div class="file-info">
                <div class="d-flex align-items-center">
                  <i class="bi bi-file-pdf text-danger fs-4 me-3"></i>
                  <div class="flex-grow-1" style="min-width: 0;">
                    <a href="<%= item.data.fileUrl %>" target="_blank" class="file-link" title="<%= item.data.fileName %>">
                      <%= item.data.fileName %>
                    </a>
                    <% if (item.data.fileSize) { %>
                      <div class="file-size">
                        <i class="bi bi-database me-1"></i><%= (item.data.fileSize / 1024 / 1024).toFixed(2) %> MB
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- Tanggal upload -->
              <p class="mb-2 text-muted small">
                <i class="bi bi-calendar3 me-1"></i>Diunggah: <%= new Date(item.data.uploadedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
              </p>

              <!-- Alasan penolakan jika ada -->
              <% if (isRejected && item.data.rejectionReason) { %>
                <div class="rejection-reason">
                  <i class="bi bi-exclamation-triangle-fill me-2"></i>
                  <strong>Alasan ditolak:</strong> <%= item.data.rejectionReason %>
                </div>
              <% } %>

              <!-- Tombol aksi berdasarkan status -->
              <div class="mt-auto pt-3">
                <% if (isApproved) { %>
                  <a href="<%= item.data.fileUrl %>" target="_blank" class="btn btn-outline-gradient w-100">
                    <i class="bi bi-eye me-2"></i>Lihat Laporan
                  </a>
                <% } else if (isRejected) { %>
                  <button class="btn btn-gradient w-100" type="button" data-bs-toggle="collapse" data-bs-target="#uploadForm<%= i %>" aria-expanded="false" aria-controls="uploadForm<%= i %>">
                    <i class="bi bi-arrow-repeat me-2"></i>Upload Ulang
                  </button>
                  <div class="collapse mt-3" id="uploadForm<%= i %>">
                    <form method="POST" action="/mahasiswa/magang/laporan/upload" enctype="multipart/form-data">
                      <input type="hidden" name="laporanKe" value="<%= i %>">
                      <div class="mb-2">
                        <input type="file" class="form-control form-control-file" name="file" accept=".pdf" required>
                      </div>
                      <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-cloud-upload me-2"></i>Unggah
                      </button>
                    </form>
                  </div>
                <% } else if (isSubmitted) { %>
                  <button class="btn btn-secondary w-100" disabled>
                    <i class="bi bi-hourglass-split me-2"></i>Menunggu Verifikasi
                  </button>
                <% } %>
              </div>
            <% } else { %>
              <!-- Belum ada laporan: tampilkan form upload -->
              <div class="empty-state flex-grow-1 d-flex flex-column justify-content-center">
                <i class="bi bi-cloud-upload fs-1 mb-3"></i>
                <p class="mb-3">Belum ada laporan diunggah</p>
                <form method="POST" action="/mahasiswa/magang/laporan/upload" enctype="multipart/form-data">
                  <input type="hidden" name="laporanKe" value="<%= i %>">
                  <div class="mb-3">
                    <input type="file" class="form-control form-control-file" name="file" accept=".pdf" required>
                  </div>
                  <button type="submit" class="btn btn-gradient w-100">
                    <i class="bi bi-cloud-upload me-2"></i>Upload Laporan
                  </button>
                </form>
              </div>
            <% } %>
          </div>
          <!-- Footer card untuk info tambahan -->
          <div class="card-footer bg-transparent border-0 pt-0 pb-3 text-center">
            <small class="text-muted">Format PDF, maks. 10MB</small>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Catatan tambahan -->
  <div class="mt-5 text-center text-muted">
    <p class="small">
      <i class="bi bi-shield-check me-1"></i> Pastikan laporan sudah sesuai dengan panduan sebelum mengunggah.
    </p>
  </div>
</div>

<!-- Tambahkan Bootstrap JS jika diperlukan untuk collapse (jika belum ada) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<%- include('../../partials/footer') %>