<%- include('../../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive (mungkin diperlukan untuk foto nanti)
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }
  .page-header .btn-light {
    border-radius: 50px;
    padding: 0.6rem 1.5rem;
    font-weight: 500;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
  }
  .page-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .seminar-table {
    margin-bottom: 0;
  }
  .seminar-table thead th {
    background: linear-gradient(135deg, var(--primary-light), rgba(109,213,237,0.1));
    color: var(--primary-dark);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--primary-start);
    padding: 1rem 0.75rem;
    white-space: nowrap;
  }
  .seminar-table tbody tr {
    transition: all 0.2s;
  }
  .seminar-table tbody tr:hover {
    background-color: var(--primary-light);
    transform: scale(1.01);
    box-shadow: 0 5px 15px rgba(33,147,176,0.1);
  }
  .seminar-table td {
    padding: 1rem 0.75rem;
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }
  .badge-approved {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-rejected {
    background: #f8d7da;
    color: #721c24;
    border-color: #f5c6cb;
  }
  .badge-cancelled {
    background: #e2e3e5;
    color: #383d41;
    border-color: #d6d8db;
  }

  /* ===== TOMBOL AKSI ===== */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
    margin: 0 2px;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-detail {
    background: var(--primary-start);
  }
  .btn-detail:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }
  .btn-cancel {
    background: #dc3545;
  }
  .btn-cancel:hover {
    background: #c82333;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(220,53,69,0.3);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 1.5rem;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header dengan gradien -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-calendar-event-fill me-2"></i>Permohonan Seminar Magang</h2>
      <p class="mb-0">Ajukan jadwal seminar dan lihat status permohonan</p>
    </div>
    <a href="/mahasiswa/magang/seminar/baru" class="btn-light btn" style="background:white; border-radius:50px; padding:0.6rem 1.5rem; font-weight:500; text-decoration:none;">
      <i class="bi bi-plus-circle me-2" style="color:var(--primary-start);"></i>Ajukan Baru
    </a>
  </div>

  <!-- Tabel Permohonan -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table seminar-table">
        <thead>
          <tr>
            <th>Judul</th>
            <th>Tanggal</th>
            <th>Waktu</th>
            <th>Tempat</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (permohonan.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Belum Ada Permohonan</h4>
                  <p class="text-muted">Ajukan seminar magang pertama Anda dengan klik tombol "Ajukan Baru".</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% permohonan.forEach(p => { %>
              <tr>
                <td><strong><%= p.judul %></strong></td>
                <td><%= new Date(p.tanggal).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %></td>
                <td><%= p.waktu || '-' %></td>
                <td><%= p.tempat %></td>
                <td>
                  <% if (p.status === 'pending') { %>
                    <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                  <% } else if (p.status === 'approved') { %>
                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                  <% } else if (p.status === 'rejected') { %>
                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                  <% } else if (p.status === 'dibatalkan') { %>
                    <span class="badge-status badge-cancelled"><i class="bi bi-x-octagon"></i> Dibatalkan</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/mahasiswa/magang/seminar/<%= p.id %>" class="btn-icon-sm btn-detail" title="Detail">
                      <i class="bi bi-eye"></i>
                    </a>
                    <% if (p.status === 'pending') { %>
                      <form method="POST" action="/mahasiswa/magang/seminar/<%= p.id %>/batal" style="display:inline;" onsubmit="return confirm('Batalkan pengajuan ini?')">
                        <button class="btn-icon-sm btn-cancel" title="Batalkan">
                          <i class="bi bi-x-lg"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>