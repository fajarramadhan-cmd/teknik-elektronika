<%- include('../partials/header-landing') %>

<style>
  /* ===== VARIABEL & BASE ===== */
  :root {
    --primary-blue: #1e3a8a;
    --accent-blue: #3b82f6;
    --soft-bg: #f8fafc;
    --text-slate: #1e293b;
    --text-muted: #64748b;
  }

  body {
    background-color: var(--soft-bg);
    color: var(--text-slate);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  /* ===== BREADCRUMB ===== */
  .breadcrumb-nav {
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  /* ===== HEADER AREA ===== */
  .detail-hero {
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    color: white;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 25px -5px rgba(30, 58, 138, 0.2);
  }

  .detail-hero h1 {
    font-weight: 800;
    font-size: 2.25rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    max-width: 900px;
  }

  .meta-badge-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .meta-badge {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(5px);
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* ===== CONTENT CARDS ===== */
  .main-card {
    background: white;
    border-radius: 1.25rem;
    padding: 2.5rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .section-title {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--primary-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #e2e8f0;
  }

  .abstract-text {
    line-height: 1.8;
    color: #334155;
    font-size: 1.05rem;
    text-align: justify;
  }

  /* ===== SIDEBAR AREA ===== */
  .sidebar-card {
    background: white;
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
    margin-bottom: 1.5rem;
  }

  .keyword-pill {
    display: inline-block;
    background: #eff6ff;
    color: #1e40af;
    padding: 0.35rem 0.85rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0.25rem;
    border: 1px solid #dbeafe;
  }

  /* ===== ACTION BUTTONS ===== */
  .btn-download-full {
    background: #10b981;
    color: white;
    width: 100%;
    padding: 1rem;
    border-radius: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.2s;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
  }

  .btn-download-full:hover {
    background: #059669;
    transform: translateY(-2px);
    color: white;
  }

  .btn-back-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 600;
    margin-top: 2rem;
    transition: color 0.2s;
  }

  .btn-back-outline:hover { color: var(--primary-blue); }

  @media (max-width: 768px) {
    .detail-hero h1 { font-size: 1.75rem; }
    .main-card { padding: 1.5rem; }
  }
</style>

<div class="container mt-4 mb-5">
  <!-- Breadcrumb -->
  <nav class="breadcrumb-nav">
    <a href="/" class="text-decoration-none text-muted">Home</a> / 
    <a href="/elk-library" class="text-decoration-none text-muted">Library</a> / 
    <span class="text-dark fw-semibold">Detail Karya</span>
  </nav>

  <!-- Hero Header -->
  <header class="detail-hero">
    <% 
      const judul = item.judulPublik || item.title || '(Judul tidak tersedia)';
      const penulis = item.nama || item.penulis || 'Anonim';
    %>
    <h1><%= judul %></h1>
    
    <div class="meta-badge-group">
      <div class="meta-badge">
        <i class="bi bi-person-circle"></i> <%= penulis %>
      </div>
      <% if (item.tahun) { %>
      <div class="meta-badge">
        <i class="bi bi-calendar-check"></i> <%= item.tahun %>
      </div>
      <% } %>
      <div class="meta-badge">
        <i class="bi bi-file-earmark-lock2"></i> Open Access
      </div>
    </div>
  </header>

  <div class="row">
    <!-- Main Content: Abstract -->
    <div class="col-lg-8">
      <article class="main-card">
        <h5 class="section-title">
          <i class="bi bi-text-paragraph"></i> Abstrak
        </h5>
        <div class="abstract-text">
          <%= item.abstrak || item.abstract || 'Abstrak tidak tersedia untuk dokumen ini.' %>
        </div>

        <hr class="my-5 opacity-50">

        <% if (item.kataKunci) { %>
        <h5 class="section-title">
          <i class="bi bi-tags"></i> Kata Kunci
        </h5>
        <div class="ms-n1">
          <% item.kataKunci.forEach(function(key) { %>
            <span class="keyword-pill"><%= key %></span>
          <% }); %>
        </div>
        <% } %>
      </article>
      
      <a href="/elk-library" class="btn-back-outline">
        <i class="bi bi-arrow-left"></i> Kembali ke Katalog Perpustakaan
      </a>
    </div>

    <!-- Sidebar: Metadata & Download -->
    <div class="col-lg-4">
      <!-- Download Box -->
      <% if (item.fileUrl) { %>
      <div class="sidebar-card border-success bg-light bg-opacity-10">
        <h6 class="fw-bold mb-3">Dokumen Lengkap</h6>
        <a href="<%= item.fileUrl %>" target="_blank" class="btn-download-full">
          <i class="bi bi-file-earmark-pdf fs-4"></i> Lihat PDF Lengkap
        </a>
        <p class="text-muted small text-center mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i> Klik untuk membuka file di tab baru
        </p>
      </div>
      <% } %>

      <!-- Author/Supervisor Box -->
      <div class="sidebar-card">
        <h6 class="fw-bold mb-3 border-bottom pb-2">Informasi Kontributor</h6>
        
        <div class="mb-3">
          <label class="text-muted small d-block">Penulis Utama</label>
          <span class="fw-semibold"><%= penulis %></span>
        </div>

        <% if (item.pembimbing) { %>
        <div class="mb-0">
          <label class="text-muted small d-block">Dosen Pembimbing</label>
          <span class="fw-semibold"><i class="bi bi-mortarboard me-1"></i> <%= item.pembimbing %></span>
        </div>
        <% } %>
      </div>

      <!-- Type/Category Box -->
      <div class="sidebar-card">
        <h6 class="fw-bold mb-3 border-bottom pb-2">Detail Publikasi</h6>
        <div class="d-flex justify-content-between mb-2">
          <span class="text-muted small">Tipe Dokumen</span>
          <span class="badge bg-primary rounded-pill small"><%= item._type === 'laporan' ? 'Laporan Magang' : 'Artikel Ilmiah' %></span>
        </div>
        <div class="d-flex justify-content-between">
          <span class="text-muted small">ID Arsip</span>
          <span class="text-dark fw-medium small">#<%= (item.id || '').substring(0,8).toUpperCase() %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer-landing') %>