<%- include('../partials/header-landing') %>

<style>
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER DETAIL ===== */
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 2rem;
    padding: 3rem;
    color: white;
    margin-bottom: 2.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -5%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(15deg);
  }
  .detail-header h1 {
    font-weight: 700;
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .detail-header p {
    margin-bottom: 0.2rem;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ===== ABSTRACT CARD ===== */
  .abstract-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-bottom: 2rem;
    border: 1px solid rgba(33,147,176,0.1);
    transition: transform 0.3s;
  }
  .abstract-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(33,147,176,0.1);
  }
  .abstract-card h5 {
    font-weight: 700;
    color: #1e293b;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 2px solid var(--primary-light);
    padding-bottom: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .abstract-card p {
    color: #475569;
    line-height: 1.8;
    font-size: 1rem;
  }
  .kata-kunci {
    background: var(--primary-light);
    padding: 1rem 1.5rem;
    border-radius: 1rem;
    color: var(--primary-dark);
    font-weight: 500;
  }

  /* ===== TOMBOL DOWNLOAD ===== */
  .btn-download {
    background: linear-gradient(135deg, #28a745, #5cb85c);
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.8rem 2.5rem;
    font-weight: 600;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(40,167,69,0.2);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-download:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(40,167,69,0.3);
    color: white;
  }

  /* ===== TOMBOL KEMBALI ===== */
  .btn-back {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.6rem 2rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-back:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }
</style>

<div class="container mt-4">
  <!-- Header Detail -->
  <div class="detail-header">
    <% 
      const judul = item.judulPublik || item.title || '(Judul tidak tersedia)';
      const penulis = item.nama || item.penulis || 'Anonim';
      const tahun = item.tahun ? `Tahun: ${item.tahun}` : '';
    %>
    <h1><%= judul %></h1>
    <p><i class="bi bi-person-badge"></i> <%= penulis %></p>
    <p><i class="bi bi-calendar3"></i> <%= tahun %></p>
  </div>

  <!-- Abstrak -->
  <div class="abstract-card">
    <h5><i class="bi bi-file-text" style="color: var(--primary-start);"></i> Abstrak</h5>
    <p class="mb-4"><%= item.abstrak || item.abstract || 'Tidak ada abstrak.' %></p>
    <% if (item.kataKunci) { %>
      <div class="kata-kunci">
        <i class="bi bi-tags"></i> <strong>Kata Kunci:</strong> <%= item.kataKunci.join(', ') %>
      </div>
    <% } %>
  </div>

  <!-- Tombol Download (hanya tampil jika ada fileUrl) -->
  <% if (item.fileUrl) { %>
    <div class="text-center mb-5">
      <a href="<%= item.fileUrl %>" target="_blank" class="btn-download">
        <i class="bi bi-file-earmark-pdf fs-5"></i> Lihat / Unduh Dokumen
      </a>
    </div>
  <% } %>

  <!-- Tombol Kembali -->
  <div class="text-center">
    <a href="/elk-library" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali ke Library
    </a>
  </div>
</div>

<%- include('../partials/footer-landing') %>