<%- include('../../partials/header') %>
<div class="container mt-4"><div class="card"><div class="card-header">Form Periode</div><div class="card-body"><form method="POST"><div class="mb-3"><label>Nama</label><input name="nama" class="form-control" value="<%= period ? period.nama : '' %>" required></div><div class="row"><div class="col-md-6"><label>Mulai</label><input type="date" name="tanggalMulai" class="form-control" value="<%= period ? period.tanggalMulai : '' %>" required></div><div class="col-md-6"><label>Selesai</label><input type="date" name="tanggalSelesai" class="form-control" value="<%= period ? period.tanggalSelesai : '' %>" required></div></div><div class="mb-3 mt-3"><label>Status</label><select name="status" class="form-select"><option value="active">Aktif</option><option value="closed">Tutup</option></select></div><button class="btn btn-primary">Simpan</button><a href="/admin/spmp/periods" class="btn btn-secondary">Batal</a></form></div></div></div>
<%- include('../../partials/footer') %>