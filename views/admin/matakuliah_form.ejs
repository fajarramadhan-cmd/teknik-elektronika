<%- include('../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive (untuk konsistensi)
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== FORM CARD ===== */
  .form-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto;
    background: white;
  }

  .form-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 2rem;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .form-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .form-header h3 {
    margin: 0;
    font-weight: 700;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .form-body {
    padding: 2.5rem;
  }

  /* ===== TOMBOL GRADIEN ===== */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.75rem 2.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid transparent;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(33,147,176,0.4);
    color: white;
  }

  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.75rem 2.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }

  /* ===== LABEL DAN INPUT ===== */
  .form-label {
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.5rem;
    display: block;
  }

  .form-control, .form-select {
    border-radius: 1rem;
    border: 1px solid #e2e8f0;
    padding: 0.75rem 1.25rem;
    transition: all 0.2s;
    background-color: #f8fafc;
    font-size: 0.95rem;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 4px rgba(33,147,176,0.1);
    outline: none;
    background-color: white;
  }
  .form-control::placeholder {
    color: #94a3b8;
    font-size: 0.9rem;
  }

  /* ===== DOSEN CONTAINER ===== */
  .dosen-container {
    max-height: 220px;
    overflow-y: auto;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 1rem;
    background-color: #f8fafc;
  }
  .dosen-item {
    padding: 0.6rem 0.5rem;
    border-bottom: 1px solid #e9ecef;
    transition: background 0.2s;
  }
  .dosen-item:last-child {
    border-bottom: none;
  }
  .dosen-item:hover {
    background: var(--primary-light);
    border-radius: 0.5rem;
  }
  .form-check-input:checked {
    background-color: var(--primary-start);
    border-color: var(--primary-start);
  }

  /* ===== CHECKBOX CUSTOM ===== */
  .form-check {
    margin-bottom: 0;
  }
  .form-check-label {
    color: #334155;
    font-weight: 500;
    margin-left: 0.5rem;
  }

  /* ===== BADGE PDK ===== */
  .pdk-badge {
    display: inline-block;
    background: var(--primary-light);
    color: var(--primary-dark);
    border-radius: 50px;
    padding: 0.2rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    margin-left: 1rem;
  }

  /* ===== RESPONSIF ===== */
  @media (max-width: 768px) {
    .form-body {
      padding: 1.5rem;
    }
    .btn-gradient, .btn-outline-gradient {
      padding: 0.6rem 1.5rem;
    }
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3>
        <i class="bi bi-<%= mk ? 'pencil-square' : 'plus-circle' %>"></i>
        <%= mk ? 'Edit Mata Kuliah' : 'Tambah Mata Kuliah' %>
      </h3>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= mk ? '/admin/matakuliah/' + mk.id + '/update' : '/admin/matakuliah' %>">
        <div class="row g-4">
          <!-- Kode MK -->
          <div class="col-md-6">
            <label for="kode" class="form-label">Kode MK <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="kode" name="kode" 
                   value="<%= mk ? mk.kode : '' %>" 
                   placeholder="Contoh: ELK101" required>
          </div>

          <!-- Nama MK -->
          <div class="col-md-6">
            <label for="nama" class="form-label">Nama Mata Kuliah <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nama" name="nama" 
                   value="<%= mk ? mk.nama : '' %>" 
                   placeholder="Contoh: Dasar Sistem Informasi" required>
          </div>

          <!-- SKS -->
          <div class="col-md-4">
            <label for="sks" class="form-label">SKS <span class="text-danger">*</span></label>
            <input type="number" class="form-control" id="sks" name="sks" 
                   value="<%= mk ? mk.sks : '' %>" min="1" max="6" required>
          </div>

          <!-- Semester -->
          <div class="col-md-4">
            <label for="semester" class="form-label">Semester <span class="text-danger">*</span></label>
            <select class="form-select" id="semester" name="semester" required>
              <option value="">-- Pilih Semester --</option>
              <% for (let i = 1; i <= 8; i++) { %>
                <option value="<%= i %>" <%= mk && mk.semester == i ? 'selected' : '' %>>Semester <%= i %></option>
              <% } %>
            </select>
          </div>

          <!-- Jadwal (opsional) -->
          <div class="col-md-4">
            <label for="jadwal" class="form-label">Jadwal</label>
            <input type="text" class="form-control" id="jadwal" name="jadwal" 
                   value="<%= mk ? mk.jadwal : '' %>" 
                   placeholder="Senin 08:00-10:30, Ruang A101">
          </div>

          <!-- Dosen Pengampu (scroll container) -->
          <div class="col-12">
            <label class="form-label">Dosen Pengampu</label>
            <div class="dosen-container">
              <% if (dosenList && dosenList.length) { %>
                <% dosenList.forEach(d => { %>
                  <div class="dosen-item">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="dosenIds" value="<%= d.id %>" id="dosen_<%= d.id %>"
                        <%= (mk && mk.dosenIds && mk.dosenIds.includes(d.id)) ? 'checked' : '' %>>
                      <label class="form-check-label" for="dosen_<%= d.id %>">
                        <%= d.nama %> <span class="text-muted">(<%= d.nip || '-' %>)</span>
                      </label>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-muted text-center py-3">
                  <i class="bi bi-exclamation-circle me-2"></i>
                  Belum ada data dosen. <a href="/admin/dosen/create">Tambah dosen</a> terlebih dahulu.
                </p>
              <% } %>
            </div>
            <small class="text-muted mt-2 d-block">Pilih satu atau lebih dosen pengampu</small>
          </div>

          <!-- Checkbox PDK -->
          <div class="col-12">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" id="isPDK" name="isPDK" value="1" 
                     <%= mk && mk.isPDK ? 'checked' : '' %>>
              <label class="form-check-label" for="isPDK">
                Mata Kuliah PDK (Praktik Dunia Kerja)
                <span class="pdk-badge">PDK</span>
              </label>
              <small class="text-muted d-block mt-1">Centang jika ini adalah mata kuliah Praktik Dunia Kerja 1, 2, atau 3</small>
            </div>
          </div>

          <!-- Tombol Aksi -->
          <div class="col-12 mt-4 d-flex justify-content-between">
            <a href="/admin/matakuliah" class="btn-outline-gradient">
              <i class="bi bi-arrow-left"></i> Kembali
            </a>
            <button type="submit" class="btn-gradient">
              <i class="bi bi-save"></i> Simpan
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>