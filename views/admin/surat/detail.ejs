<%- include('../../partials/header') %>

<style>
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -5%;
    width: 250px;
    height: 250px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    filter: blur(30px);
  }
  .info-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .badge-status {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
  }
  .badge-pending { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
  .badge-completed { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
  .badge-rejected { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
  .badge-cancelled { background: #e9ecef; color: #495057; border: 1px solid #ced4da; }
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(30,58,138,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
  }
  .btn-danger-outline {
    background: transparent;
    border: 2px solid #dc2626;
    color: #dc2626;
  }
  .btn-danger-outline:hover {
    background: #dc2626;
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-envelope-paper me-2"></i>Detail Surat</h2>
    </div>
    <a href="/admin/surat" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Info Pemohon -->
  <div class="info-card">
    <h5 class="fw-bold mb-3"><i class="bi bi-person-circle me-2"></i>Data <%= role === 'mahasiswa' ? 'Mahasiswa' : 'Dosen' %></h5>
    <div class="row">
      <div class="col-md-6">
        <p><strong>Nama:</strong> <%= pemohon.nama %></p>
        <p><strong><%= role === 'mahasiswa' ? 'NIM' : 'NIP' %>:</strong> <%= pemohon.nim || pemohon.nip %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Email:</strong> <%= pemohon.email %></p>
        <p><strong>No HP:</strong> <%= pemohon.noHp || '-' %></p>
      </div>
    </div>
  </div>

  <!-- Info Surat -->
  <div class="info-card">
    <div class="row">
      <div class="col-md-6">
        <p><strong>Jenis Surat:</strong> <%= surat.jenis || surat.jenisSurat %></p>
        <p><strong>Tanggal Pengajuan:</strong> <%= new Date(surat.createdAt).toLocaleString('id-ID') %></p>
        <p><strong>Status:</strong> 
          <% if (surat.status === 'pending') { %>
            <span class="badge-status badge-pending">Pending</span>
          <% } else if (surat.status === 'completed') { %>
            <span class="badge-status badge-completed">Selesai</span>
          <% } else if (surat.status === 'rejected') { %>
            <span class="badge-status badge-rejected">Ditolak</span>
          <% } else if (surat.status === 'cancelled') { %>
            <span class="badge-status badge-cancelled">Dibatalkan</span>
          <% } %>
        </p>
      </div>
      <div class="col-md-6">
        <p><strong>Kode Validasi:</strong> 
          <code><%= surat.kodeValidasi %></code>
        </p>
        <% if (surat.semester) { %>
          <p><strong>Semester:</strong> <%= surat.semester %></p>
        <% } %>
        <% if (surat.tahunAkademik) { %>
          <p><strong>Tahun Akademik:</strong> <%= surat.tahunAkademik %></p>
        <% } %>
      </div>
    </div>
    <hr>
    <p><strong>Keperluan:</strong> <%= surat.keperluan %></p>
    <% if (surat.keterangan) { %>
      <p><strong>Keterangan Tambahan:</strong> <%= surat.keterangan %></p>
    <% } %>
    <% if (surat.tujuan) { %>
      <p><strong>Tujuan:</strong> <%= surat.tujuan %></p>
    <% } %>
  </div>

  <!-- File yang sudah diupload -->
  <% if (surat.fileUrl) { %>
    <div class="info-card">
      <h5 class="fw-bold mb-3">File Surat</h5>
      <a href="<%= surat.fileUrl %>" target="_blank" class="btn btn-info btn-sm">
        <i class="bi bi-eye me-2"></i>Lihat File
      </a>
    </div>
  <% } %>

  <!-- Riwayat -->
  <% if (surat.history && surat.history.length > 0) { %>
    <div class="info-card">
      <h5 class="fw-bold mb-3">Riwayat</h5>
      <ul class="list-group">
        <% surat.history.slice().reverse().forEach(item => { %>
          <li class="list-group-item">
            <div class="d-flex justify-content-between align-items-center">
              <span><%= item.catatan %></span>
              <small class="text-muted"><%= new Date(item.timestamp).toLocaleString('id-ID') %></small>
            </div>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <!-- Aksi admin -->
  <% if (surat.status === 'pending') { %>
    <div class="row">
      <div class="col-md-6 mb-3">
        <div class="info-card">
          <h5 class="fw-bold mb-3">Upload Surat Jadi</h5>
          <form method="POST" action="/admin/surat/<%= surat.id %>/<%= role %>/upload" enctype="multipart/form-data">
            <div class="mb-3">
              <input type="file" class="form-control" name="file" accept=".pdf,.doc,.docx" required>
            </div>
            <button type="submit" class="btn btn-success">Upload & Selesaikan</button>
          </form>
        </div>
      </div>
      <div class="col-md-6 mb-3">
        <div class="info-card">
          <h5 class="fw-bold mb-3">Tolak Surat</h5>
          <form method="POST" action="/admin/surat/<%= surat.id %>/<%= role %>/reject">
            <div class="mb-3">
              <textarea class="form-control" name="alasan" rows="3" placeholder="Alasan penolakan" required></textarea>
            </div>
            <button type="submit" class="btn btn-danger" onclick="return confirm('Yakin menolak surat ini?')">Tolak</button>
          </form>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Jika sudah selesai, bisa ganti file (upload ulang) -->
  <% if (surat.status === 'completed') { %>
    <div class="info-card">
      <h5 class="fw-bold mb-3">Upload Ulang / Ganti File Surat</h5>
      <form method="POST" action="/admin/surat/<%= surat.id %>/<%= role %>/upload" enctype="multipart/form-data">
        <div class="mb-3">
          <input type="file" class="form-control" name="file" accept=".pdf,.doc,.docx">
        </div>
        <button type="submit" class="btn btn-warning">Ganti File</button>
      </form>
    </div>
  <% } %>

  <!-- Opsi Hapus (untuk semua status) -->
  <div class="info-card">
    <h5 class="fw-bold mb-3 text-danger">Hapus Surat</h5>
    <form method="POST" action="/admin/surat/<%= surat.id %>/<%= role %>/delete" onsubmit="return confirm('Yakin menghapus surat ini? Semua data terkait akan hilang.')">
      <button type="submit" class="btn btn-danger-outline btn-outline-gradient">Hapus Surat</button>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>