<%- include('../../partials/header') %>

<style>
  :root {
    --primary-gradient: linear-gradient(135deg, #1e3a8a, #3b82f6);
    --input-focus-shadow: rgba(59, 130, 246, 0.15);
  }

  body {
    background-color: #f8fafc;
  }

  .form-card {
    max-width: 750px;
    margin: 2rem auto;
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
  }

  .form-header {
    background: var(--primary-gradient);
    padding: 2.5rem 2rem;
    color: white;
    text-align: center;
    position: relative;
  }

  .form-header h3 {
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .form-header p {
    margin-top: 0.5rem;
    opacity: 0.8;
    font-size: 0.95rem;
  }

  .form-body {
    padding: 2.5rem 3rem;
  }

  /* Form Styling */
  .form-label {
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .form-label i {
    color: #3b82f6;
  }

  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1.5px solid #e2e8f0;
    background-color: #fcfcfd;
    transition: all 0.2s ease-in-out;
  }

  .form-control:focus, .form-select:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 4px var(--input-focus-shadow);
    background-color: #fff;
  }

  /* Custom File Input */
  .file-upload-wrapper {
    position: relative;
    border: 2px dashed #cbd5e1;
    border-radius: 1rem;
    padding: 1.5rem;
    text-align: center;
    background-color: #f8fafc;
    transition: all 0.2s;
  }

  .file-upload-wrapper:hover {
    border-color: #3b82f6;
    background-color: #eff6ff;
  }

  /* Buttons */
  .btn-submit {
    background: var(--primary-gradient);
    border: none;
    color: white;
    padding: 0.8rem 2.5rem;
    border-radius: 50px;
    font-weight: 700;
    transition: all 0.3s;
    box-shadow: 0 4px 12px rgba(30, 58, 138, 0.2);
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(30, 58, 138, 0.3);
    color: white;
  }

  .btn-cancel {
    border-radius: 50px;
    padding: 0.8rem 2rem;
    font-weight: 600;
    color: #64748b;
    border: 1.5px solid #e2e8f0;
    transition: all 0.2s;
  }

  .btn-cancel:hover {
    background-color: #f1f5f9;
    color: #1e293b;
  }

  @media (max-width: 768px) {
    .form-body { padding: 1.5rem; }
  }
</style>

<div class="container py-4">
  <div class="form-card">
    <div class="form-header">
      <div class="mb-2">
        <i class="bi bi-send-check-fill fs-1"></i>
      </div>
      <h3>Kirim Surat ke Dosen</h3>
      <p>Lengkapi formulir di bawah untuk mendistribusikan dokumen secara digital</p>
    </div>

    <div class="form-body">
      <form method="POST" action="/admin/surat/create" enctype="multipart/form-data">
        
        <!-- Dosen Selection -->
        <div class="mb-4">
          <label class="form-label">
            <i class="bi bi-person-badge"></i> Pilih Dosen Penerima <span class="text-danger">*</span>
          </label>
          <select name="dosenId" class="form-select" required>
            <option value="">Cari dan pilih nama dosen...</option>
            <% if (dosenList && dosenList.length) { %>
              <% dosenList.forEach(d => { %>
                <option value="<%= d.id %>"><%= d.nama %> — NIP: <%= d.nip || 'N/A' %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div class="row">
          <!-- Jenis Surat -->
          <div class="col-md-6 mb-4">
            <label class="form-label">
              <i class="bi bi-tag"></i> Jenis Surat <span class="text-danger">*</span>
            </label>
            <select name="jenisSurat" class="form-select" required>
              <option value="">Pilih kategori...</option>
              <option value="Surat Tugas">Surat Tugas</option>
              <option value="Surat Keterangan">Surat Keterangan</option>
              <option value="Surat Rekomendasi">Surat Rekomendasi</option>
              <option value="Surat Pengantar">Surat Pengantar</option>
              <option value="Surat Undangan">Surat Undangan</option>
              <option value="Lainnya">Lainnya</option>
            </select>
          </div>

          <!-- Judul / Keperluan -->
          <div class="col-md-6 mb-4">
            <label class="form-label">
              <i class="bi bi-bookmark-star"></i> Judul / Perihal <span class="text-danger">*</span>
            </label>
            <input type="text" name="keperluan" class="form-control" placeholder="Contoh: Pengabdian Masyarakat" required>
          </div>
        </div>

        <!-- Keterangan -->
        <div class="mb-4">
          <label class="form-label">
            <i class="bi bi-chat-left-text"></i> Catatan Tambahan <span class="text-muted small">(Opsional)</span>
          </label>
          <textarea name="isiLain" class="form-control" rows="3" placeholder="Tambahkan informasi pendukung jika diperlukan..."></textarea>
        </div>

        <!-- File Upload -->
        <div class="mb-4">
          <label class="form-label">
            <i class="bi bi-file-earmark-pdf"></i> Unggah Dokumen PDF <span class="text-danger">*</span>
          </label>
          <div class="file-upload-wrapper">
            <input type="file" name="file" class="form-control" accept=".pdf" required>
            <div class="mt-2 text-muted small">
              <i class="bi bi-info-circle me-1"></i> Pastikan file dalam format <strong>.pdf</strong> dengan ukuran maksimal 5MB.
            </div>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5 gap-3 border-top pt-4">
          <a href="/admin/surat" class="btn btn-cancel order-2 order-md-1 w-100 w-md-auto">
            <i class="bi bi-x-lg me-2"></i>Batalkan
          </a>
          <button type="submit" class="btn btn-submit order-1 order-md-2 w-100 w-md-auto">
            <i class="bi bi-send-fill me-2"></i>Kirim Surat Sekarang
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>