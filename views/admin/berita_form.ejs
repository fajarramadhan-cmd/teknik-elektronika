<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    margin: 0;
    font-weight: 600;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
  .preview-image {
    max-width: 200px;
    max-height: 150px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-pencil-square me-2"></i><%= berita ? 'Edit Berita' : 'Tambah Berita' %></h3>
    </div>
    <div class="form-body">
      <!-- Hapus enctype -->
      <form method="POST" action="<%= berita ? '/admin/berita/' + berita.id + '/update' : '/admin/berita' %>">
        <div class="mb-3">
          <label for="judul" class="form-label">Judul <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="judul" name="judul" value="<%= berita ? berita.judul : '' %>" required>
        </div>
        <div class="mb-3">
  <label for="tanggal" class="form-label">Tanggal Berita</label>
  <input type="date" class="form-control" id="tanggal" name="tanggal" 
         value="<%= berita && berita.tanggal ? new Date(berita.tanggal).toISOString().split('T')[0] : '' %>">
  <small class="text-muted">Kosongkan untuk menggunakan tanggal hari ini</small>
</div>
        <div class="mb-3">
          <label for="isi" class="form-label">Isi Berita <span class="text-danger">*</span></label>
          <textarea class="form-control" id="isi" name="isi" rows="8" required><%= berita ? berita.isi : '' %></textarea>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="penulis" class="form-label">Penulis</label>
            <input type="text" class="form-control" id="penulis" name="penulis" value="<%= berita ? berita.penulis : user.nama %>">
          </div>
          <div class="col-md-6 mb-3">
            <label for="sumber" class="form-label">Sumber (opsional)</label>
            <input type="text" class="form-control" id="sumber" name="sumber" value="<%= berita ? berita.sumber : '' %>">
          </div>
        </div>
        <div class="mb-3">
          <label for="gambar" class="form-label">URL Gambar Utama</label>
          <% if (berita && berita.gambar) { %>
            <div class="mb-2">
              <img src="<%= berita.gambar %>" alt="gambar" class="preview-image">
            </div>
          <% } %>
          <input type="url" class="form-control" id="gambar" name="gambar" value="<%= berita ? berita.gambar : '' %>" placeholder="https://contoh.com/gambar.jpg">
          <small class="text-muted">Masukkan URL gambar (opsional)</small>
        </div>
        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/berita" class="btn-outline-gradient">
            <i class="bi bi-arrow-left me-2"></i>Kembali
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save me-2"></i>Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>