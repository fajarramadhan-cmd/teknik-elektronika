<%- include('../partials/header') %>
<style>
  .card-perusahaan { border: none; border-radius: 1rem; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 1.5rem; }
  .card-perusahaan .card-header { background: linear-gradient(135deg, #1e3a8a, #3b82f6); color: white; border-radius: 1rem 1rem 0 0; font-weight: bold; }
  .btn-detail { border-radius: 60px; border: 1px solid #1e3a8a; background: white; color: #1e3a8a; }
  .btn-detail:hover { background: #1e3a8a; color: white; transform: translateY(-2px); }
</style>
<div class="container mt-4">
  <div class="page-header bg-primary text-white p-4 rounded-4 mb-4">
    <h2><i class="bi bi-building"></i> Daftar Perusahaan Magang</h2>
    <p>Data perusahaan dari seluruh periode magang mahasiswa</p>
  </div>

  <div class="row g-4">
    <% if (perusahaanList.length === 0) { %>
      <div class="col-12 text-center py-5">Belum ada data perusahaan</div>
    <% } else { %>
      <% perusahaanList.forEach(p => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-perusahaan h-100">
            <div class="card-header">
              <i class="bi bi-building me-2"></i> <%= p.nama %>
            </div>
            <div class="card-body">
              <p><i class="bi bi-geo-alt"></i> <strong>Alamat:</strong> <%= p.alamat || '-' %></p>
              <p><i class="bi bi-telephone"></i> <strong>Kontak HP:</strong> <%= p.kontakHp || '-' %></p>
              <p><i class="bi bi-person-badge"></i> <strong>Pembimbing Lapangan:</strong> <%= p.pembimbingLapangan || '-' %></p>
              <p><i class="bi bi-briefcase"></i> <strong>Jabatan:</strong> <%= p.jabatan || '-' %></p>
              <p><i class="bi bi-calendar-week"></i> <strong>Jumlah Periode:</strong> <%= p.periode.length %></p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
              <button class="btn-detail btn-sm" data-bs-toggle="modal" data-bs-target="#detailModal" data-nama="<%= p.nama %>" data-alamat="<%= p.alamat %>" data-kontak="<%= p.kontakHp %>" data-pembimbing="<%= p.pembimbingLapangan %>" data-jabatan="<%= p.jabatan %>">Detail</button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Modal Detail -->
<div class="modal fade" id="detailModal" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Detail Perusahaan</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body" id="modalBody"></div></div></div>
</div>
<script>
  const detailModal = document.getElementById('detailModal');
  detailModal.addEventListener('show.bs.modal', function(event) {
    const button = event.relatedTarget;
    const nama = button.getAttribute('data-nama');
    const alamat = button.getAttribute('data-alamat');
    const kontak = button.getAttribute('data-kontak');
    const pembimbing = button.getAttribute('data-pembimbing');
    const jabatan = button.getAttribute('data-jabatan');
    document.getElementById('modalBody').innerHTML = `<p><strong>Nama:</strong> ${nama}</p><p><strong>Alamat:</strong> ${alamat || '-'}</p><p><strong>Kontak HP:</strong> ${kontak || '-'}</p><p><strong>Pembimbing Lapangan:</strong> ${pembimbing || '-'}</p><p><strong>Jabatan:</strong> ${jabatan || '-'}</p>`;
  });
</script>
<%- include('../partials/footer') %>