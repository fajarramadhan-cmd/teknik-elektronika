<%- include('../partials/header') %>

<%
  // Helper untuk format tanggal
  const formatTanggal = (dateString) => {
    if (!dateString) return '-';
    const date = new Date(dateString);
    return date.toLocaleDateString('id-ID', {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    });
  };
  
  const formatDateTime = (dateString) => {
    if (!dateString) return '-';
    const date = new Date(dateString);
    return date.toLocaleDateString('id-ID', {
      day: '2-digit',
      month: 'long',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  };
  
  // Fungsi untuk mengekstrak fileId dari URL Google Drive
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>
<%
  if (typeof bimbingan === 'undefined') {
    var bimbingan = null;
  }
%>
<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --gray-border: #e2e8f0;
  }

  .profile-card {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.3);
    position: relative;
    overflow: hidden;
  }
  .avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .avatar-circle-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: white;
    color: var(--primary-start);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 600;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .pdk-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    background: white;
    border-radius: 1rem;
    padding: 1rem;
    text-align: center;
    border: 1px solid var(--gray-border);
    transition: all 0.3s;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  .stat-card.active {
    border: 2px solid var(--primary-start);
    background: var(--primary-light);
  }
  .stat-card .pdk-kode {
    font-weight: 700;
    color: var(--primary-start);
    font-size: 0.8rem;
  }
  .stat-card .pdk-nama {
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .stat-numbers {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .stat-item { text-align: center; }
  .stat-value { font-weight: 700; font-size: 1.2rem; }
  .stat-label { font-size: 0.7rem; color: #64748b; }
  .stat-card.pending .stat-value { color: #f59e0b; }
  .stat-card.approved .stat-value { color: #10b981; }
  .stat-card.rejected .stat-value { color: #ef4444; }

  .info-period {
    background: var(--info-bg);
    border-left: 4px solid var(--primary-start);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
  }

  .filter-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid var(--gray-border);
  }

  .table-container {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid var(--gray-border);
  }
  .logbook-table th {
    background: #f8f9fa;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.75rem;
    white-space: nowrap;
  }
  .logbook-table td {
    vertical-align: middle;
    padding: 0.75rem;
  }
  .thumbnail {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
  }

  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.75rem;
  }
  .badge-pending { background: var(--warning-bg); color: var(--warning-text); }
  .badge-approved { background: var(--success-bg); color: var(--success-text); }
  .badge-rejected { background: var(--danger-bg); color: var(--danger-text); }

  .btn-approve { background: #10b981; color: white; border: none; border-radius: 50px; padding: 0.3rem 1rem; font-size: 0.75rem; }
  .btn-reject { background: #ef4444; color: white; border: none; border-radius: 50px; padding: 0.3rem 1rem; font-size: 0.75rem; }
  .btn-manage { background: #8b5cf6; color: white; border: none; border-radius: 50px; padding: 0.3rem 1rem; font-size: 0.75rem; }
  .btn-print { background: #17a2b8; color: white; border: none; border-radius: 50px; padding: 0.5rem 1.2rem; font-size: 0.85rem; }
  .btn-back { background: transparent; border: 1px solid var(--primary-start); color: var(--primary-start); border-radius: 50px; padding: 0.5rem 1.2rem; }

  .modal-header-custom {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
  }
</style>

<div class="container mt-4">
  <!-- Profile Card -->
  <div class="profile-card">
    <div class="d-flex align-items-center flex-wrap">
      <div class="flex-shrink-0 me-4">
        <% if (mahasiswa.foto) { 
          const fileId = getFileIdFromUrl(mahasiswa.foto);
          if (fileId) { %>
            <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w200" class="avatar-large" onerror="this.onerror=null; this.src='<%= mahasiswa.foto %>';">
          <% } else { %>
            <img src="<%= mahasiswa.foto %>" class="avatar-large" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(mahasiswa.nama || '') %>&background=1e3a8a&color=fff&size=80';">
          <% } %>
        <% } else { %>
          <div class="avatar-circle-large"><%= (mahasiswa.nama || '?').charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <div>
        <h2 class="fw-bold"><%= mahasiswa.nama %></h2>
        <p class="mb-1"><i class="bi bi-qr-code me-2"></i>NIM: <%= mahasiswa.nim || '-' %></p>
        <p class="mb-1"><i class="bi bi-envelope me-2"></i><%= mahasiswa.email %></p>
        <p class="mb-0"><i class="bi bi-telephone me-2"></i><%= mahasiswa.noHp || '-' %></p>
      </div>
    </div>
  </div>

  <!-- Tombol Aksi -->
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="bi bi-journal-bookmark-fill me-2"></i>Logbook Magang</h4>
    <div class="d-flex gap-2">
      <button class="btn-manage" data-bs-toggle="modal" data-bs-target="#startPeriodModal">
        <i class="bi bi-plus-circle"></i> Mulai Periode Baru
      </button>
      <a href="/admin/emagang/print?userId=<%= mahasiswa.id %>" class="btn-print" target="_blank">
        <i class="bi bi-printer"></i> Print
      </a>
      <a href="/admin/emagang" class="btn-back">
        <i class="bi bi-arrow-left"></i> Kembali
      </a>
    </div>
  </div>

  <!-- PDK Stats Cards -->
  <% if (pdkStats && pdkStats.length > 0) { %>
    <div class="pdk-stats">
      <a href="/admin/emagang/mahasiswa/<%= mahasiswa.id %>" class="stat-card <%= !selectedPeriod ? 'active' : '' %>">
        <div class="pdk-kode">SEMUA</div>
        <div class="pdk-nama">Semua Periode</div>
        <div class="stat-numbers">
          <div class="stat-item pending"><div class="stat-value"><%= pdkStats.reduce(function(s, p) { return s + p.pendingCount; }, 0) %></div><div class="stat-label">Pending</div></div>
          <div class="stat-item approved"><div class="stat-value"><%= pdkStats.reduce(function(s, p) { return s + p.approvedCount; }, 0) %></div><div class="stat-label">Approved</div></div>
          <div class="stat-item rejected"><div class="stat-value"><%= pdkStats.reduce(function(s, p) { return s + p.rejectedCount; }, 0) %></div><div class="stat-label">Rejected</div></div>
        </div>
      </a>
      <% pdkStats.forEach(function(period) { %>
        <a href="/admin/emagang/mahasiswa/<%= mahasiswa.id %>?periodId=<%= period.id %>" class="stat-card <%= (selectedPeriod && selectedPeriod.id === period.id) ? 'active' : '' %>">
          <div class="pdk-kode"><%= period.pdkKode %></div>
          <div class="pdk-nama"><%= period.pdkNama %></div>
          <div class="stat-numbers">
            <div class="stat-item pending"><div class="stat-value"><%= period.pendingCount %></div><div class="stat-label">Pending</div></div>
            <div class="stat-item approved"><div class="stat-value"><%= period.approvedCount %></div><div class="stat-label">Approved</div></div>
            <div class="stat-item rejected"><div class="stat-value"><%= period.rejectedCount %></div><div class="stat-label">Rejected</div></div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>

  <!-- Info Periode Aktif -->
  <% if (selectedPeriod) { %>
    <div class="info-period">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
          <strong><i class="bi bi-info-circle"></i> Periode Magang:</strong> 
          <%= selectedPeriod.pdkKode %> - <%= selectedPeriod.pdkNama %>
          (<%= formatTanggal(selectedPeriod.tanggalMulai) %> 
          <%= selectedPeriod.tanggalSelesai ? 's/d ' + formatTanggal(selectedPeriod.tanggalSelesai) : 'Berlangsung' %>)
        </div>
        <div class="mt-1 mt-sm-0">
          <button class="btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editPerusahaanModal" 
                  data-period-id="<%= selectedPeriod.id %>"
                  data-nama="<%= selectedPeriod.perusahaan ? selectedPeriod.perusahaan.nama : '' %>"
                  data-alamat="<%= selectedPeriod.perusahaan ? selectedPeriod.perusahaan.alamat : '' %>"
                  data-kontak="<%= selectedPeriod.perusahaan ? selectedPeriod.perusahaan.kontak : '' %>"
                  data-kontakhp="<%= selectedPeriod.perusahaan ? selectedPeriod.perusahaan.kontakHp : '' %>"
                  data-pembimbing="<%= selectedPeriod.perusahaan ? selectedPeriod.perusahaan.pembimbingLapangan : '' %>">
            <i class="bi bi-pencil"></i> Edit Perusahaan
          </button>
          <% if (selectedPeriod.status === 'active') { %>
            <button class="btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#lockModal" 
                    data-period-id="<%= selectedPeriod.id %>" data-period-name="<%= selectedPeriod.pdkNama %>">
              <i class="bi bi-lock"></i> Lock
            </button>
            <button class="btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#extendModal" 
                    data-period-id="<%= selectedPeriod.id %>" data-period-name="<%= selectedPeriod.pdkNama %>"
                    data-current-end="<%= selectedPeriod.tanggalSelesai || '' %>">
              <i class="bi bi-calendar-plus"></i> Perpanjang
            </button>
            <button class="btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#completeModal" 
                    data-period-id="<%= selectedPeriod.id %>" data-period-name="<%= selectedPeriod.pdkNama %>">
              <i class="bi bi-check-circle"></i> Selesai & Nilai
            </button>
          <% } else if (selectedPeriod.status === 'locked') { %>
            <button class="btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#unlockModal" 
                    data-period-id="<%= selectedPeriod.id %>" data-period-name="<%= selectedPeriod.pdkNama %>">
              <i class="bi bi-unlock"></i> Unlock
            </button>
          <% } %>
        </div>
      </div>
      <div class="mt-2">
        <strong><i class="bi bi-building"></i> Perusahaan:</strong> <%= (selectedPeriod.perusahaan && selectedPeriod.perusahaan.nama) ? selectedPeriod.perusahaan.nama : 'Belum diisi' %>
      </div>
      <div class="mt-2">
        <strong><i class="bi bi-person-badge"></i> Pembimbing 1:</strong> <%= selectedPeriod.pembimbing1Nama || '-' %> &nbsp;|&nbsp;
        <strong><i class="bi bi-person-badge"></i> Pembimbing 2:</strong> <%= selectedPeriod.pembimbing2Nama || '-' %>
      </div>
    </div>
  <% } else if (bimbingan && bimbingan.pembimbing1Nama) { %>
    <div class="info-period">
      <strong><i class="bi bi-person-badge"></i> Pembimbing 1:</strong> <%= bimbingan.pembimbing1Nama %> &nbsp;|&nbsp;
      <strong><i class="bi bi-person-badge"></i> Pembimbing 2:</strong> <%= bimbingan.pembimbing2Nama || '-' %>
    </div>
  <% } %>

  <!-- Filter Semester -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label fw-semibold"><i class="bi bi-funnel"></i> Filter Semester</label>
        <select name="semester" class="form-select" onchange="this.form.submit()">
          <option value="">Semua Semester</option>
          <% semesterList.forEach(function(s) { %>
            <option value="<%= s %>" <%= (selectedSemester === s) ? 'selected' : '' %>><%= s %></option>
          <% }); %>
        </select>
      </div>
      <% if (selectedPeriod) { %>
        <input type="hidden" name="periodId" value="<%= selectedPeriod.id %>">
      <% } %>
    </form>
  </div>

  <!-- Tabel Logbook -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table logbook-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Tanggal</th>
            <th>Kegiatan</th>
            <th>Durasi</th>
            <th>Lokasi</th>
            <th>Semester</th>
            <th>Gambar</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (logbookList.length === 0) { %>
            <tr><td colspan="9" class="text-center py-5">Belum ada logbook untuk periode ini.ERB</td></td>
          <% } else { %>
            <% logbookList.forEach(function(item, idx) { %>
              <tr>
                <td class="fw-bold text-center"><%= idx+1 %></td>
                <td><%= formatTanggal(item.tanggal) %></td>
                <td><%= item.kegiatan %></td>
                <td class="text-center"><%= item.durasi ? item.durasi + ' jam' : '-' %></td>
                <td><%= item.lokasi || '-' %></td>
                <td><%= item.semester || '-' %></td>
                <td class="text-center">
                  <% if (item.imageUrls && item.imageUrls.length > 0) { 
                    var firstUrl = item.imageUrls[0];
                    var fileId = getFileIdFromUrl(firstUrl);
                  %>
                    <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w100" class="thumbnail" onclick="lihatGambar(<%= JSON.stringify(item.imageUrls) %>)">
                  <% } else { %>-<% } %>
                </td>
                <td>
                  <% if (item.status === 'approved') { %>
                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                    <% if (item.approvedByNama) { %>
                      <div class="small text-muted mt-1">Oleh: <%= item.approvedByNama %></div>
                    <% } %>
                  <% } else if (item.status === 'rejected') { %>
                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                    <% if (item.rejectedByNama) { %>
                      <div class="small text-muted mt-1">Oleh: <%= item.rejectedByNama %></div>
                    <% } %>
                  <% } else { %>
                    <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                  <% } %>
                </td>
                <td>
                  <% if (item.status === 'pending') { %>
                    <form method="POST" action="/admin/emagang/logbook/<%= item.id %>/approve" style="display:inline;">
                      <button class="btn-approve btn-sm" onclick="return confirm('Setujui logbook ini?')"><i class="bi bi-check-lg"></i> Setujui</button>
                    </form>
                    <button class="btn-reject btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal" data-logbook-id="<%= item.id %>" data-logbook-title="<%= item.kegiatan.substring(0, 50) %>">Tolak</button>
                  <% } else { %>-<% } %>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Start Period -->
<div class="modal fade" id="startPeriodModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header modal-header-custom">
        <h5 class="modal-title"><i class="bi bi-play-fill"></i> Mulai Periode Magang</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/admin/emagang/period/start">
        <input type="hidden" name="mahasiswaId" value="<%= mahasiswa.id %>">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label>Pilih PDK <span class="text-danger">*</span></label>
              <select name="pdkId" class="form-select" required>
                <option value="">-- Pilih PDK --</option>
                <% if (pdkList && pdkList.length > 0) { %>
                  <% pdkList.forEach(function(p) { %>
                    <option value="<%= p.id %>"><%= p.kode %> - <%= p.nama %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label>Tanggal Mulai <span class="text-danger">*</span></label>
              <input type="date" name="tanggalMulai" class="form-control" required>
            </div>
            <div class="col-md-6 mb-3">
              <label>Tanggal Selesai (Opsional)</label>
              <input type="date" name="tanggalSelesai" class="form-control">
            </div>
          </div>
          <hr>
          <h6 class="fw-bold">Informasi Perusahaan</h6>
          <div class="row">
            <div class="col-12 mb-3">
              <label>Nama Perusahaan <span class="text-danger">*</span></label>
              <input type="text" name="namaPerusahaan" class="form-control" required>
            </div>
            <div class="col-12 mb-3">
              <label>Alamat</label>
              <textarea name="alamatPerusahaan" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-6 mb-3">
              <label>Kontak Telepon</label>
              <input type="text" name="kontakPerusahaan" class="form-control">
            </div>
            <div class="col-md-6 mb-3">
              <label>Kontak HP</label>
              <input type="text" name="kontakHpPerusahaan" class="form-control">
            </div>
            <div class="col-md-6 mb-3">
              <label>Pembimbing Lapangan</label>
              <input type="text" name="pembimbingLapangan" class="form-control">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Mulai Magang</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Perusahaan -->
<div class="modal fade" id="editPerusahaanModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header modal-header-custom">
        <h5 class="modal-title"><i class="bi bi-building"></i> Edit Perusahaan</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="editPerusahaanForm">
        <div class="modal-body">
          <div class="mb-3"><label>Nama Perusahaan</label><input type="text" name="namaPerusahaan" id="editNama" class="form-control" required></div>
          <div class="mb-3"><label>Alamat</label><textarea name="alamatPerusahaan" id="editAlamat" class="form-control" rows="2"></textarea></div>
          <div class="row"><div class="col-md-6 mb-3"><label>Kontak Telepon</label><input type="text" name="kontakPerusahaan" id="editKontak" class="form-control"></div>
          <div class="col-md-6 mb-3"><label>Kontak HP</label><input type="text" name="kontakHpPerusahaan" id="editKontakHp" class="form-control"></div></div>
          <div class="mb-3"><label>Pembimbing Lapangan</label><input type="text" name="pembimbingLapangan" id="editPembimbing" class="form-control"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Lock -->
<div class="modal fade" id="lockModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header modal-header-custom">
        <h5 class="modal-title"><i class="bi bi-lock"></i> Kunci Periode Magang</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="lockForm">
        <div class="modal-body">
          <p>Yakin ingin mengunci periode magang <strong id="lockPeriodName"></strong>?</p>
          <div class="mb-3"><label>Alasan</label><textarea name="reason" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-warning">Kunci</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Unlock -->
<div class="modal fade" id="unlockModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header modal-header-custom">
        <h5 class="modal-title"><i class="bi bi-unlock"></i> Buka Kunci Periode Magang</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
