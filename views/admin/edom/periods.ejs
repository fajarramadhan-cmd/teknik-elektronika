<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.08);
  }
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.8rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header h2 {
    font-weight: 800;
    font-size: 1.8rem;
    margin: 0;
  }
  .page-header p {
    margin-top: 0.5rem;
    opacity: 0.9;
  }
  .filter-bar {
    background: white;
    border-radius: 1rem;
    padding: 1rem 1.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    border: 1px solid rgba(30,58,138,0.1);
  }
  .btn-primary-custom {
    background: linear-gradient(105deg, var(--primary-start), var(--primary-end));
    border: none;
    border-radius: 60px;
    padding: 0.5rem 1.2rem;
    font-weight: 500;
    transition: all 0.2s;
    color: white;
  }
  .btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(30,58,138,0.25);
    color: white;
  }
  .table-container {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow-x: auto;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .table th {
    background: #f8fafc;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.5px;
    border-bottom: 2px solid #e2e8f0;
    padding: 1rem;
  }
  .table td {
    padding: 1rem;
    vertical-align: middle;
    border-bottom: 1px solid #f0f2f5;
  }
  .table tr:hover td {
    background: #fefce8;
  }
  .badge-status {
    padding: 0.3rem 0.9rem;
    border-radius: 60px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-active {
    background: #d1fae5;
    color: #065f46;
  }
  .badge-closed {
    background: #e2e8f0;
    color: #475569;
  }
  .modal-header-custom {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-bottom: none;
  }
  .modal-header-custom .btn-close {
    filter: brightness(0) invert(1);
  }
  .form-label {
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .page-header { padding: 1.2rem; }
    .page-header h2 { font-size: 1.4rem; }
    .table th, .table td { padding: 0.75rem; font-size: 0.85rem; }
  }
</style>

<div class="container mt-4">
  <div class="page-header">
    <h2><i class="bi bi-calendar-week me-2"></i>Kelola Periode EDOM</h2>
    <p>Atur periode evaluasi dosen oleh mahasiswa</p>
  </div>

  <div class="filter-bar">
    <div>
      <i class="bi bi-info-circle-fill text-primary me-2"></i>
      <span>Periode aktif: hanya periode dengan status <strong>Aktif</strong> dan tanggal dalam range dapat diisi mahasiswa.</span>
    </div>
    <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#periodModal" onclick="clearForm()">
      <i class="bi bi-plus-circle me-2"></i>Tambah Periode
    </button>
  </div>

  <div class="table-container">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Nama Periode</th>
          <th>Semester</th>
          <th>Tanggal Mulai</th>
          <th>Tanggal Selesai</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (periods && periods.length) { %>
          <% periods.forEach(p => { %>
            <tr>
              <td class="fw-semibold"><%= p.nama %></td>
              <td><%= p.semester %></td>
              <td><%= p.tanggalMulai %></td>
              <td><%= p.tanggalSelesai %></td>
              <td>
                <span class="badge-status <%= p.status === 'active' ? 'badge-active' : 'badge-closed' %>">
                  <%= p.status === 'active' ? 'Aktif' : 'Ditutup' %>
                </span>
              </td>
              <td>
                <button class="btn btn-sm btn-warning me-1" onclick="editPeriod('<%= p.id %>', '<%= p.nama %>', '<%= p.semester %>', '<%= p.tanggalMulai %>', '<%= p.tanggalSelesai %>', '<%= p.status %>')">
                  <i class="bi bi-pencil"></i> Edit
                </button>
                <form method="POST" action="/admin/edom/periods/<%= p.id %>/delete" style="display:inline;" onsubmit="return confirm('Hapus periode ini? Semua data respon terkait akan hilang.')">
                  <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Hapus</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted"></i>
              <p class="mt-2 mb-0">Belum ada periode. Klik "Tambah Periode" untuk membuat.</p>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Form Periode (Tambah / Edit) -->
<div class="modal fade" id="periodModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header modal-header-custom">
        <h5 class="modal-title" id="modalTitle"><i class="bi bi-pencil-square me-2"></i>Tambah Periode</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="periodForm" action="/admin/edom/periods">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Nama Periode <span class="text-danger">*</span></label>
            <input type="text" name="nama" id="periodNama" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Semester <span class="text-danger">*</span></label>
            <input type="text" name="semester" id="periodSemester" class="form-control" placeholder="Contoh: Ganjil 2025/2026" required>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Tanggal Mulai</label>
              <input type="date" name="tanggalMulai" id="periodMulai" class="form-control" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Tanggal Selesai</label>
              <input type="date" name="tanggalSelesai" id="periodSelesai" class="form-control" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Status</label>
            <select name="status" id="periodStatus" class="form-select">
              <option value="active">Aktif</option>
              <option value="closed">Ditutup</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function clearForm() {
    document.getElementById('modalTitle').innerHTML = '<i class="bi bi-plus-circle me-2"></i>Tambah Periode';
    document.getElementById('periodForm').reset();
    document.getElementById('periodForm').action = '/admin/edom/periods';
    document.getElementById('periodForm').method = 'POST';
  }

  function editPeriod(id, nama, semester, tanggalMulai, tanggalSelesai, status) {
    document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil-square me-2"></i>Edit Periode';
    document.getElementById('periodNama').value = nama;
    document.getElementById('periodSemester').value = semester;
    document.getElementById('periodMulai').value = tanggalMulai;
    document.getElementById('periodSelesai').value = tanggalSelesai;
    document.getElementById('periodStatus').value = status;
    const form = document.getElementById('periodForm');
    form.action = `/admin/edom/periods/${id}/edit`;
    form.method = 'POST';
    // Show modal via Bootstrap JS (assuming Bootstrap 5)
    const modal = new bootstrap.Modal(document.getElementById('periodModal'));
    modal.show();
  }
</script>

<%- include('../../partials/footer') %>