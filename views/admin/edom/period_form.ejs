<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
  }
  .form-card {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .form-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    font-weight: 700;
    margin: 0;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-primary-custom {
    background: linear-gradient(105deg, var(--primary-start), var(--primary-end));
    border: none;
    border-radius: 60px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: 0.2s;
  }
  .btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(30,58,138,0.25);
  }
  .form-label {
    font-weight: 600;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-calendar-week me-2"></i><%= period ? 'Edit Periode' : 'Tambah Periode' %></h3>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= period ? '/admin/edom/periods/' + period.id + '/edit' : '/admin/edom/periods' %>">
        <div class="mb-3">
          <label class="form-label">Nama Periode <span class="text-danger">*</span></label>
          <input type="text" name="nama" class="form-control" value="<%= period ? period.nama : '' %>" required>
          <small class="text-muted">Contoh: Ganjil 2025/2026</small>
        </div>
        <div class="mb-3">
          <label class="form-label">Semester <span class="text-danger">*</span></label>
          <input type="text" name="semester" class="form-control" value="<%= period ? period.semester : '' %>" required>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Tanggal Mulai</label>
            <input type="date" name="tanggalMulai" class="form-control" value="<%= period ? period.tanggalMulai : '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Tanggal Selesai</label>
            <input type="date" name="tanggalSelesai" class="form-control" value="<%= period ? period.tanggalSelesai : '' %>" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Status</label>
          <select name="status" class="form-select">
            <option value="active" <%= period && period.status === 'active' ? 'selected' : '' %>>Aktif</option>
            <option value="closed" <%= period && period.status === 'closed' ? 'selected' : '' %>>Ditutup</option>
          </select>
        </div>
        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/edom" class="btn btn-outline-secondary rounded-pill px-4">Batal</a>
          <button type="submit" class="btn btn-primary-custom">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>