<%- include('../../partials/header') %>

<style>
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
  }
  .form-card {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .form-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    font-weight: 700;
    margin: 0;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-primary-custom {
    background: linear-gradient(105deg, var(--primary-start), var(--primary-end));
    border: none;
    border-radius: 60px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: 0.2s;
  }
  .btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(30,58,138,0.25);
  }
  .form-label {
    font-weight: 600;
  }
  .form-check-input:checked {
    background-color: var(--primary-start);
    border-color: var(--primary-start);
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-question-circle me-2"></i><%= question ? 'Edit Pertanyaan' : 'Tambah Pertanyaan' %></h3>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= question ? '/admin/edom/questions/' + question.id + '/edit' : '/admin/edom/questions' %>">
        <div class="mb-3">
          <label class="form-label">Pertanyaan <span class="text-danger">*</span></label>
          <textarea name="pertanyaan" class="form-control" rows="2" required><%= question ? question.pertanyaan : '' %></textarea>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Tipe</label>
            <select name="tipe" class="form-select">
              <option value="rating" <%= question && question.tipe === 'rating' ? 'selected' : '' %>>Rating (1-5)</option>
              <option value="text" <%= question && question.tipe === 'text' ? 'selected' : '' %>>Teks (opsional)</option>
            </select>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Skala (maks nilai)</label>
            <input type="number" name="skala" class="form-control" min="1" max="10" value="<%= question ? (question.skala || 5) : 5 %>">
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Bobot</label>
            <input type="number" name="bobot" class="form-control" step="0.1" min="0" value="<%= question ? (question.bobot || 1) : 1 %>">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Urutan</label>
            <input type="number" name="urutan" class="form-control" min="0" value="<%= question ? (question.urutan || 0) : 0 %>">
          </div>
        </div>
        <div class="mb-3 form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" name="aktif" id="aktif" <%= question && question.aktif === true ? 'checked' : '' %>>
          <label class="form-check-label" for="aktif">Aktif (ditampilkan saat evaluasi)</label>
        </div>
        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/edom/questions" class="btn btn-outline-secondary rounded-pill px-4">Batal</a>
          <button type="submit" class="btn btn-primary-custom">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>