<%- include('../../partials/header') %>
<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white"><%= period ? 'Edit' : 'Tambah' %> Periode</div>
    <div class="card-body">
      <form method="POST" action="<%= period ? '/admin/edom/periods/'+period.id+'/edit' : '/admin/edom/periods' %>">
        <div class="mb-3">
          <label>Nama Periode</label>
          <input type="text" name="nama" class="form-control" value="<%= period ? period.nama : '' %>" required>
        </div>
        <div class="row">
          <div class="col-md-6"><label>Tanggal Mulai</label><input type="date" name="tanggalMulai" class="form-control" value="<%= period ? period.tanggalMulai : '' %>" required></div>
          <div class="col-md-6"><label>Tanggal Selesai</label><input type="date" name="tanggalSelesai" class="form-control" value="<%= period ? period.tanggalSelesai : '' %>" required></div>
        </div>
        <div class="mb-3 mt-3">
          <label>Semester</label>
          <input type="text" name="semester" class="form-control" value="<%= period ? period.semester : (typeof defaultSemester !== 'undefined' ? defaultSemester : '') %>" required>
        </div>
        <div class="mb-3">
          <label>Status</label>
          <select name="status" class="form-select">
            <option value="active" <%= period && period.status === 'active' ? 'selected' : '' %>>Aktif</option>
            <option value="closed" <%= period && period.status === 'closed' ? 'selected' : '' %>>Ditutup</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary">Simpan</button>
        <a href="/admin/edom/periods" class="btn btn-secondary">Batal</a>
      </form>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>