<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .preview-file {
    margin-top: 1rem;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 0.5rem;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-check2-circle me-2"></i>Setujui Artikel</h3>
    </div>
    <div class="form-body">
      <div class="mb-4">
        <h5>Informasi Artikel</h5>
        <p><strong>Judul:</strong> <%= artikel.judul %></p>
        <p><strong>Penulis:</strong> <%= artikel.penulis %></p>
        <p><strong>Abstrak:</strong></p>
        <p><%= artikel.abstrak %></p>
        <p><strong>File:</strong> <a href="<%= artikel.fileUrl %>" target="_blank">Lihat file</a></p>
      </div>

      <form method="POST" action="/admin/artikel/<%= artikel.id %>/approve">
        <div class="mb-3">
          <label for="keterangan" class="form-label fw-bold">Keterangan (opsional)</label>
          <textarea class="form-control" id="keterangan" name="keterangan" rows="2"></textarea>
        </div>
        <div class="d-flex gap-3">
          <button type="submit" name="action" value="approve" class="btn btn-success">Setujui</button>
          <button type="submit" name="action" value="reject" class="btn btn-danger">Tolak</button>
          <a href="/admin/artikel" class="btn btn-outline-secondary">Batal</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>