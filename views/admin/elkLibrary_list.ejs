<%- include('../partials/header') %>

<style>
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }
  .nav-tabs-custom {
    border-bottom: 2px solid var(--primary-light);
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .nav-tabs-custom .nav-link {
    border: none;
    color: #64748b;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 50px 50px 0 0;
    transition: all 0.2s;
    background: transparent;
    text-decoration: none;
  }
  .nav-tabs-custom .nav-link:hover {
    color: var(--primary-dark);
    background: var(--primary-light);
  }
  .nav-tabs-custom .nav-link.active {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    box-shadow: 0 5px 15px rgba(33,147,176,0.3);
  }
  .section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1.5rem 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-title i {
    color: var(--primary-start);
  }
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(33,147,176,0.1);
    margin-bottom: 2rem;
  }
  .table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1rem 0.75rem;
    white-space: nowrap;
  }
  .table tbody td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
    border-bottom: 1px solid #e9ecef;
  }
  .table tbody tr:hover {
    background-color: var(--primary-light);
  }
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
  }
  .badge-pending { background: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
  .badge-approved { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  .badge-rejected { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
  .btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    transition: all 0.2s;
    color: white;
    margin: 0 2px;
  }
  .btn-action i { font-size: 1rem; }
  .btn-edit { background: #ffc107; }
  .btn-edit:hover { background: #e0a800; transform: translateY(-2px); box-shadow: 0 5px 10px rgba(255,193,7,0.3); }
  .btn-delete { background: #dc3545; }
  .btn-delete:hover { background: #c82333; transform: translateY(-2px); box-shadow: 0 5px 10px rgba(220,53,69,0.3); }
  .btn-view { background: var(--primary-start); }
  .btn-view:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 5px 10px rgba(33,147,176,0.3); }
  .empty-state {
    padding: 3rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1rem;
    color: #6c757d;
  }
  .empty-state i {
    font-size: 3rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="page-header">
    <h2><i class="bi bi-journal-richtext me-2"></i>Kelola E-Library</h2>
    <p class="mb-0 opacity-75">Atur konten laporan magang, artikel dosen, penelitian, dan pengabdian</p>
  </div>

  <!-- Tab navigasi -->
  <div class="nav-tabs-custom">
    <a class="nav-link <%= currentType === 'all' ? 'active' : '' %>" href="/admin/elk-library?type=all">Semua</a>
    <a class="nav-link <%= currentType === 'laporan' ? 'active' : '' %>" href="/admin/elk-library?type=laporan">Laporan Magang</a>
    <a class="nav-link <%= currentType === 'artikel' ? 'active' : '' %>" href="/admin/elk-library?type=artikel">Artikel Dosen</a>
    <a class="nav-link <%= currentType === 'penelitian' ? 'active' : '' %>" href="/admin/elk-library?type=penelitian">Penelitian</a>
    <a class="nav-link <%= currentType === 'pengabdian' ? 'active' : '' %>" href="/admin/elk-library?type=pengabdian">Pengabdian</a>
  </div>

  <!-- Laporan Magang -->
  <% if (currentType === 'all' || currentType === 'laporan') { %>
    <div class="section-title"><i class="bi bi-file-earmark-pdf-fill"></i> Laporan Magang</div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr><th>Judul</th><th>Mahasiswa</th><th>Pembimbing</th><th>Tahun</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody>
            <% if (laporanList.length === 0) { %>
              <tr><td colspan="6" class="empty-state">Belum ada laporan magang.</td></tr>
            <% } else { %>
              <% laporanList.forEach(l => { %>
                <tr><td><%= l.judulPublik || '-' %></td>
                  <td><%= l.nama %> (<%= l.nim %>)</td>
                  <td><%= l.pembimbing || '-' %></td>
                  <td><%= l.tahun || '-' %></td>
                  <td><span class="badge-status <%= l.status === 'pending' ? 'badge-pending' : (l.status === 'approved' ? 'badge-approved' : 'badge-rejected') %>"><%= l.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/admin/elk-library/laporan/<%= l.id %>" class="btn-action btn-view"><i class="bi bi-eye"></i></a>
                      <a href="/admin/elk-library/laporan/<%= l.id %>/edit" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                      <form method="POST" action="/admin/elk-library/laporan/<%= l.id %>/delete" style="display:inline;" onsubmit="return confirm('Hapus?')">
                        <button class="btn-action btn-delete"><i class="bi bi-trash"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <!-- Artikel Dosen -->
  <% if (currentType === 'all' || currentType === 'artikel') { %>
    <div class="section-title"><i class="bi bi-file-text-fill"></i> Artikel Dosen</div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <td><th>Judul</th><th>Penulis</th><th>Tahun</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody>
            <% if (artikelList.length === 0) { %>
              <tr><td colspan="5" class="empty-state">Belum ada artikel dosen.</td></tr>
            <% } else { %>
              <% artikelList.forEach(a => { %>
                <tr><td><%= a.judul %></td>
                  <td><%= a.penulis || (a.authors ? a.authors.join(', ') : '-') %></td>
                  <td><%= a.publicationYear || a.tahun || '-' %></td>
                  <td><span class="badge-status <%= a.status === 'pending' ? 'badge-pending' : (a.status === 'approved' ? 'badge-approved' : 'badge-rejected') %>"><%= a.status %></span></td>
                  <td>
                    <a href="/admin/elk-library/artikel/<%= a.id %>" class="btn-action btn-view"><i class="bi bi-eye"></i></a>
                    <a href="/admin/elk-library/artikel/<%= a.id %>/edit" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                    <form method="POST" action="/admin/elk-library/artikel/<%= a.id %>/delete" style="display:inline"><button class="btn-action btn-delete"><i class="bi bi-trash"></i></button></form>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <!-- Penelitian -->
  <% if (currentType === 'all' || currentType === 'penelitian') { %>
    <div class="section-title"><i class="bi bi-mortarboard-fill"></i> Penelitian Dosen</div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr><th>Judul</th><th>Peneliti</th><th>Tahun</th><th>Jurnal</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody>
            <% if (penelitianList.length === 0) { %>
              <tr><td colspan="6" class="empty-state">Belum ada penelitian.</td></tr>
            <% } else { %>
              <% penelitianList.forEach(p => { %>
                <tr><td><%= p.judul %></td>
                  <td><%= p.dosenNama %></td>
                  <td><%= p.tahun %></td>
                  <td><%= p.namaJurnal || '-' %></td>
                  <td><span class="badge-status <%= p.status === 'pending' ? 'badge-pending' : (p.status === 'approved' ? 'badge-approved' : 'badge-rejected') %>"><%= p.status %></span></td>
                  <td>
                    <a href="/admin/elk-library/penelitian/<%= p.id %>" class="btn-action btn-view"><i class="bi bi-eye"></i></a>
                    <a href="/admin/elk-library/penelitian/<%= p.id %>/edit" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                    <form method="POST" action="/admin/elk-library/penelitian/<%= p.id %>/delete" style="display:inline"><button class="btn-action btn-delete"><i class="bi bi-trash"></i></button></form>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <!-- Pengabdian -->
  <% if (currentType === 'all' || currentType === 'pengabdian') { %>
    <div class="section-title"><i class="bi bi-people-fill"></i> Pengabdian Dosen</div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr><th>Judul / Kegiatan</th><th>Penanggung Jawab</th><th>Tahun</th><th>Mitra</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody>
            <% if (pengabdianList.length === 0) { %>
              <tr><td colspan="6" class="empty-state">Belum ada pengabdian.</td></tr>
            <% } else { %>
              <% pengabdianList.forEach(p => { %>
                <tr><td><%= p.judul || p.namaKegiatan %></td>
                  <td><%= p.dosenNama %></td>
                  <td><%= p.tahun %></td>
                  <td><%= p.mitra || '-' %></td>
                  <td><span class="badge-status <%= p.status === 'pending' ? 'badge-pending' : (p.status === 'approved' ? 'badge-approved' : 'badge-rejected') %>"><%= p.status %></span></td>
                  <td>
                    <a href="/admin/elk-library/pengabdian/<%= p.id %>" class="btn-action btn-view"><i class="bi bi-eye"></i></a>
                    <a href="/admin/elk-library/pengabdian/<%= p.id %>/edit" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
                    <form method="POST" action="/admin/elk-library/pengabdian/<%= p.id %>/delete" style="display:inline"><button class="btn-action btn-delete"><i class="bi bi-trash"></i></button></form>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>